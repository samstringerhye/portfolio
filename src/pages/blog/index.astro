---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
---

<BaseLayout title="Writing — Sam Stringer-Hye" description="Writing about design decisions, building with AI, and the details people skip.">
  <section class="blog-index" aria-label="Blog posts">
    <h1 class="blog-index-heading typo-display-md">Writing</h1>
    <div class="blog-index-inner">
      {allPosts.length === 0 && (
        <p class="blog-empty typo-body-lg">No posts yet. Check back soon.</p>
      )}

      {allPosts.map(post => (
        <article class="blog-row">
          <a href={`/blog/${post.id}`} class="blog-row-link" data-astro-prefetch="hover">
            <time class="blog-row-date typo-ui-caps" datetime={post.data.publishedDate.toISOString().slice(0, 10)}>
              {post.data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
            </time>
            <h2 class="blog-row-title typo-headline-lg">{post.data.title}</h2>
            <p class="blog-row-desc typo-body-lg">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-index {
    grid-column: 4 / 10;
    min-height: 75vh;
    padding-block: var(--space-6);
  }

  .blog-index-heading {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4);
  }

  .blog-index-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .blog-empty {
    color: var(--color-text-primary);
  }

  .blog-row-link {
    display: block;
    padding-block: var(--space-3);
    text-decoration: none;
    color: inherit;
  }

  .blog-row-date {
    display: block;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .blog-row-title {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    text-wrap: balance;
  }

  .blog-row-desc {
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: pretty;
    max-width: var(--prose-measure);
  }

  @media (--2x) {
    .blog-index {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }
  }
</style>
