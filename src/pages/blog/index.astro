---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
---

<BaseLayout title="Blog — Sam Stringer-Hye" description="Thoughts on design, development, and the space between.">
  <section class="blog-index" aria-label="Blog posts">
    <h1 class="blog-index-heading typo-display-md" data-reveal="line">Blog</h1>

    {allPosts.length === 0 && (
      <p class="blog-empty typo-body-lg" data-reveal="line">No posts yet. Check back soon.</p>
    )}

    {allPosts.map(post => (
      <article class="blog-row" data-reveal-group>
        <a href={`/blog/${post.id}`} class="blog-row-link" data-astro-prefetch="hover">
          <time class="blog-row-date typo-ui-caps" data-reveal="line" datetime={post.data.publishedDate.toISOString().slice(0, 10)}>
            {post.data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
          </time>
          <h2 class="blog-row-title typo-headline-lg" data-reveal="line">{post.data.title}</h2>
          <p class="blog-row-desc typo-body-lg" data-reveal="line">{post.data.description}</p>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .blog-index {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    padding-bottom: var(--space-6);
    min-height: 75vh;
  }

  .blog-index-heading {
    grid-column: 4 / 10;
    color: var(--color-text-primary);
    margin: 0;
    padding-block: var(--space-6);
  }

  .blog-empty {
    grid-column: 4 / 10;
    color: var(--color-text-primary);
  }

  .blog-row {
    grid-column: 4 / 10;
  }

  .blog-row-link {
    display: block;
    padding-block: var(--space-5);
    text-decoration: none;
    color: inherit;
  }

  .blog-row-date {
    display: block;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .blog-row-title {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    text-wrap: balance;
  }

  .blog-row-desc {
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: pretty;
    max-width: var(--prose-measure);
  }

  @media (--2x) {
    .blog-index-heading,
    .blog-empty,
    .blog-row {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }
  }
</style>
