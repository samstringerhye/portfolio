---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog'))
    .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())

  return allPosts.map((entry, i) => {
    const prev = allPosts[i - 1]
    const next = allPosts[i + 1]

    return {
      params: { slug: entry.id },
      props: {
        entry,
        prevSlug: prev?.id,
        prevTitle: prev?.data.title,
        nextSlug: next?.id,
        nextTitle: next?.data.title,
      },
    }
  })
}

const { entry, prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
const { Content } = await render(entry)

const publishedISO = entry.data.publishedDate.toISOString().slice(0, 10)
const publishedDisplay = entry.data.publishedDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC',
})

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://samstringerhye.com'

const blogPostLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": publishedISO,
  "url": `${siteUrl}/blog/${entry.id}`,
  "author": {
    "@type": "Person",
    "name": "Sam Stringer-Hye",
  },
}
---

<BaseLayout
  title={`${entry.data.title} — Sam Stringer-Hye`}
  description={entry.data.description}
  jsonLd={blogPostLd}
>
  <article class="blog-post">
    <header class="blog-post-header">
      <time class="blog-post-date typo-ui-caps" datetime={publishedISO}>{publishedDisplay}</time>
      <h1 class="blog-post-title typo-display-md">{entry.data.title}</h1>
      {entry.data.description && (
        <p class="blog-post-desc typo-body-lg">{entry.data.description}</p>
      )}
    </header>

    <div class="blog-post-body typo-body-lg">
      <Content />
    </div>

    <nav class="blog-post-nav" aria-label="Blog post navigation">
      <a href="/blog" class="blog-post-back typo-ui" data-astro-prefetch="hover">&larr; All posts</a>
      <div class="blog-post-nav-links">
        {prevSlug ? (
          <a href={`/blog/${prevSlug}`} class="blog-post-nav-link typo-ui" data-astro-prefetch="hover">
            &larr; {prevTitle}
          </a>
        ) : <span />}
        {nextSlug ? (
          <a href={`/blog/${nextSlug}`} class="blog-post-nav-link typo-ui" data-astro-prefetch="hover">
            {nextTitle} &rarr;
          </a>
        ) : <span />}
      </div>
    </nav>
  </article>
</BaseLayout>

<style>
  .blog-post {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    min-height: 75vh;
  }

  .blog-post-header {
    grid-column: 4 / 10;
    padding-block: var(--space-6) var(--space-2);
  }

  .blog-post-date {
    display: block;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .blog-post-title {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    text-wrap: balance;
  }

  .blog-post-desc {
    color: var(--color-text-primary);
    margin: 0;
    max-width: var(--prose-measure);
  }

  .blog-post-body {
    grid-column: 4 / 10;
    padding-block: var(--space-2) var(--space-6);
    max-width: var(--prose-measure);
  }

  .blog-post-body :global(p),
  .blog-post-body :global(ul),
  .blog-post-body :global(ol),
  .blog-post-body :global(li),
  .blog-post-body :global(blockquote) {
    font-size: inherit;
    line-height: inherit;
  }

  .blog-post-body :global(h2) {
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
  }

  .blog-post-body :global(h3) {
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
  }

  .blog-post-body :global(p) {
    margin-bottom: var(--space-3);
  }

  .blog-post-body :global(ul),
  .blog-post-body :global(ol) {
    margin-bottom: var(--space-3);
    padding-left: 1.25em;
  }

  .blog-post-body :global(li) {
    margin-bottom: var(--space-1);
  }

  .blog-post-body :global(blockquote) {
    position: relative;
    padding-left: var(--space-3);
    color: var(--color-text-primary);
    margin-block: var(--space-3);
  }

  .blog-post-body :global(blockquote)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleY(var(--border-draw, 1));
    transform-origin: top;
  }

  .blog-post-body :global(code) {
    background: var(--prose-code-bg);
    padding: var(--prose-code-padding-block) var(--prose-code-padding-inline);
    border-radius: var(--prose-code-border-radius);
    font-size: 0.9em;
  }

  .blog-post-body :global(pre) {
    background: var(--prose-code-bg);
    padding: var(--prose-code-block-padding);
    border-radius: var(--prose-code-block-radius);
    overflow-x: auto;
    margin-bottom: var(--space-3);
  }

  .blog-post-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .blog-post-body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin-block: var(--space-3);
  }

  .blog-post-nav {
    grid-column: 4 / 10;
    padding-block: var(--space-5);
  }

  .blog-post-back {
    display: inline-block;
    color: var(--color-text-primary);
    text-decoration: none;
    margin-bottom: var(--space-3);
  }

  .blog-post-back:hover {
    text-decoration: underline;
  }

  .blog-post-nav-links {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .blog-post-nav-link {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .blog-post-nav-link:hover {
    text-decoration: underline;
  }

  @media (--2x) {
    .blog-post-header,
    .blog-post-body,
    .blog-post-nav {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }
  }
</style>
