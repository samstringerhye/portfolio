---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Contact — Sam Stringer-Hye" description="Get in touch with Sam Stringer-Hye.">
  <section class="contact-page" aria-label="Contact">
    <div class="contact-body">
      <h1 class="typo-display-md contact-heading">Get in touch</h1>
      <p class="typo-body-lg contact-intro">Say hello, pitch a project, or ask me something. I read everything.</p>

      <form class="contact-form" id="contact-form" novalidate>
        <div class="contact-field">
          <label for="contact-name" class="typo-ui-caps">Name</label>
          <input type="text" id="contact-name" name="name" required autocomplete="name" />
        </div>
        <div class="contact-field">
          <label for="contact-email" class="typo-ui-caps">Email</label>
          <input type="email" id="contact-email" name="email" required autocomplete="email" />
        </div>
        <div class="contact-field">
          <label for="contact-message" class="typo-ui-caps">Message</label>
          <textarea id="contact-message" name="message" rows="6" required></textarea>
        </div>
        <label for="website" style="position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; overflow: hidden;">Leave this field empty
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; overflow: hidden;" />
        </label>
        <input type="hidden" id="form-loaded" name="form_loaded" />
        <button type="submit" class="contact-submit typo-ui">Send message</button>
        <p class="contact-status" id="contact-status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    min-height: 75vh;
  }

  .contact-body {
    grid-column: 4 / 10;
    padding-block: var(--space-6);
  }

  .contact-heading {
    margin: 0 0 var(--space-3);
  }

  .contact-intro {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6);
    max-width: var(--prose-measure);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--prose-measure);
  }

  .contact-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-field label {
    color: var(--color-text-primary);
  }

  .contact-field input,
  .contact-field textarea {
    padding: var(--space-2);
    background: transparent;
    border: var(--border-width-1) solid var(--color-rule);
    color: var(--color-text-primary);
    font-family: var(--font-primary);
    font-size: var(--text-100);
    line-height: var(--line-height-normal);
    transition: border-color var(--duration-short) ease;
  }

  .contact-field input:focus-visible,
  .contact-field textarea:focus-visible {
    outline: none;
    border-color: var(--color-text-primary);
    box-shadow: var(--focus-ring);
  }

  .contact-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    align-self: flex-start;
    padding: var(--space-2) var(--space-4);
    min-height: 44px;
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
    border: none;
    cursor: pointer;
    transition: opacity var(--duration-short) ease;
  }

  .contact-submit:disabled {
    opacity: var(--opacity-50);
    cursor: not-allowed;
  }

  @media (hover: hover) {
    .contact-submit:hover:not(:disabled) {
      opacity: var(--opacity-80);
    }
  }

  .contact-status {
    font-size: var(--text-100);
    margin: 0;
    min-height: 1.5em;
  }

  .contact-status.is-success {
    color: var(--color-text-primary);
  }

  .contact-status.is-error {
    color: var(--color-accent-1);
  }

  @media (--2x) {
    .contact-body {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }
  }
</style>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null
    if (!form) return
    if (form.dataset.bound === 'true') return
    form.dataset.bound = 'true'

    const status = document.getElementById('contact-status')!
    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement
    ;(form.querySelector('#form-loaded') as HTMLInputElement).value = String(Date.now())

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      status.textContent = ''
      status.className = 'contact-status'

      const data = {
        name: (form.querySelector('#contact-name') as HTMLInputElement).value.trim(),
        email: (form.querySelector('#contact-email') as HTMLInputElement).value.trim(),
        message: (form.querySelector('#contact-message') as HTMLTextAreaElement).value.trim(),
        website: (form.querySelector('#website') as HTMLInputElement).value,
        form_loaded: (form.querySelector('#form-loaded') as HTMLInputElement).value,
      }

      if (!data.name || !data.email || !data.message) {
        status.textContent = 'Please fill in all fields.'
        status.classList.add('is-error')
        return
      }

      submit.disabled = true
      submit.textContent = 'Sending...'

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })

        const result = await res.json()

        if (res.ok) {
          status.textContent = 'Message sent. I\'ll be in touch.'
          status.classList.add('is-success')
          form.reset()
        } else {
          status.textContent = result.error || 'Something went wrong.'
          status.classList.add('is-error')
        }
      } catch {
        status.textContent = 'Failed to send. Please try again.'
        status.classList.add('is-error')
      } finally {
        submit.disabled = false
        submit.textContent = 'Send message'
      }
    })
  }

  initContactForm()
  document.addEventListener('astro:page-load', initContactForm)
</script>
