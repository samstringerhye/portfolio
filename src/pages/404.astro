---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="404 — Page Not Found" description="Page not found." hideFooter={true}>
  <meta slot="head" name="robots" content="noindex" />
  <section class="not-found" aria-label="Page not found">
    <p class="typo-ui-caps" style="color: var(--color-text-secondary);">404</p>
    <h1 class="typo-display-lg">Page not found</h1>
    <p class="typo-body-lg">Nothing here. Just empty pixels.</p>
    <div class="not-found-actions">
      <a href="/" class="not-found-link typo-body-lg">Back to home</a>
      <a href="/work" class="not-found-link typo-body-lg">See work</a>
      <a href="/about" class="not-found-link typo-body-lg">About</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - var(--nav-height));
    padding: var(--space-4);
    gap: var(--space-2);
  }

  .not-found-actions {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .not-found-link {
    padding: var(--space-1) var(--space-4);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border: var(--border-light);
    border-radius: var(--radius-sm);
    transition: box-shadow var(--duration-long) ease, transform var(--duration-short) ease;
  }

  @media (hover: hover) {
    .not-found-link:hover {
      transform: translateY(var(--hover-lift));
    }
  }
</style>
