---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allWork = (await getCollection('work'))
  .filter(e => !e.data.unlisted)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)

const siteUrl = 'https://samstringerhye.com'

const workJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Selected Work",
    "itemListElement": allWork.map((entry, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": entry.data.title,
      "url": `${siteUrl}/work/${entry.id}`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Work", "item": `${siteUrl}/work` },
    ],
  },
]
---

<BaseLayout title="Work — Sam Stringer-Hye" description="Selected case studies from Samsung, Frontier, CVS, and more — $143M+ in measurable conversion impact." jsonLd={workJsonLd}>
  <section class="work-index" aria-label="All work">
    <h1 class="work-index-heading typo-display-md">Work</h1>
    {allWork.map((entry, i) => (
      <article class:list={['work-row', { 'work-row--reversed': i % 2 !== 0 }]}>
        <div class="work-row-image">
          <Image
            src={entry.data.thumbnail}
            alt={entry.data.title}
            width={1600}
            format="webp"
            quality={90}
            loading="eager"
          />
        </div>
        <div class="work-row-info">
          <p class="work-row-year typo-ui-caps">{entry.data.year}</p>
          <h2 class="work-row-title typo-headline-lg">{entry.data.title}</h2>
          <p class="work-row-tagline typo-body-lg">{entry.data.tagline}</p>
          <a href={`/work/${entry.id}`} class="work-row-link typo-body-lg" aria-label={`View ${entry.data.title} project`}>
            View project <Icon name="material-symbols:arrow-forward-sharp" class="work-row-arrow" />
          </a>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .work-index {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
  }

  .work-index-heading {
    grid-column: 1 / -1;
    color: var(--color-text-primary);
    margin: 0;
    padding: var(--space-6);
  }

  .work-row {
    position: relative;
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    padding: 0;
  }

  .work-row::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .work-row:last-child::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }


  /* Default: image left 50%, text right 50% */
  .work-row-image {
    grid-column: 1;
    grid-row: 1;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .work-row-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-row-info {
    position: relative;
    grid-column: 2;
    grid-row: 1;
    padding: var(--content-inset-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .work-row-info::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleY(var(--border-draw, 1));
    transform-origin: top;
  }

  /* Reversed: text left 50%, image right 50% */
  .work-row--reversed .work-row-info {
    grid-column: 1;
  }

  .work-row--reversed .work-row-info::before {
    display: none;
  }

  .work-row--reversed .work-row-image {
    position: relative;
    grid-column: 2;
  }

  .work-row--reversed .work-row-image::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleY(var(--border-draw, 1));
    transform-origin: top;
    z-index: 1;
  }

  .work-row-year {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
  }

  .work-row-title {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    text-wrap: balance;
  }

  .work-row-tagline {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4);
    text-wrap: pretty;
  }

  .work-row-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .work-row-arrow {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform var(--duration-short) ease;
  }

  @media (hover: hover) {
    .work-row-link:hover .work-row-arrow {
      transform: translateX(4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-row-image img {
      transition: none;
    }
  }

  /* ── Mobile ── */
  @media (--2x) {
    .work-row {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0;
    }

    .work-row-image,
    .work-row--reversed .work-row-image {
      grid-column: 1 / -1;
      grid-row: auto;
      padding: 0;
      aspect-ratio: 4 / 3;
      overflow: hidden;
    }

    .work-index-heading {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }

    .work-row-info,
    .work-row--reversed .work-row-info {
      grid-column: 1 / -1;
      grid-row: auto;
      padding: var(--content-inset-md);
    }

    .work-row-info::before,
    .work-row--reversed .work-row-info::before {
      display: none;
    }

    .work-row--reversed .work-row-image::before {
      display: none;
    }
  }
</style>
