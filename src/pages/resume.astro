---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Resume — Sam Stringer-Hye" description="Resume for Sam Stringer-Hye — Associate Design Director with 13+ years in UI/UX, design systems, and interactive experiences.">
  <section class="resume-page" aria-label="Resume">
    <div class="resume-body">

      <header class="resume-header">
        <h1 class="typo-display-md">Sam Stringer-Hye</h1>
        <p class="resume-contact typo-body-sm">
          Philadelphia, PA · (615) 739-8930 · <a href="https://linkedin.com/in/samstringerhye" target="_blank" rel="noopener noreferrer">LinkedIn</a> · <a href="/contact">Contact</a>
        </p>
      </header>

      <p class="resume-summary typo-body-lg">
        Associate Design Director with 13+ years designing interfaces, design systems, and interactive experiences across e-commerce, consumer apps, and media. Work on Samsung.com contributed to a 10% conversion lift ($143M in additional revenue). Strong prototyping background that connects design intent to real implementation. Shipped for Samsung, CVS, Frontier, Barclays, and Mashable. Now building at the intersection of design and code, using agentic AI and creative coding to ship work directly.
      </p>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Experience</h2>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Associate Design Director</h3>
            <p class="resume-entry-meta typo-body-sm">Razorfish · Oct 2021 – Present · Remote</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Led UX and production design for Samsung's Bespoke Design Studio, a luxury appliance customization tool. Research-driven iteration reduced exit rates 14% and increased add-to-cart 24%.</li>
            <li>Owned design system development and page-level UX for Samsung.com and Frontier's MyFrontier app. Samsung work contributed to a 10% conversion lift ($143M in additional revenue). Frontier saw a 22% increase in autopay sign-ups.</li>
            <li>Built a flexible design system for CVS Pharmacy's e-commerce platform, modernizing the shopping experience and increasing conversion 12%.</li>
            <li>Created CRM brand guidelines and Figma component templates for Samsung, cutting production time by 50%.</li>
            <li>Won W3 Award Best in Show for Best Interactive Design, Emerging Tech Features for Samsung SmartThings Hub (2025).</li>
            <li>Founded a Designers & AI Craft Group focused on integrating emerging tools into production workflows.</li>
            <li>Mentor junior designers on systems thinking, UX craft, and career growth.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Senior Designer</h3>
            <p class="resume-entry-meta typo-body-sm">Razorfish · Jun 2018 – Oct 2021 · New York, NY</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Designed prototypes and motion interactions for Samsung's Smart Home marketing page, driving a 5% increase in SmartThings sales.</li>
            <li>Built prototypes and user flows for Barclays' finance app, improving customer satisfaction scores 10%.</li>
            <li>Designed motion and interaction systems for Pilot Flying J's mobile app. Dynamic micro-interactions contributed to a 15% increase in positive app reviews.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Motion & Product Designer</h3>
            <p class="resume-entry-meta typo-body-sm">Independent · Aug 2016 – Jun 2018 · New York, NY</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Created an interactive motion system for Walmart's voice-activated eCommerce platform pitch, prototyping a dynamic voice persona through animation.</li>
            <li>Developed motion concepts for a McDonald's drive-thru redesign pitch.</li>
            <li>Built an interactive motion prototype for Google's editorial platform, bridging animation intent and developer handoff.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Art Director</h3>
            <p class="resume-entry-meta typo-body-sm">Mashable · Mar 2014 – Aug 2016 · New York, NY</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Led design and art direction for Mashable's Snapchat Discover launch, defining visual identity and brand voice for a new platform and audience.</li>
            <li>Built cross-platform motion design systems across six digital channels. Coordinated animators, illustrators, editors, and producers on daily production.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Motion Designer</h3>
            <p class="resume-entry-meta typo-body-sm">NowThis News · Aug 2012 – Mar 2014 · New York, NY</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Created motion templates that streamlined production and maintained brand consistency across viral social content.</li>
            <li>Redesigned the brand identity at a pivotal early stage, building a visual system that strengthened recognition across social platforms.</li>
          </ul>
        </div>
      </div>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Awards</h2>
        <p class="typo-body-lg"><strong>W3 Award · Best in Show</strong> – Best Interactive Design, Emerging Tech Features<br />Samsung SmartThings Hub · Razorfish · 2025</p>
      </div>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Education</h2>
        <p class="typo-body-lg"><strong>BFA in Film Editing</strong> · Watkins College of Art, Design & Film · Nashville, TN · 2012</p>
      </div>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Skills</h2>
        <dl class="resume-skills">
          <div class="resume-skill-row">
            <dt class="typo-body-lg"><strong>Design</strong></dt>
            <dd class="typo-body-lg">UI/UX, Design Systems, Motion Design, Interaction Prototyping, Typography, Branding, User Research</dd>
          </div>
          <div class="resume-skill-row">
            <dt class="typo-body-lg"><strong>Tools</strong></dt>
            <dd class="typo-body-lg">Figma, After Effects, Photoshop, Illustrator, Framer, ProtoPie, Astro, Three.js, GSAP, Blender, Midjourney</dd>
          </div>
          <div class="resume-skill-row">
            <dt class="typo-body-lg"><strong>Practice</strong></dt>
            <dd class="typo-body-lg">Cross-functional collaboration, client engagement, mentoring, storytelling</dd>
          </div>
        </dl>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .resume-page {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
  }

  .resume-body {
    grid-column: 4 / 10;
    padding-block: var(--space-6);
  }

  .resume-header {
    margin-bottom: var(--space-4);
  }

  .resume-header h1 {
    margin: 0;
  }

  .resume-contact {
    margin-top: var(--space-1);
    color: var(--color-text-secondary);
  }

  .resume-contact a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .resume-summary {
    position: relative;
    color: var(--color-text-primary);
    max-width: var(--prose-measure);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
  }

  .resume-summary::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .resume-section {
    margin-bottom: var(--space-5);
  }

  .resume-section-heading {
    position: relative;
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
  }

  .resume-section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .resume-entry {
    padding-block: var(--space-3);
  }

  .resume-entry {
    position: relative;
  }

  .resume-entry + .resume-entry::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-border);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }


  .resume-entry-header {
    margin-bottom: var(--space-2);
  }

  .resume-entry-header h3 {
    margin: 0;
  }

  .resume-entry-meta {
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }

  .resume-list {
    list-style: disc;
    padding-left: 1.25em;
    margin: 0;
    color: var(--color-text-primary);
    max-width: var(--prose-measure);
  }

  .resume-list li {
    margin-bottom: var(--space-1);
  }

  .resume-list li:last-child {
    margin-bottom: 0;
  }

  .resume-skills {
    margin: 0;
  }

  .resume-skill-row {
    display: flex;
    gap: var(--space-2);
    padding-block: var(--space-1);
  }

  .resume-skill-row dt {
    flex-shrink: 0;
    min-width: 5rem;
  }

  .resume-skill-row dd {
    margin: 0;
    color: var(--color-text-primary);
  }

  @media (--2x) {
    .resume-body {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }

    .resume-skill-row {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
