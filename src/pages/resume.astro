---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Resume — Sam Stringer-Hye" description="Resume for Sam Stringer-Hye — Associate Design Director with 13+ years in UI/UX, design systems, and interactive experiences.">
  <section class="resume-page" aria-label="Resume">
    <div class="resume-body">

      <header class="resume-header">
        <div class="resume-header-row">
          <h1 class="typo-headline-lg">Sam Stringer-Hye</h1>
          <button type="button" class="resume-download typo-ui-caps" id="resume-download" aria-label="Download resume as PDF">Download PDF</button>
        </div>
        <p class="resume-subtitle typo-body-lg">Associate Design Director</p>
        <p class="resume-contact typo-body-sm">
          Philadelphia, PA · <a href="https://linkedin.com/in/samstringerhye" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </p>
      </header>

      <p class="resume-summary typo-body-lg">
        Associate Design Director with 13+ years designing interfaces, design systems, and interactive experiences across e-commerce, consumer apps, and media. Work on Samsung.com contributed to a 10% conversion lift ($143M in additional revenue). Prototyping background in After Effects, ProtoPie, and code. Shipped for Samsung, CVS, Frontier, Barclays, and Mashable. Now designing and building with agentic AI and creative coding.
      </p>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Experience</h2>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Associate Design Director</h3>
            <p class="resume-entry-meta typo-body-sm">Razorfish · Remote · Oct 2021 – Present</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Led UX and production design for Samsung's Bespoke Design Studio, a luxury appliance customization tool. Research-driven iteration reduced exit rates 14% and increased add-to-cart 24%.</li>
            <li>Owned design system development and page-level UX for Samsung.com and Frontier's MyFrontier app. Samsung work contributed to a 10% conversion lift ($143M in additional revenue). Frontier saw a 22% increase in autopay sign-ups.</li>
            <li>Built a flexible design system for CVS Pharmacy's e-commerce platform, replacing fragmented components with composable primitives. Conversion increased 12%.</li>
            <li>Created CRM brand guidelines and Figma component templates for Samsung, cutting production time by 50%.</li>
            <li>Won W3 Award Best in Show for Best Interactive Design, Emerging Tech Features for Samsung SmartThings Hub (2025).</li>
            <li>Founded a Designers & AI Craft Group that brought generative AI tools into active client work.</li>
            <li>Mentor junior designers on systems thinking, UX craft, and career growth.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Senior Designer</h3>
            <p class="resume-entry-meta typo-body-sm">Razorfish · New York, NY · Jun 2018 – Oct 2021</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Designed prototypes and motion interactions for Samsung's Smart Home marketing page, driving a 5% increase in SmartThings sales.</li>
            <li>Built prototypes and user flows for Barclays' finance app, improving customer satisfaction scores 10%.</li>
            <li>Designed motion and interaction systems for Pilot Flying J's mobile app. Micro-interactions contributed to a 15% increase in positive app reviews.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Motion & Product Designer</h3>
            <p class="resume-entry-meta typo-body-sm">Independent · New York, NY · Aug 2016 – Jun 2018</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Created an interactive motion system for Walmart's voice-activated eCommerce platform pitch, animating a voice persona through motion.</li>
            <li>Developed motion concepts for a McDonald's drive-thru redesign pitch.</li>
            <li>Built an interactive motion prototype for Google's editorial platform with animation specs built for developer handoff.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Art Director</h3>
            <p class="resume-entry-meta typo-body-sm">Mashable · New York, NY · Mar 2014 – Aug 2016</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Led design and art direction for Mashable's Snapchat Discover launch, defining visual identity and brand voice for a new platform and audience.</li>
            <li>Built cross-platform motion design systems across six digital channels. Coordinated animators, illustrators, editors, and producers on daily production.</li>
          </ul>
        </div>

        <div class="resume-entry">
          <div class="resume-entry-header">
            <h3 class="typo-title-lg">Motion Designer</h3>
            <p class="resume-entry-meta typo-body-sm">NowThis News · New York, NY · Aug 2012 – Mar 2014</p>
          </div>
          <ul class="resume-list typo-body-lg">
            <li>Created motion templates that sped up production and maintained brand consistency across viral social content.</li>
            <li>Redesigned the brand identity at a pivotal early stage, building the visual system NowThis used across its social channels.</li>
          </ul>
        </div>
      </div>

      <div class="resume-section resume-awards">
        <h2 class="resume-section-heading typo-headline-sm">Awards</h2>
        <p class="typo-body-lg"><strong>W3 Award · Best in Show</strong> – Best Interactive Design, Emerging Tech Features<br />Samsung SmartThings Hub · Razorfish · 2025</p>
      </div>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Education</h2>
        <p class="typo-body-lg"><strong>BFA in Film Editing</strong> · Watkins College of Art, Design & Film · Nashville, TN · 2012</p>
      </div>

      <div class="resume-section">
        <h2 class="resume-section-heading typo-headline-sm">Skills</h2>
        <p class="resume-skills-line typo-body-lg"><strong>Design:</strong> UI/UX, Design Systems, Motion Design, Interaction Prototyping, Typography, Branding, User Research</p>
        <p class="resume-skills-line typo-body-lg"><strong>Tools:</strong> Figma, After Effects, Photoshop, Illustrator, Framer, ProtoPie, Astro, Three.js, GSAP, Blender, Midjourney</p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .resume-page {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
  }

  .resume-body {
    grid-column: 4 / 10;
    padding-block: var(--space-6);
  }

  .resume-header {
    margin-bottom: var(--space-4);
  }

  .resume-header-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .resume-header h1 {
    margin: 0;
    flex: 1;
  }

  .resume-download {
    flex-shrink: 0;
    padding: var(--space-1) var(--space-3);
    min-height: 44px;
    background: transparent;
    color: var(--color-text-primary);
    border: var(--border-width-1) solid var(--color-rule);
    cursor: pointer;
    transition: opacity var(--duration-short) ease;
  }

  @media (hover: hover) {
    .resume-download:hover {
      opacity: var(--opacity-50);
    }
  }

  .resume-subtitle {
    color: var(--color-text-secondary);
    margin: var(--space-1) 0 0;
  }

  .resume-contact {
    color: var(--color-text-secondary);
    display: none;
  }

  .resume-contact a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .resume-summary {
    position: relative;
    color: var(--color-text-primary);
    max-width: var(--prose-measure);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
  }

  .resume-summary::after {
    display: none;
  }

  .resume-section {
    margin-bottom: var(--space-5);
  }

  .resume-section-heading {
    position: relative;
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
  }

  .resume-section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .resume-entry {
    padding-block: var(--space-3);
  }

  .resume-entry {
    position: relative;
  }

  .resume-entry + .resume-entry::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-border);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }


  .resume-entry-header {
    margin-bottom: var(--space-2);
  }

  .resume-entry-header h3 {
    margin: 0;
  }

  .resume-entry-meta {
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }

  .resume-list {
    list-style: disc;
    padding-left: 1.25em;
    margin: 0;
    color: var(--color-text-primary);
    max-width: var(--prose-measure);
  }

  .resume-list li {
    margin-bottom: var(--space-1);
  }

  .resume-list li:last-child {
    margin-bottom: 0;
  }

  .resume-skills-line {
    color: var(--color-text-primary);
    margin: 0 0 var(--space-1);
    max-width: var(--prose-measure);
  }

  .resume-skills-line:last-child {
    margin-bottom: 0;
  }

  @media (--2x) {
    .resume-body {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }
  }

  /* ── Print / PDF stylesheet ── */
  @media print {
    /* Hide site chrome */
    :global(.nav),
    :global(.footer),
    :global(.grid-overlay),
    :global(.skip-to-content),
    :global(.scroll-progress),
    .resume-download {
      display: none !important;
    }

    @page {
      size: letter;
      margin: 0;
    }

    /*
     * Print type system: 3 sizes only
     * Name: 12pt  |  Section heads: 10pt bold  |  Everything else: 8pt
     */

    :global(html), :global(body) {
      background: #fff !important;
      color: #333 !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      font-size: 8pt !important;
      line-height: 1.4 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* Override serif headline classes for print */
    .resume-body :global([class*="typo-"]) {
      font-family: 'Inter', system-ui, sans-serif !important;
    }

    :global(main) {
      display: block !important;
      padding: 0 !important;
    }

    .resume-page {
      display: block !important;
      padding: 0.45in 0.55in 0.4in !important;
    }

    .resume-body {
      grid-column: unset !important;
      padding: 0 !important;
      max-width: none !important;
    }

    /* Hide color strip for ATS */
    .resume-page::before {
      display: none !important;
    }

    /* Header — name left, contact right */
    .resume-header {
      margin-bottom: 8pt !important;
    }

    .resume-header-row {
      display: block !important;
      margin-bottom: 2pt !important;
    }

    .resume-header h1 {
      font-size: 12pt !important;
      font-weight: 700 !important;
      line-height: 1.1 !important;
      margin-bottom: 0 !important;
      color: #1a1a1a !important;
      flex-shrink: 0 !important;
    }

    .resume-subtitle {
      font-size: 8pt !important;
      margin: 2pt 0 0 !important;
      color: #555 !important;
    }

    .resume-contact {
      font-size: 8pt !important;
      margin-top: 2pt !important;
      color: #888 !important;
    }

    .resume-contact a {
      color: #888 !important;
      text-decoration: none !important;
    }

    /* Summary */
    .resume-summary {
      font-size: 8pt !important;
      line-height: 1.4 !important;
      margin-bottom: 8pt !important;
      padding-bottom: 8pt !important;
      max-width: none !important;
      color: #333 !important;
    }

    .resume-summary::after {
      display: none !important;
    }

    /* Sections */
    .resume-section {
      margin-bottom: 8pt !important;
    }

    .resume-section-heading {
      font-size: 10pt !important;
      font-weight: 700 !important;
      text-transform: none !important;
      letter-spacing: normal !important;
      margin-bottom: 4pt !important;
      padding-bottom: 2pt !important;
      color: #1a1a1a !important;
    }

    .resume-section-heading::after {
      transform: scaleX(1) !important;
      background: #ddd !important;
    }

    /* Entries */
    .resume-entry {
      padding-block: 2pt !important;
    }

    .resume-entry + .resume-entry::before {
      display: none !important;
    }

    .resume-entry-header {
      margin-bottom: 2pt !important;
    }

    .resume-entry-header h3 {
      font-size: 8pt !important;
      font-weight: 600 !important;
      color: #1a1a1a !important;
    }

    .resume-entry-meta {
      font-size: 8pt !important;
      margin-top: 2pt !important;
      color: #888 !important;
    }

    .resume-list {
      font-size: 8pt !important;
      line-height: 1.35 !important;
      padding-left: 1.2em !important;
      max-width: none !important;
      color: #333 !important;
      margin-top: 2pt !important;
    }

    .resume-list li {
      margin-bottom: 1pt !important;
    }

    .resume-list li::marker {
      color: #ccc !important;
    }

    /* Skills + Education */
    .resume-skills-line,
    .resume-section > p {
      font-size: 8pt !important;
      color: #333 !important;
      max-width: none !important;
    }

    .resume-section > p strong {
      color: #1a1a1a !important;
    }

    /* Hide awards in print */
    .resume-awards {
      display: none !important;
    }

    /* Prevent page breaks inside entries */
    .resume-entry,
    .resume-section {
      break-inside: avoid;
    }

  }
</style>

<script>
  function initResumeDownload() {
    const btn = document.getElementById('resume-download')
    if (!btn) return
    if (btn.dataset.bound === 'true') return
    btn.dataset.bound = 'true'

    btn.addEventListener('click', () => {
      window.print()
    })
  }

  initResumeDownload()
  document.addEventListener('astro:page-load', initResumeDownload)
</script>
