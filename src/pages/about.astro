---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="About — Sam Stringer-Hye" description="About Sam Stringer-Hye — Associate Design Director at Razorfish.">
  <section class="about-page" aria-label="About">
    <div class="about-body">
      <img src="https://media1.tenor.com/m/9ItR8nSuxE0AAAAd/thumbs-up-computer.gif" alt="Kid at computer giving thumbs up" class="about-gif" width="498" height="498" loading="lazy" />

      <h1 class="about-name typo-display-md">All that screen time actually led somewhere</h1>

      <p class="about-bio typo-body-lg">
        I got my first computer at seven and never really looked up. What started as a kid messing around online turned into a career designing products for Samsung, Frontier, and CVS. Currently at Razorfish, working on consumer-facing product design.
      </p>

      <p class="about-bio typo-body-lg">
        I'm the person who notices when the spacing is off, when a transition feels wrong, or when a component system only works in the deck. That instinct is the whole job. Making things feel right in a way that's hard to explain but easy to notice when it's missing.
      </p>

      <nav class="about-links" aria-label="Contact and resume">
        <a href="https://linkedin.com/in/samstringerhye" target="_blank" rel="noopener noreferrer" class="about-link typo-body-lg">
          <span>LinkedIn</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 15L15 5M15 5H8M15 5V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/resume" class="about-link typo-body-lg">
          <span>Resume</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 15L15 5M15 5H8M15 5V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    min-height: 75vh;
  }

  .about-body {
    grid-column: 4 / 10;
    padding-block: var(--space-6);
  }

  .about-name {
    margin: 0 0 var(--space-4);
  }

  .about-bio {
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
    max-width: var(--prose-measure);
  }

  .about-bio:last-of-type {
    margin-bottom: var(--space-8);
  }

  .about-gif {
    width: 100%;
    max-width: 280px;
    height: auto;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-4);
  }

  .about-links {
    display: flex;
    flex-direction: column;
  }

  .about-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-text-primary);
    text-decoration: none;
    padding-block: var(--space-3);
    min-height: 44px;
    transition: padding-left var(--duration-medium) ease;
  }

  .about-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .about-link:last-child::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }


  .about-link svg {
    flex-shrink: 0;
    transition: transform var(--duration-medium) ease;
  }

  @media (hover: hover) {
    .about-link:hover {
      padding-left: var(--space-2);
    }

    .about-link:hover svg {
      transform: translate(2px, -2px);
    }
  }

  @media (--2x) {
    .about-body {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }
  }
</style>
