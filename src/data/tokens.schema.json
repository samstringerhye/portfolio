{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tokens.schema.json",
  "title": "Design Tokens",
  "description": "M3-aligned design token schema (ref/sys) for Sam Stringer-Hye portfolio.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "ref": { "$ref": "#/definitions/ref" },
    "sys": { "$ref": "#/definitions/sys" },
    "elementMap": { "$ref": "#/definitions/elementMap" }
  },
  "required": ["ref", "sys", "elementMap"],
  "additionalProperties": false,

  "definitions": {

    "refPath": {
      "type": "string",
      "description": "Dot-path to a ref or sys leaf value"
    },

    "refObject": {
      "type": "object",
      "description": "A reference to a token value via dot-path",
      "properties": {
        "$ref": { "$ref": "#/definitions/refPath" }
      },
      "required": ["$ref"],
      "additionalProperties": false
    },

    "fluidRange": {
      "type": "object",
      "description": "A fluid clamp range with min/max rem values",
      "properties": {
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 }
      },
      "required": ["min", "max"],
      "additionalProperties": false
    },

    "fluidOrFixed": {
      "description": "Either a fixed number or a { min, max } fluid range",
      "oneOf": [
        { "type": "number", "minimum": 0 },
        { "$ref": "#/definitions/fluidRange" }
      ]
    },

    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
    },

    "cssLength": {
      "type": "string",
      "pattern": "^-?\\d+(\\.\\d+)?(px|rem|em|vh|vw|%)$"
    },

    "cssPx": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?px$"
    },

    "cssDuration": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?s$"
    },

    "cssEasing": {
      "type": "string",
      "pattern": "^cubic-bezier\\("
    },

    "cssShadow": {
      "type": "string"
    },

    "fontWeight": {
      "type": "number",
      "minimum": 100,
      "maximum": 900,
      "multipleOf": 100
    },

    "ref": {
      "type": "object",
      "description": "Reference (primitive) tokens",
      "properties": {
        "font": {
          "type": "object",
          "properties": {
            "family": {
              "type": "object",
              "properties": {
                "sans": { "type": "string" },
                "serif": { "type": "string" },
                "mono": { "type": "string" }
              },
              "additionalProperties": false
            },
            "weight": {
              "type": "object",
              "properties": {
                "regular": { "$ref": "#/definitions/fontWeight" },
                "medium": { "$ref": "#/definitions/fontWeight" },
                "semibold": { "$ref": "#/definitions/fontWeight" },
                "bold": { "$ref": "#/definitions/fontWeight" }
              },
              "additionalProperties": false
            },
            "scale": {
              "type": "object",
              "properties": {
                "50": { "$ref": "#/definitions/fluidOrFixed" },
                "75": { "$ref": "#/definitions/fluidOrFixed" },
                "100": { "$ref": "#/definitions/fluidOrFixed" },
                "200": { "$ref": "#/definitions/fluidOrFixed" },
                "300": { "$ref": "#/definitions/fluidOrFixed" },
                "400": { "$ref": "#/definitions/fluidOrFixed" },
                "500": { "$ref": "#/definitions/fluidOrFixed" },
                "600": { "$ref": "#/definitions/fluidOrFixed" },
                "700": { "$ref": "#/definitions/fluidOrFixed" }
              },
              "additionalProperties": false
            },
            "lineHeight": {
              "type": "object",
              "properties": {
                "tight": { "type": "number", "minimum": 0.5, "maximum": 3 },
                "normal": { "type": "number", "minimum": 0.5, "maximum": 3 }
              },
              "additionalProperties": false
            },
            "tracking": {
              "type": "object",
              "properties": {
                "tight": { "type": "number" },
                "normal": { "type": "number" },
                "wide": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "color": {
          "type": "object",
          "properties": {
            "neutral": {
              "type": "object",
              "properties": {
                "900": { "$ref": "#/definitions/hexColor" },
                "700": { "$ref": "#/definitions/hexColor" },
                "500": { "$ref": "#/definitions/hexColor" },
                "100": { "$ref": "#/definitions/hexColor" },
                "50": { "$ref": "#/definitions/hexColor" }
              },
              "additionalProperties": false
            },
            "alpha": {
              "type": "object",
              "properties": {
                "black8": { "$ref": "#/definitions/hexColor" },
                "black30": { "$ref": "#/definitions/hexColor" }
              },
              "additionalProperties": false
            },
            "accent": {
              "type": "object",
              "properties": {
                "1": { "$ref": "#/definitions/hexColor" },
                "2": { "$ref": "#/definitions/hexColor" },
                "3": { "$ref": "#/definitions/hexColor" }
              },
              "additionalProperties": false
            },
            "highlight": { "$ref": "#/definitions/hexColor" }
          },
          "additionalProperties": false
        },
        "spacing": {
          "type": "object",
          "patternProperties": {
            "^[1-8]$": { "$ref": "#/definitions/fluidOrFixed" }
          },
          "additionalProperties": false
        },
        "inlineSpacing": {
          "type": "object",
          "properties": {
            "1x": { "type": "string" },
            "2x": { "type": "string" }
          },
          "additionalProperties": false
        },
        "radii": {
          "type": "object",
          "properties": {
            "xs": { "$ref": "#/definitions/cssPx" },
            "sm": { "$ref": "#/definitions/cssPx" },
            "md": { "$ref": "#/definitions/cssPx" },
            "lg": { "$ref": "#/definitions/cssPx" },
            "full": { "$ref": "#/definitions/cssPx" }
          },
          "additionalProperties": false
        },
        "border": {
          "type": "object",
          "properties": {
            "width": {
              "type": "object",
              "properties": {
                "1": { "$ref": "#/definitions/cssPx" },
                "2": { "$ref": "#/definitions/cssPx" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "elevation": {
          "type": "object",
          "properties": {
            "0": { "$ref": "#/definitions/cssShadow" },
            "1": { "$ref": "#/definitions/cssShadow" },
            "2": { "$ref": "#/definitions/cssShadow" },
            "3": { "$ref": "#/definitions/cssShadow" },
            "4": { "$ref": "#/definitions/cssShadow" },
            "5": { "$ref": "#/definitions/cssShadow" }
          },
          "additionalProperties": false
        },
        "motion": {
          "type": "object",
          "properties": {
            "duration": {
              "type": "object",
              "properties": {
                "short": { "$ref": "#/definitions/cssDuration" },
                "medium": { "$ref": "#/definitions/cssDuration" },
                "long": { "$ref": "#/definitions/cssDuration" },
                "extra-long": { "$ref": "#/definitions/cssDuration" }
              },
              "additionalProperties": false
            },
            "easing": {
              "type": "object",
              "properties": {
                "standard": { "$ref": "#/definitions/cssEasing" },
                "decelerate": { "$ref": "#/definitions/cssEasing" },
                "accelerate": { "$ref": "#/definitions/cssEasing" },
                "emphasized": { "$ref": "#/definitions/cssEasing" }
              },
              "additionalProperties": false
            },
            "gsapEasing": {
              "type": "object",
              "properties": {
                "enter": { "type": "string" },
                "bounce": { "type": "string" },
                "bounceIn": { "type": "string" },
                "bounceMove": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "breakpoint": {
          "type": "object",
          "properties": {
            "1x": { "type": "number" },
            "2x": { "type": "number" },
            "3x": { "type": "number" }
          },
          "additionalProperties": false
        },
        "zIndex": {
          "type": "object",
          "properties": {
            "1x": { "type": "integer" },
            "overlay": { "type": "integer" },
            "modal": { "type": "integer" },
            "toast": { "type": "integer" },
            "shutter": { "type": "integer" },
            "debug": { "type": "integer" }
          },
          "additionalProperties": false
        },
        "sizing": {
          "type": "object",
          "properties": {
            "navHeight": { "type": "string" },
            "modalMaxWidth": { "type": "string" },
            "modalMaxHeight": { "type": "string" },
            "scrollbarWidth": { "$ref": "#/definitions/cssPx" },
            "sectionRuleMark": { "type": "string" },
            "wordmark": { "type": "string" },
            "wordmarkMobile": { "type": "string" },
            "touchTarget": { "$ref": "#/definitions/cssPx" },
            "navToggleBarWidth": { "$ref": "#/definitions/cssPx" },
            "navToggleBarHeight": { "type": "string" },
            "navToggleGap": { "$ref": "#/definitions/cssPx" },
            "proseMeasure": { "type": "string" }
          },
          "additionalProperties": false
        },
        "blur": {
          "type": "object",
          "properties": {
            "1x": { "$ref": "#/definitions/cssPx" }
          },
          "additionalProperties": false
        },
        "opacity": {
          "type": "object",
          "properties": {
            "30": { "type": "number", "minimum": 0, "maximum": 1 },
            "50": { "type": "number", "minimum": 0, "maximum": 1 },
            "60": { "type": "number", "minimum": 0, "maximum": 1 },
            "80": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "interaction": {
          "type": "object",
          "properties": {
            "lift": { "$ref": "#/definitions/cssLength" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "typographyRole": {
      "type": "object",
      "description": "A typography role composing font primitives",
      "properties": {
        "family": { "$ref": "#/definitions/refObject" },
        "weight": { "$ref": "#/definitions/refObject" },
        "scale": { "$ref": "#/definitions/refObject" },
        "lineHeight": { "$ref": "#/definitions/refObject" },
        "tracking": { "$ref": "#/definitions/refObject" }
      },
      "required": ["family", "weight", "scale", "lineHeight", "tracking"],
      "additionalProperties": false
    },

    "sys": {
      "type": "object",
      "description": "System (semantic) tokens mapped to ref via $ref",
      "properties": {
        "color": {
          "type": "object",
          "properties": {
            "text": {
              "type": "object",
              "properties": {
                "primary": { "$ref": "#/definitions/refObject" },
                "secondary": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            },
            "bg": {
              "type": "object",
              "properties": {
                "primary": { "$ref": "#/definitions/refObject" },
                "alt": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            },
            "rule": { "$ref": "#/definitions/refObject" },
            "accent": {
              "type": "object",
              "properties": {
                "1": { "$ref": "#/definitions/refObject" },
                "2": { "$ref": "#/definitions/refObject" },
                "3": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            },
            "border": { "$ref": "#/definitions/refObject" },
            "backdrop": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "focus": {
          "type": "object",
          "properties": {
            "ring": {
              "type": "object",
              "properties": {
                "width": { "$ref": "#/definitions/refObject" },
                "color": { "$ref": "#/definitions/refObject" },
                "offset": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "layer": {
          "type": "object",
          "properties": {
            "base": { "$ref": "#/definitions/refObject" },
            "nav": { "$ref": "#/definitions/refObject" },
            "modal": { "$ref": "#/definitions/refObject" },
            "skipLink": { "$ref": "#/definitions/refObject" },
            "shutter": { "$ref": "#/definitions/refObject" },
            "debug": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "layout": {
          "type": "object",
          "properties": {
            "pageMargin": { "$ref": "#/definitions/refObject" },
            "contentInset": {
              "type": "object",
              "properties": {
                "sm": { "$ref": "#/definitions/refObject" },
                "md": { "$ref": "#/definitions/refObject" },
                "lg": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            },
            "gridGutter": { "$ref": "#/definitions/refObject" },
            "sectionPadding": { "$ref": "#/definitions/refObject" },
            "navHeight": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "modal": {
          "type": "object",
          "properties": {
            "maxWidth": { "$ref": "#/definitions/refObject" },
            "maxHeight": { "$ref": "#/definitions/refObject" },
            "backdropBlur": { "$ref": "#/definitions/refObject" },
            "shadow": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "scrollbar": {
          "type": "object",
          "properties": {
            "width": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "elevation": {
          "type": "object",
          "properties": {
            "none": { "$ref": "#/definitions/refObject" },
            "low": { "$ref": "#/definitions/refObject" },
            "medium": { "$ref": "#/definitions/refObject" },
            "high": { "$ref": "#/definitions/refObject" },
            "higher": { "$ref": "#/definitions/refObject" },
            "highest": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "motion": {
          "type": "object",
          "properties": {
            "duration": {
              "type": "object",
              "properties": {
                "instant": { "$ref": "#/definitions/refObject" },
                "quick": { "$ref": "#/definitions/refObject" },
                "default": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            },
            "easing": {
              "type": "object",
              "properties": {
                "standard": { "$ref": "#/definitions/refObject" },
                "decelerate": { "$ref": "#/definitions/refObject" },
                "accelerate": { "$ref": "#/definitions/refObject" },
                "emphasized": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            },
            "gsapEasing": {
              "type": "object",
              "properties": {
                "enter": { "$ref": "#/definitions/refObject" },
                "bounce": { "$ref": "#/definitions/refObject" },
                "bounceIn": { "$ref": "#/definitions/refObject" },
                "bounceMove": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "typescale": {
          "type": "object",
          "properties": {
            "display-lg": { "$ref": "#/definitions/typographyRole" },
            "display-md": { "$ref": "#/definitions/typographyRole" },
            "display-sm": { "$ref": "#/definitions/typographyRole" },
            "headline-lg": { "$ref": "#/definitions/typographyRole" },
            "headline-md": { "$ref": "#/definitions/typographyRole" },
            "headline-sm": { "$ref": "#/definitions/typographyRole" },
            "title-lg": { "$ref": "#/definitions/typographyRole" },
            "title-md": { "$ref": "#/definitions/typographyRole" },
            "title-sm": { "$ref": "#/definitions/typographyRole" },
            "body-lg": { "$ref": "#/definitions/typographyRole" },
            "body-md": { "$ref": "#/definitions/typographyRole" },
            "body-sm": { "$ref": "#/definitions/typographyRole" },
            "label-lg": { "$ref": "#/definitions/typographyRole" },
            "label-md": { "$ref": "#/definitions/typographyRole" },
            "label-sm": { "$ref": "#/definitions/typographyRole" }
          },
          "additionalProperties": false
        },
        "hover": {
          "type": "object",
          "properties": {
            "lift": { "$ref": "#/definitions/refObject" },
            "underlineHeight": { "$ref": "#/definitions/refObject" },
            "underlineHoverHeight": { "$ref": "#/definitions/refObject" },
            "underlineOpacity": { "$ref": "#/definitions/refObject" },
            "underlineHoverOpacity": { "$ref": "#/definitions/refObject" }
          },
          "additionalProperties": false
        },
        "prose": {
          "type": "object",
          "properties": {
            "code": {
              "type": "object",
              "properties": {
                "bg": { "$ref": "#/definitions/refObject" },
                "paddingInline": { "$ref": "#/definitions/refObject" },
                "paddingBlock": { "$ref": "#/definitions/refObject" },
                "borderRadius": { "$ref": "#/definitions/refObject" },
                "blockPadding": { "$ref": "#/definitions/refObject" },
                "blockRadius": { "$ref": "#/definitions/refObject" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "elementMap": {
      "type": "object",
      "description": "Maps HTML elements to typography role names",
      "propertyNames": {
        "enum": ["h1", "h2", "h3", "h4", "h5", "h6", "p", "li"]
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
