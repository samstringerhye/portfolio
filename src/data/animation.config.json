{
  "$schema": "./animation.config.schema.json",
  "textReveal": {
    "duration": 0.4,
    "wordStagger": 0.08,
    "blockStagger": 0.06,
    "slideUp": 20,
    "initialBlur": 6,
    "ease": { "$ref": "sys.motion.gsapEasing.enter" },
    "scrollStart": "top 70%",
    "cmyStagger": 0.04,
    "cmyOpacity": 0.4
  },
  "hero": {
    "canvas": {
      "arrangement": "spiral",
      "numRays": 80,
      "dotsPerRay": 30,
      "spacing": 1,
      "innerRadius": 0,
      "dotRadius": 0.2,
      "dotSegments": 8,
      "sizeStart": 0.1,
      "sizeMid": 1.0,
      "sizeEnd": 0.1,
      "waveSpeed": 1.0,
      "waveFrequency": 0.1,
      "waveAmplitude": 0.5,
      "waveSharpness": 0.25,
      "propagation": 30,
      "baseScale": 1.25,
      "twistAmount": 0.5,
      "zoom": 20,
      "maxDpr": 2,
      "cmyStagger": 0.03,
      "accentOpacity": 0.6,
      "bgColor": { "$ref": "sys.color.bg.primary" }
    },
    "text": {
      "startDelay": 0.25
    }
  },
  "timeline": {
    "hover": {
      "cmyOpacity": 1,
      "saveCmyOpacity": 1,
      "expandDuration": 0.5,
      "expandEase": { "$ref": "sys.motion.gsapEasing.bounce" },
      "collapseDuration": { "$ref": "sys.motion.duration.quick" },
      "collapseEase": { "$ref": "sys.motion.gsapEasing.bounceMove" },
      "textShowDuration": { "$ref": "sys.motion.duration.quick" },
      "textHideDuration": { "$ref": "sys.motion.duration.quick" },
      "collapseTextDuration": { "$ref": "sys.motion.duration.quick" },
      "wipeDuration": { "$ref": "sys.motion.duration.quick" },
      "wipeEase": { "$ref": "sys.motion.gsapEasing.bounce" },
      "wipeOutDuration": { "$ref": "sys.motion.duration.quick" },
      "wipeOutEase": { "$ref": "sys.motion.gsapEasing.bounceIn" },
      "highlightsShowDuration": { "$ref": "sys.motion.duration.quick" },
      "highlightsShowDelay": 0.15,
      "highlightsShowEase": { "$ref": "sys.motion.gsapEasing.bounce" },
      "highlightsHideDuration": 0.2,
      "highlightsHideEase": { "$ref": "sys.motion.gsapEasing.bounceIn" }
    }
  },
  "workHover": {
    "radius": 0.4,
    "channelSpread": { "r": 0.4, "g": 0.45, "b": 0.35 },
    "mouseSmoothing": 0.2,
    "speedSmoothing": 0.2,
    "speedDecay": 0.999,
    "maxVelocity": 1.25,
    "idleThreshold": 0.001,
    "fadeDuration": 0.4,
    "maxDpr": 1.8
  },
  "dotGrid": {
    "spacing": 30,
    "radius": 1,
    "opacity": 0.5
  },
  "interests": {
    "scrollDuration": 480
  },
  "smoothScroll": {
    "lerp": 0.25,
    "wheelMultiplier": 1.4
  },
  "pageTransition": {
    "duration": 0.25,
    "stagger": 0.04,
    "ease": "power2.inOut",
    "exitDelay": 0.05
  }
}
