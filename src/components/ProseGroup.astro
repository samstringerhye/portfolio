---
<div class="prose-group"><slot /></div>

<style is:global>
  .prose-group {
    display: flex;
    flex-direction: column;
    gap: var(--prose-gap, var(--space-3));
  }

  /* p sizing based on preceding heading level */
  .prose-group > h1 + p {
    font-weight: var(--prose-lede-weight, var(--font-weight-regular));
    font-size: var(--prose-lede-size, var(--text-3x));
    line-height: var(--line-height-normal);
    max-width: var(--prose-heading-measure, 42rem);
  }

  .prose-group > h2 + p {
    font-size: var(--h2-follow-size, var(--text-base));
  }

  .prose-group > h3 + p {
    font-size: var(--h3-follow-size, var(--text-base));
  }

  /* Body-scale: ch-based measure */
  .prose-group > p,
  .prose-group > ul, .prose-group > ol, .prose-group > blockquote {
    max-width: var(--prose-measure);
  }

  /* Headings: fixed measure aligned to body column */
  .prose-group > h1, .prose-group > h2, .prose-group > h3 {
    max-width: var(--prose-heading-measure, 42rem);
  }
</style>
