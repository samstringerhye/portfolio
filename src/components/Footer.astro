---
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer-container">
    <!-- Name bar -->
    <div class="footer-bar">
      <div class="footer-palette" aria-hidden="true">
        <span style="background:#24F266"></span>
        <span style="background:#F22434"></span>
        <span style="background:#FBE91E"></span>
        <span style="background:#2471F2"></span>
        <span style="background:#0B0D1B"></span>
        <span style="background:white"></span>
      </div>
      <div class="footer-bar-text">
        <p class="footer-wordmark-text">Sam Stringer-Hye</p>
        <nav class="footer-links" aria-label="Footer links">
          <a href="/contact" class="footer-link typo-ui-caps">Contact</a>
          <a href="https://linkedin.com/in/samstringerhye" target="_blank" rel="noopener noreferrer" class="footer-link typo-ui-caps">LinkedIn</a>
          <a href="/colophon" class="footer-link typo-ui-caps">Colophon</a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copyright typo-ui-caps">&copy; {year}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 0;
    position: relative;
    overflow: visible;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background-color: var(--color-text-primary);
    transform: scaleX(var(--footer-line-draw, 1));
    transform-origin: left;
    z-index: 1;
  }


  .footer-container {
    max-width: var(--max-content-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  /* ── Top utility bar ── */
  .footer-bar {
    position: relative;
    display: flex;
    height: var(--nav-height);
  }

  /* Bottom border — draws left to right */
  .footer-bar::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-text-primary);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .footer-palette {
    display: flex;
    flex-direction: column;
    align-self: stretch;
  }

  .footer-palette span {
    width: calc(var(--nav-height) / 6);
    height: calc(var(--nav-height) / 6);
  }

  .footer-bar-text {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: var(--space-2);
    padding-right: var(--content-inset-md);
  }

  .footer-wordmark-text {
    font-family: var(--font-serif);
    font-weight: var(--font-weight-regular);
    font-size: var(--wordmark-size);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: calc(var(--page-margin) * 2);
    padding: var(--space-3) var(--content-inset-md);
  }

  .footer-links {
    display: flex;
    gap: var(--space-3);
  }

  .footer-link {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: opacity var(--duration-short) ease;
  }

  @media (hover: hover) {
    .footer-link:hover {
      opacity: var(--opacity-50);
    }
  }

  /* ── Mobile ── */
  @media (--2x) {
    .footer-bar-text {
      padding-left: var(--page-margin);
      padding-right: var(--page-margin);
    }

    .footer-bottom {
      padding: var(--space-3) var(--page-margin);
    }

    .footer-wordmark-text {
      font-size: var(--wordmark-size-mobile);
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }
</style>

<script>
  const PALETTE_COLORS = [
    '#24F266', '#F22434', '#FBE91E', '#2471F2', '#0B0D1B', '#ffffff',
  ]

  let paletteIntervalId: ReturnType<typeof setInterval> | null = null

  function initPaletteCycle() {
    // Clear previous interval to prevent accumulation across page navigations
    if (paletteIntervalId !== null) {
      clearInterval(paletteIntervalId)
      paletteIntervalId = null
    }

    const spans = document.querySelectorAll<HTMLSpanElement>('.footer-palette span')
    if (!spans.length) return

    // Respect reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    let offset = 0
    function paint() {
      spans.forEach((span, i) => {
        span.style.background = PALETTE_COLORS[((i + offset) % PALETTE_COLORS.length + PALETTE_COLORS.length) % PALETTE_COLORS.length]
      })
    }
    paint()

    // Shift all colors down by one position each tick
    paletteIntervalId = setInterval(() => { offset--; paint() }, 200)
  }

  initPaletteCycle()
  document.addEventListener('astro:page-load', () => {
    initPaletteCycle()
  })
  document.addEventListener('astro:before-swap', () => {
    if (paletteIntervalId !== null) {
      clearInterval(paletteIntervalId)
      paletteIntervalId = null
    }
  })
</script>
