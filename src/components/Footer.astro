---
import { Icon } from 'astro-icon/components'
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer-container">
    <!-- Name bar -->
    <div class="footer-bar">
      <div class="footer-palette" aria-hidden="true">
        <span style="background:#24F266"></span>
        <span style="background:#F22434"></span>
        <span style="background:#FBE91E"></span>
        <span style="background:#2471F2"></span>
        <span style="background:#0B0D1B"></span>
        <span style="background:white"></span>
      </div>
      <div class="footer-bar-text">
        <p class="footer-wordmark-text">Sam Stringer-Hye</p>
      </div>
      <nav class="footer-bar-icons" aria-label="Social links">
        <a href="mailto:sam@samstringerhye.com" class="footer-icon-cell" aria-label="Email">
          <Icon name="material-symbols-light:mail-outline-sharp" aria-hidden="true" />
        </a>
        <a href="https://linkedin.com/in/samstringerhye" target="_blank" rel="noopener noreferrer" class="footer-icon-cell" aria-label="LinkedIn (opens in new tab)">
          <Icon name="simple-icons:linkedin" aria-hidden="true" />
        </a>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copyright typo-ui-caps">&copy; {year}</p>
      <a href="/colophon" class="footer-colophon typo-ui-caps">Colophon</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 0;
    position: relative;
    overflow: visible;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background-color: var(--color-text-primary);
  }

  .footer-container {
    max-width: var(--max-content-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  /* ── Top utility bar ── */
  .footer-bar {
    display: flex;
    height: var(--nav-height);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  .footer-palette {
    display: flex;
    flex-direction: column;
    align-self: stretch;
  }

  .footer-palette span {
    width: calc(var(--nav-height) / 6);
    height: calc(var(--nav-height) / 6);
  }

  .footer-bar-text {
    flex: 1;
    display: flex;
    align-items: center;
    padding-left: var(--space-2);
    padding-right: var(--content-inset-md);
  }

  .footer-bar-icons {
    display: flex;
    flex-shrink: 0;
    height: 100%;
  }

  .footer-icon-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--nav-height);
    height: 100%;
    border-left: var(--border-width-1) solid var(--color-text-primary);
    color: var(--color-text-primary);
    transition: background-color var(--duration-medium) ease;
  }

  .footer-icon-cell svg {
    width: 30%;
    height: 30%;
    transition: transform var(--duration-medium) cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @media (hover: hover) {
    .footer-icon-cell:hover svg {
      transform: scale(1.2) rotate(-5deg);
      transition: transform 490ms cubic-bezier(0.5, 0, 0, 1);
    }
  }

  .footer-wordmark-text {
    font-family: var(--font-serif);
    font-weight: var(--font-weight-regular);
    font-size: var(--wordmark-size);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: calc(var(--page-margin) * 2);
    padding: var(--space-3) var(--content-inset-md);
  }

  .footer-colophon {
    transition: opacity var(--duration-short) ease;
  }

  @media (hover: hover) {
    .footer-colophon:hover {
      opacity: var(--opacity-50);
    }
  }

  /* ── Mobile ── */
  @media (--2x) {
    .footer-bar-text {
      padding-left: var(--page-margin);
      padding-right: var(--page-margin);
    }

    .footer-bottom {
      padding: var(--space-3) var(--page-margin);
    }

    .footer-wordmark-text {
      font-size: var(--wordmark-size-mobile);
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }
</style>

<script>
  import { animations, cmyRgba } from '../data/tokens'

  const CMY_COLORS = cmyRgba(animations.timeline.hover.saveCmyOpacity)
  let colorIndex = 0

  function initFooterHover() {
    if (!window.matchMedia('(hover: hover)').matches) return
    const cells = document.querySelectorAll<HTMLAnchorElement>('.footer-icon-cell')
    cells.forEach((cell) => {
      cell.addEventListener('mouseenter', () => {
        cell.style.backgroundColor = CMY_COLORS[colorIndex++ % CMY_COLORS.length]
      })
      cell.addEventListener('mouseleave', () => {
        cell.style.backgroundColor = ''
      })
    })
  }

  const PALETTE_COLORS = [
    '#24F266', '#F22434', '#FBE91E', '#2471F2', '#0B0D1B', '#ffffff',
  ]

  let paletteIntervalId: ReturnType<typeof setInterval> | null = null

  function initPaletteCycle() {
    // Clear previous interval to prevent accumulation across page navigations
    if (paletteIntervalId !== null) {
      clearInterval(paletteIntervalId)
      paletteIntervalId = null
    }

    const spans = document.querySelectorAll<HTMLSpanElement>('.footer-palette span')
    if (!spans.length) return

    // Respect reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    let offset = 0
    function paint() {
      spans.forEach((span, i) => {
        span.style.background = PALETTE_COLORS[((i + offset) % PALETTE_COLORS.length + PALETTE_COLORS.length) % PALETTE_COLORS.length]
      })
    }
    paint()

    // Shift all colors down by one position each tick
    paletteIntervalId = setInterval(() => { offset--; paint() }, 200)
  }

  initFooterHover()
  initPaletteCycle()
  document.addEventListener('astro:page-load', () => {
    initFooterHover()
    initPaletteCycle()
  })
  document.addEventListener('astro:before-swap', () => {
    if (paletteIntervalId !== null) {
      clearInterval(paletteIntervalId)
      paletteIntervalId = null
    }
  })
</script>
