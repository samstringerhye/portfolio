---
const pathname = Astro.url.pathname

const links = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
]

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  if (href.startsWith('/#')) return false
  return pathname.startsWith(href)
}
---

<header class="nav" id="site-nav">
  <nav class="nav-inner" aria-label="Main navigation">
    <a href="/" class="nav-logo typo-ui-lg" aria-label="Sam Stringer-Hye — Home">
      <svg class="nav-logo-icon" width="1100" height="1100" viewBox="0 0 1100 1100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M250.5 0C388.295 0 500 111.929 500 250V500H250.5C112.705 500 1 388.071 1 250C1 111.929 112.705 0 250.5 0Z" fill="#F22434"/>
        <path d="M500 850C500 988.071 388.071 1100 250 1100C111.929 1100 -1.60836e-06 988.071 0 850C1.81059e-05 711.929 111.929 600 250 600H500V850Z" fill="#E5C800"/>
        <path d="M850 0C988.071 6.03528e-06 1100 111.929 1100 250C1100 388.071 988.071 500 850 500H600V250C600 111.929 711.929 2.21346e-06 850 0Z" fill="#00CC55"/>
        <path d="M850 600C988.071 600 1100 711.929 1100 850C1100 988.071 988.071 1100 850 1100C711.929 1100 600 988.071 600 850V600H850Z" fill="#2471F2"/>
      </svg>
      Sam Stringer-Hye
    </a>

    <ul class="nav-links" id="nav-links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', 'typo-ui', { active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
            data-astro-prefetch="hover"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: var(--color-bg-primary);
    padding-top: env(safe-area-inset-top);
  }

  .nav::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
  }

  .nav-inner {
    display: flex;
    align-items: stretch;
    gap: var(--space-1);
    height: var(--nav-height);
    max-width: var(--max-content-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    padding-inline: var(--space-3);
    border-right: var(--border-width-1) solid var(--color-rule);
    color: var(--color-text-primary);
    text-decoration: none;
    white-space: nowrap;
    font-size: var(--text-100);
    gap: var(--space-2);
    transition: background-color var(--duration-medium) ease;
  }

  .nav-logo-icon {
    width: 1.5rem;
    height: auto;
    flex-shrink: 0;
    overflow: visible;
  }


  .nav-links {
    display: flex;
    align-items: stretch;
    list-style: none;
    flex-shrink: 0;
    margin-left: auto;
  }

  .nav-links li {
    display: flex;
    border-left: var(--border-width-1) solid var(--color-rule);
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding-inline: var(--space-3);
    color: var(--color-text-primary);
    text-decoration: none;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    transition: background-color var(--duration-medium) ease;
  }



  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: var(--nav-toggle-gap);
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav-toggle-bar {
    display: block;
    width: var(--nav-toggle-bar-width);
    height: var(--nav-toggle-bar-height);
    background: var(--color-text-primary);
    border-radius: var(--radius-xs);
    transition: transform var(--duration-long) ease, opacity var(--duration-long) ease;
  }

  @media (--2x) {
    .nav::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: var(--border-width-1);
      background: var(--color-rule);
    }

    .nav-logo {
      border-right: none;
      flex: 1;
    }

    .nav-toggle {
      display: flex;
      margin-left: auto;
      border-left: var(--border-width-1) solid var(--color-rule);
      aspect-ratio: 1;
      height: var(--nav-height);
      width: auto;
      min-width: unset;
      min-height: unset;
      padding: 0;
    }

    .nav-links {
      position: fixed;
      top: calc(var(--nav-height) + env(safe-area-inset-top));
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 0;
      padding-bottom: env(safe-area-inset-bottom);
      background: var(--color-bg-primary);
      transform: translateX(100%);
      transition: transform var(--duration-long) ease;
    }

    .nav-links li {
      flex: none;
      border-left: none;
      border-bottom: none;
    }

    .nav-links.open {
      transform: translateX(0);
    }

    .nav-link {
      width: 100%;
      margin-inline: var(--page-margin);
      padding: var(--space-3) var(--space-3);
      font-size: var(--text-400);
      border-bottom: var(--border-width-1) solid var(--color-rule);
    }


    @media (prefers-reduced-motion: reduce) {
      .nav-links {
        transition: none;
      }
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:first-child {
      transform: translateY(calc((var(--nav-toggle-gap) + var(--nav-toggle-bar-height)) / 2)) rotate(45deg);
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:last-child {
      transform: translateY(calc((var(--nav-toggle-gap) + var(--nav-toggle-bar-height)) / -2)) rotate(-45deg);
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { cmyRgba } from '../data/tokens'

  const CMY_COLORS = cmyRgba(1)
  let colorIndex = 0

  // Petal directions: top-left, bottom-left, top-right, bottom-right (DOM order)
  const petalOffsets = [
    { x: -60, y: -60 },  // path 1: red top-left
    { x: -60, y: 60 },   // path 2: yellow bottom-left
    { x: 60, y: -60 },   // path 3: green top-right
    { x: 60, y: 60 },    // path 4: blue bottom-right
  ]

  const canHover = window.matchMedia('(hover: hover)').matches

  function initNavHover() {
    if (!canHover) return
    const items = document.querySelectorAll<HTMLElement>('.nav-link, .nav-logo')
    items.forEach((el) => {
      if (el.dataset.navHoverBound === 'true') return
      el.dataset.navHoverBound = 'true'
      el.addEventListener('mouseenter', () => {
        el.style.backgroundColor = CMY_COLORS[colorIndex++ % CMY_COLORS.length]
      })
      el.addEventListener('mouseleave', () => {
        el.style.backgroundColor = el.dataset.activeBg || ''
      })
    })

    // Logo petal animation (skip if user prefers reduced motion)
    const logo = document.querySelector('.nav-logo')
    if (logo && !logo.dataset.petalBound && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      logo.dataset.petalBound = 'true'
      const paths = logo.querySelectorAll<SVGPathElement>('.nav-logo-icon path')
      const originalFills = Array.from(paths).map(p => p.getAttribute('fill'))

      logo.addEventListener('mouseenter', () => {
        paths.forEach((path, i) => {
          gsap.killTweensOf(path)
          const { x, y } = petalOffsets[i]
          gsap.to(path, { attr: { fill: '#ffffff' }, duration: 0.2, ease: 'power2.out' })

          const tl = gsap.timeline()
          // 1. Anticipation: pull toward center
          tl.to(path, {
            x: -x * 0.3,
            y: -y * 0.3,
            duration: 0.15,
            ease: 'back.in(4)',
          })
          // 2. Burst outward
          .to(path, {
            x, y,
            duration: 0.25,
            ease: 'power4.out',
          })
          // 3. Spring settle back to rest
          .to(path, {
            x: 0, y: 0,
            duration: 0.6,
            ease: 'elastic.out(1, 0.4)',
          })
        })
      })

      logo.addEventListener('mouseleave', () => {
        paths.forEach((path, i) => {
          gsap.killTweensOf(path)
          gsap.to(path, { attr: { fill: originalFills[i] }, duration: 0.3, ease: 'power2.out' })
          gsap.to(path, { x: 0, y: 0, duration: 0.3, ease: 'back.out(2)' })
        })
      })
    }
  }

  initNavHover()
  document.addEventListener('astro:after-swap', initNavHover)

  type NavWindow = Window & {
    __navAfterSwapHandler?: () => void
  }

  function initNav() {
    const toggle = document.getElementById('nav-toggle')
    const links = document.getElementById('nav-links')
    if (!toggle || !links) return
    if (toggle.dataset.navBound === 'true') return

    toggle.dataset.navBound = 'true'

    let removeTrap: (() => void) | null = null

    // Disable tab access to hidden mobile nav links
    function setNavLinksTabindex(enabled: boolean) {
      links!.querySelectorAll<HTMLElement>('a, button').forEach(el => {
        if (enabled) el.removeAttribute('tabindex')
        else el.setAttribute('tabindex', '-1')
      })
    }

    // Start with links hidden from tab order on mobile
    if (window.matchMedia('(max-width: 768px)').matches) {
      setNavLinksTabindex(false)
    }
    window.matchMedia('(max-width: 768px)').addEventListener('change', (e) => {
      if (!e.matches) setNavLinksTabindex(true)
      else if (toggle!.getAttribute('aria-expanded') !== 'true') setNavLinksTabindex(false)
    })

    function openNav() {
      toggle!.setAttribute('aria-expanded', 'true')
      links!.classList.add('open')
      setNavLinksTabindex(true)

      // Focus trap for mobile nav
      const focusable = links!.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])')
      const first = focusable[0]
      const last = focusable[focusable.length - 1]

      function handler(e: KeyboardEvent) {
        if (e.key === 'Escape') { closeNav(); return }
        if (e.key !== 'Tab') return
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last?.focus() }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first?.focus() }
      }

      links!.addEventListener('keydown', handler)
      first?.focus()
      removeTrap = () => links!.removeEventListener('keydown', handler)
    }

    function closeNav() {
      toggle!.setAttribute('aria-expanded', 'false')
      links!.classList.remove('open')
      setNavLinksTabindex(false)
      removeTrap?.()
      removeTrap = null
      toggle!.focus()
    }

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true'
      if (expanded) closeNav()
      else openNav()
    })

    // Close on Escape key (document-level for when focus is outside nav)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle!.getAttribute('aria-expanded') === 'true') {
        closeNav()
      }
    })

    // Close on nav link click (mobile)
    links.querySelectorAll('a').forEach(link => {
      if ((link as HTMLElement).dataset.navCloseBound === 'true') return
      ;(link as HTMLElement).dataset.navCloseBound = 'true'
      link.addEventListener('click', closeNav)
    })
  }

  const navWindow = window as NavWindow
  if (navWindow.__navAfterSwapHandler) {
    document.removeEventListener('astro:after-swap', navWindow.__navAfterSwapHandler)
  }
  navWindow.__navAfterSwapHandler = initNav

  initNav()
  document.addEventListener('astro:after-swap', navWindow.__navAfterSwapHandler)

  // Cycle accent color on the active nav link
  const ACTIVE_COLORS = cmyRgba(1)
  let activeColorIndex = Math.floor(Math.random() * ACTIVE_COLORS.length)

  function setActiveNavColor() {
    const activeLink = document.querySelector<HTMLElement>('.nav-link.active')
    if (activeLink) {
      const color = ACTIVE_COLORS[activeColorIndex]
      activeLink.style.backgroundColor = color
      activeLink.dataset.activeBg = color
      activeColorIndex = (activeColorIndex + 1) % ACTIVE_COLORS.length
    }
  }

  setActiveNavColor()
  document.addEventListener('astro:after-swap', setActiveNavColor)
</script>
