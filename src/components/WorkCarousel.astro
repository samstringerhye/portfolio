---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import type { HeadingTag, TypographyRole } from '../types/typography'
import { animations } from '../data/tokens'

interface Props {
  headline?: string
  headingTag?: HeadingTag
  headingRole?: TypographyRole
  cardTitleTag?: HeadingTag
  cardTitleRole?: TypographyRole
  contentInset?: 'sm' | 'md' | 'lg'
}

const {
  headline = 'Selected Work',
  headingTag = 'h2', headingRole = 'display',
  cardTitleTag = 'h3', cardTitleRole = 'display-sm',
  contentInset = 'md',
} = Astro.props as Props
const SectionTag = headingTag as any
const CardTitleTag = cardTitleTag as any
const allWork = await getCollection('work')
const featured = allWork
  .filter(w => w.data.featured)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map(w => ({
    title: w.data.title,
    role: w.data.role,
    year: w.data.year,
    thumbnail: w.data.thumbnail,
    slug: w.id,
  }))
const revealCfg = animations.textReveal
const workInitBlur = `${revealCfg.initialBlur}px`
---

<section class="work-section" id="selected-work" aria-label="Selected work" style={`--content-inset: var(--content-inset-${contentInset})`}>
  <div class="work-container">
    <SectionTag class={`work-label typo-${headingRole}`} data-reveal>{headline}</SectionTag>

    <div class="work-grid">
      {featured.map(card => (
        <a href={`/work/${card.slug}`} class="work-card" data-work-card>
          <div class="work-card-proof" aria-hidden="true">
            <span class="trim trim-tl-v"></span>
            <span class="trim trim-tl-h"></span>
            <span class="trim trim-tr-v"></span>
            <span class="trim trim-tr-h"></span>
            <span class="trim trim-bl-v"></span>
            <span class="trim trim-bl-h"></span>
            <span class="trim trim-br-v"></span>
            <span class="trim trim-br-h"></span>
          </div>
          <div class="work-card-inner">
            <Image
              src={card.thumbnail}
              alt={card.title}
              width={1600}
              format="webp"
              quality={90}
              loading="lazy"
            />
            <div class="work-card-cta">
              <Icon name="material-symbols:arrow-forward-sharp" class="work-card-cta-icon" />
            </div>
          </div>
          <div class="work-card-label">
            <CardTitleTag class={`work-card-title typo-${cardTitleRole}`} data-card-title>{card.title}</CardTitleTag>
            <Icon name="material-symbols:arrow-forward-sharp" class="work-card-arrow" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style define:vars={{ workInitBlur }}>
  .work-section {
    padding: 0;
  }

  .work-container {
    padding: 0;
  }

  .work-label {
    color: var(--color-text-primary);
    margin: 0;
    padding: var(--content-inset-md);
    opacity: 0;
    filter: blur(var(--workInitBlur));
  }

  @media (prefers-reduced-motion: reduce) {
    .work-label {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto;
    gap: 0;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-card {
    --trim-length: 1.5rem;
    position: relative;
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 2;
    text-decoration: none;
  }

  /* Vertical center line */
  .work-card:nth-child(odd) {
    border-right: var(--border-width-1) solid var(--color-text-primary);
  }

  /* Horizontal center line */
  .work-card:nth-child(-n+2) {
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-card-inner {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .work-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-card-cta {
    display: none;
  }

  .work-card-cta-icon {
    width: 3em;
    height: 3em;
  }

  .work-card-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--content-inset-sm);
    gap: var(--space-2);
    border-top: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-card-title {
    display: block;
    color: var(--color-text-primary);
    margin: 0;
  }

  .work-card-arrow {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    color: var(--color-text-primary);
  }

  /* ── Print proof marks ── */
  .work-card-proof {
    position: absolute;
    inset: calc(-1 * var(--trim-length));
    pointer-events: none;
  }

  /* Trim lines — draw in from corners */
  .trim {
    position: absolute;
    background: none;
    border: none;
    transition: transform var(--transition-1x) ease;
  }

  /* Vertical trims */
  .trim-tl-v, .trim-tr-v { width: 0; height: var(--trim-length); top: 0; border-left: var(--border-width-1) solid var(--color-text-primary); }
  .trim-bl-v, .trim-br-v { width: 0; height: var(--trim-length); bottom: 0; border-left: var(--border-width-1) solid var(--color-text-primary); }
  .trim-tl-v, .trim-bl-v { left: var(--trim-length); }
  .trim-tr-v, .trim-br-v { right: var(--trim-length); }

  /* Horizontal trims */
  .trim-tl-h, .trim-bl-h { height: 0; width: var(--trim-length); left: 0; border-top: var(--border-width-1) solid var(--color-text-primary); }
  .trim-tr-h, .trim-br-h { height: 0; width: var(--trim-length); right: 0; border-top: var(--border-width-1) solid var(--color-text-primary); }
  .trim-tl-h, .trim-tr-h { top: var(--trim-length); }
  .trim-bl-h, .trim-br-h { bottom: var(--trim-length); }

  /* Draw direction: scale from image edge outward */
  .trim-tl-v, .trim-tr-v { transform-origin: bottom; transform: scaleY(0); }
  .trim-bl-v, .trim-br-v { transform-origin: top; transform: scaleY(0); }
  .trim-tl-h, .trim-bl-h { transform-origin: right; transform: scaleX(0); }
  .trim-tr-h, .trim-br-h { transform-origin: left; transform: scaleX(0); }

  @media (--2x) {
    .work-label {
      padding: var(--space-4) var(--page-margin);
    }

    .work-card-info {
      padding: var(--page-margin);
    }

    .work-grid {
      grid-template-columns: 1fr;
      border-top: var(--border-width-1) solid var(--color-rule);
      border-bottom: var(--border-width-1) solid var(--color-rule);
    }

    .work-card:nth-child(odd) {
      border-right: none;
    }

    /* All cards except last get a bottom border */
    .work-card:nth-child(-n+3) {
      border-bottom: var(--border-width-1) solid var(--color-rule);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card img {
      transition: none;
    }

    .work-card-overlay {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { cmyRgba } from '../data/tokens'

  gsap.registerPlugin(ScrollTrigger)

  const CMY_COLORS = cmyRgba(1)
  let colorIndex = 0

  function tightenSingleLineHeadings() {
    document.querySelectorAll<HTMLElement>('.work-label, .work-card-title').forEach((el) => {
      const style = getComputedStyle(el)
      const lineHeight = parseFloat(style.lineHeight)
      const contentHeight = el.scrollHeight - parseFloat(style.paddingTop) - parseFloat(style.paddingBottom)
      if (contentHeight <= lineHeight * 1.1) {
        el.style.lineHeight = '1'
      }
    })
  }

  function initWorkSection() {
    const cards = document.querySelectorAll<HTMLElement>('[data-work-card]')
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (!cards.length) return

    if (prefersReduced) {
      gsap.set(cards, { opacity: 1 })
      return
    }

    gsap.set(cards, { opacity: 1 })
    tightenSingleLineHeadings()
  }

  function initWorkHover() {
    document.querySelectorAll<HTMLElement>('.work-card-label').forEach((label) => {
      if (label.dataset.workHoverBound === 'true') return
      label.dataset.workHoverBound = 'true'

      label.addEventListener('mouseenter', () => {
        label.style.backgroundColor = CMY_COLORS[colorIndex++ % CMY_COLORS.length]
      })
      label.addEventListener('mouseleave', () => {
        label.style.backgroundColor = ''
      })
    })
  }

  async function initWebGL() {
    try {
      const { initWebGLHoverEffect } = await import('./webgl-hover-effect')
      initWebGLHoverEffect()
    } catch (err) {
      console.warn('[WorkCarousel] WebGL hover effect failed:', err)
    }
  }

  function init() {
    initWorkSection()
    initWorkHover()
    initWebGL()
  }

  init()
  document.addEventListener('astro:page-load', init)
</script>
