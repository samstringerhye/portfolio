---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import type { HeadingTag, TypographyRole } from '../types/typography'

interface Props {
  headline?: string
  headingTag?: HeadingTag
  headingRole?: TypographyRole
  cardTitleTag?: HeadingTag
  cardTitleRole?: TypographyRole
  contentInset?: 'sm' | 'md' | 'lg'
}

const {
  headline = 'Selected Work',
  headingTag = 'h2', headingRole = 'display',
  cardTitleTag = 'h3', cardTitleRole = 'headline-lg',
  contentInset = 'md',
} = Astro.props as Props
const SectionTag = headingTag as any
const CardTitleTag = cardTitleTag as any
const allWork = await getCollection('work')
const featured = allWork
  .filter(w => w.data.featured)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map(w => ({
    title: w.data.title,
    role: w.data.role,
    year: w.data.year,
    thumbnail: w.data.thumbnail,
    slug: w.id,
  }))
---

<section class="work-section" id="selected-work" aria-label="Selected work" style={`--content-inset: var(--content-inset-${contentInset})`}>
  <div class="work-container">
    <div class="work-header">
      <SectionTag class={`work-label typo-${headingRole}`} data-reveal>{headline}</SectionTag>
      <a href="/work" class="work-see-all" aria-label="See all work">
        <span class="work-see-all-label">See all</span>
        <svg class="work-see-all-icon" width="28" height="28" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
          <line x1="80" y1="100" x2="140" y2="100"/>
          <polyline points="115,75 140,100 115,125"/>
        </svg>
      </a>
    </div>

    <div class="work-carousel" data-work-carousel tabindex="0" role="region" aria-roledescription="carousel" aria-label="Selected work carousel">
      <div class="work-track">
        {featured.map(card => (
          <a href={`/work/${card.slug}`} class="work-card" data-work-card>
            <div class="work-card-inner">
              <Image
                src={card.thumbnail}
                alt=""
                widths={[400, 800, 1200, 1600]}
                sizes="(max-width: 768px) 100vw, 50vw"
                format="webp"
                quality={80}
                loading="lazy"
              />
            </div>
            <div class="work-card-label">
              <CardTitleTag class={`work-card-title typo-${cardTitleRole}`} data-card-title>{card.title}</CardTitleTag>
              <Icon name="material-symbols:arrow-forward-sharp" class="work-card-arrow" />
            </div>
          </a>
        ))}
      </div>
      <div class="work-carousel-dots" aria-live="polite"></div>
    </div>
  </div>
</section>

<style>
  .work-section {
    padding: 0;
  }

  .work-container {
    padding: 0;
  }

  .work-header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--content-inset-md);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-label {
    color: var(--color-text-primary);
    margin: 0;
  }

  .work-see-all {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    text-decoration: none;
    border-left: var(--border-width-1) solid var(--color-text-primary);
    transition: background-color var(--duration-medium, 0.3s) ease;
  }

  .work-see-all-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  .work-see-all-icon {
    width: 65%;
    height: 65%;
    transition: transform var(--duration-medium, 0.3s) cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @media (hover: hover) {
    .work-see-all:hover .work-see-all-icon {
      transform: scale(1.2) rotate(-5deg);
      transition: transform 490ms cubic-bezier(0.5, 0, 0, 1);
    }
  }

  .work-carousel {
    overflow: hidden;
    position: relative;
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-carousel:focus-visible {
    outline: 2px solid var(--focus-ring-color);
    outline-offset: 2px;
  }

  .work-carousel:focus:not(:focus-visible) {
    outline: none;
  }

  .work-track {
    display: flex;
    will-change: transform;
    touch-action: pan-y pinch-zoom;
  }

  .work-track {
    cursor: grab;
  }
  .work-track.is-dragging {
    cursor: grabbing;
  }

  .work-card {
    cursor: grab;
  }

  .work-card-label {
    cursor: pointer;
  }

  .work-card {
    flex: 0 0 50%;
    position: relative;
    display: block;
    text-decoration: none;
    user-select: none;
    -webkit-user-drag: none;
    border-right: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-card:last-child {
    border-right: none;
  }

  .work-card-inner {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .work-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    -webkit-user-drag: none;
  }

  .work-card-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--content-inset-sm);
    gap: var(--space-2);
    border-top: var(--border-width-1) solid var(--color-text-primary);
  }

  .work-card-title {
    display: block;
    color: var(--color-text-primary);
    margin: 0;
  }

  .work-card-arrow {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    color: var(--color-text-primary);
  }

  @media (--2x) {
    .work-header {
      padding: var(--space-4) var(--page-margin);
      border-bottom-color: var(--color-rule);
    }

    .work-see-all {
      border-left-color: var(--color-rule);
    }

    .work-carousel {
      border-bottom-color: var(--color-rule);
    }

    .work-card {
      border-right-color: var(--color-rule);
    }

    .work-card-label {
      border-top-color: var(--color-rule);
    }
  }

  .work-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: var(--space-2) 0;
    border-top: var(--border-width-1) solid var(--color-rule);
  }

  .work-carousel-dots :global(.work-dot) {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: var(--color-text-primary);
    opacity: 0.3;
    transition: width 0.3s ease, opacity 0.3s ease;
  }

  .work-carousel-dots :global(.work-dot.is-active) {
    width: 16px;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card img {
      transition: none;
    }
  }
</style>

<script>
  let gsap: any
  let ScrollTrigger: any
  let CMY_COLORS: string[]
  let tightenSingleLineHeadings: any
  let colorIndex = 0

  function initWorkHover() {
    if (!window.matchMedia('(hover: hover)').matches) return
    document.querySelectorAll<HTMLElement>('.work-card-label, .work-see-all').forEach((el) => {
      if (el.dataset.workHoverBound === 'true') return
      el.dataset.workHoverBound = 'true'

      el.addEventListener('mouseenter', () => {
        el.style.backgroundColor = CMY_COLORS[colorIndex++ % CMY_COLORS.length]
      })
      el.addEventListener('mouseleave', () => {
        el.style.backgroundColor = ''
      })
    })
  }

  function initWorkCarousel() {
    document.querySelectorAll<HTMLElement>('[data-work-carousel]').forEach(carousel => {
      if (carousel.dataset.carouselInit === 'true') return
      carousel.dataset.carouselInit = 'true'

      const track = carousel.querySelector<HTMLElement>('.work-track')
      if (!track) return

      const slides = Array.from(track.querySelectorAll<HTMLElement>('.work-card'))
      if (slides.length <= 1) return

      let currentIndex = 0
      let snapPoints: number[] = []

      function getGridMetrics() {
        const cw = carousel.offsetWidth
        const probe = document.createElement('div')
        probe.style.cssText = 'position:absolute;width:var(--grid-gutter);visibility:hidden;'
        carousel.appendChild(probe)
        const gutter = probe.offsetWidth
        carousel.removeChild(probe)
        const col = (cw - 11 * gutter) / 12
        return { col, gutter }
      }

      function applyGridSizing() {
        const cw = carousel.offsetWidth
        if (cw <= 768) {
          const probe = document.createElement('div')
          probe.style.cssText = 'position:absolute;width:var(--page-margin);visibility:hidden;'
          carousel.appendChild(probe)
          const padSide = probe.offsetWidth || 16
          carousel.removeChild(probe)
          const slideWidth = cw
          track!.style.paddingLeft = '0'
          track!.style.paddingRight = '0'
          track!.style.gap = '0'
          slides.forEach(s => { s.style.flex = `0 0 ${slideWidth}px` })
          return
        }
        const { col, gutter } = getGridMetrics()
        const slideWidth = col * 6 + gutter * 5
        track!.style.paddingLeft = '0'
        track!.style.paddingRight = '0'
        track!.style.gap = '0'
        slides.forEach(s => { s.style.flex = `0 0 ${slideWidth}px` })
      }
      applyGridSizing()

      function buildSnapPoints() {
        const padLeft = parseFloat(getComputedStyle(track!).paddingLeft)
        const lastSlide = slides[slides.length - 1]
        const maxScroll = -(lastSlide.offsetLeft + lastSlide.offsetWidth - carousel.offsetWidth)
        snapPoints = slides.map(s => {
          const snap = padLeft - s.offsetLeft
          return Math.max(snap, maxScroll)
        })
        snapPoints = [...new Set(snapPoints)]
      }
      buildSnapPoints()

      function nearestIndex(x: number): number {
        let best = 0, bestD = Infinity
        snapPoints.forEach((p, i) => {
          const d = Math.abs(x - p)
          if (d < bestD) { bestD = d; best = i }
        })
        return best
      }

      const dotsContainer = carousel.querySelector('.work-carousel-dots') as HTMLElement

      function renderDots() {
        if (!dotsContainer) return
        dotsContainer.innerHTML = ''
        snapPoints.forEach((_, i) => {
          const dot = document.createElement('span')
          dot.className = 'work-dot' + (i === 0 ? ' is-active' : '')
          dot.setAttribute('aria-hidden', 'true')
          dotsContainer.appendChild(dot)
        })
      }

      function updateDots(index: number) {
        if (!dotsContainer) return
        dotsContainer.querySelectorAll('.work-dot').forEach((dot, i) => {
          dot.classList.toggle('is-active', i === index)
        })
      }

      renderDots()

      function animateTo(index: number) {
        const i = Math.max(0, Math.min(index, snapPoints.length - 1))
        currentIndex = i
        updateDots(i)
        gsap.to(track, {
          x: snapPoints[i],
          duration: 0.5,
          ease: 'power3.out',
          overwrite: true,
        })
      }

      // ── Native pointer event drag ──
      let didDrag = false
      let dragging = false
      let startX = 0
      let startY = 0
      let trackStartX = 0
      let lastX = 0
      let lastTime = 0
      let velocityX = 0

      // Suppress click after drag
      track!.addEventListener('click', (e) => {
        if (didDrag) { e.stopPropagation(); e.preventDefault(); didDrag = false }
      }, true)

      let pointerId = -1

      track!.addEventListener('pointerdown', (e: PointerEvent) => {
        if (e.button !== 0) return
        dragging = true
        didDrag = false
        pointerId = e.pointerId
        startX = e.clientX
        startY = e.clientY
        lastX = e.clientX
        lastTime = Date.now()
        velocityX = 0
        trackStartX = (gsap.getProperty(track, 'x') as number) || 0
        gsap.killTweensOf(track)
      })

      track!.addEventListener('pointermove', (e: PointerEvent) => {
        if (!dragging) return
        const dx = e.clientX - startX
        const dy = e.clientY - startY

        if (!didDrag) {
          const absDx = Math.abs(dx)
          const absDy = Math.abs(dy)
          if (absDx < 5 && absDy < 5) return
          if (absDy > absDx * 1.2) {
            dragging = false
            return
          }
          didDrag = true
          track!.setPointerCapture(pointerId)
          track!.classList.add('is-dragging')
        }

        e.preventDefault()

        const now = Date.now()
        const dt = now - lastTime
        if (dt > 0) {
          velocityX = (e.clientX - lastX) / dt * 1000
          lastX = e.clientX
          lastTime = now
        }

        let newX = trackStartX + dx
        const minX = snapPoints[snapPoints.length - 1]
        const maxX = snapPoints[0]
        if (newX > maxX) newX = maxX + (newX - maxX) * 0.3
        else if (newX < minX) newX = minX + (newX - minX) * 0.3
        gsap.set(track, { x: newX })
        updateDots(nearestIndex(newX))
      })

      function onPointerEnd(e: PointerEvent) {
        if (!dragging) return
        dragging = false
        track!.classList.remove('is-dragging')

        if (!didDrag) return

        const trackX = gsap.getProperty(track, 'x') as number
        let targetIndex = nearestIndex(trackX)

        if (Math.abs(velocityX) > 300) {
          targetIndex = velocityX > 0
            ? Math.max(0, currentIndex - 1)
            : Math.min(snapPoints.length - 1, currentIndex + 1)
        }

        animateTo(targetIndex)
      }

      track!.addEventListener('pointerup', onPointerEnd)
      track!.addEventListener('pointercancel', onPointerEnd)
      track!.addEventListener('dragstart', (e) => e.preventDefault())

      // Keyboard navigation
      carousel.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'ArrowRight') { animateTo(currentIndex + 1); e.preventDefault() }
        else if ((e as KeyboardEvent).key === 'ArrowLeft') { animateTo(currentIndex - 1); e.preventDefault() }
      })

      // Scroll-triggered slide-in entrance
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      let entranceDone = !prefersReduced ? false : true

      if (!prefersReduced) {
        const startX = carousel.offsetWidth * 0.4
        gsap.set(track, { x: startX, opacity: 0 })
        ScrollTrigger.create({
          trigger: carousel,
          start: 'top 85%',
          once: true,
          onEnter() {
            gsap.to(track, {
              x: snapPoints[0],
              opacity: 1,
              duration: 0.8,
              ease: 'power4.out',
              onComplete() {
                entranceDone = true
              },
            })
          },
        })
      }

      // Recalculate on resize — disconnect previous observer to prevent leaks
      if ((carousel as any).__workRo) (carousel as any).__workRo.disconnect()
      const ro = new ResizeObserver(() => {
        applyGridSizing()
        buildSnapPoints()
        renderDots()
        updateDots(Math.min(currentIndex, snapPoints.length - 1))
        if (entranceDone) {
          const safeIndex = Math.min(currentIndex, snapPoints.length - 1)
          gsap.set(track, { x: snapPoints[safeIndex] })
        }
      })
      ;(carousel as any).__workRo = ro
      ro.observe(carousel)
    })
  }

  async function init() {
    const [gsapMod, stMod, tokensMod, tightenMod] = await Promise.all([
      import('gsap'),
      import('gsap/ScrollTrigger'),
      import('../data/tokens'),
      import('./tighten-headings'),
    ])
    gsap = gsapMod.default
    ScrollTrigger = stMod.ScrollTrigger
    gsap.registerPlugin(ScrollTrigger)
    CMY_COLORS = tokensMod.cmyRgba(1)
    tightenSingleLineHeadings = tightenMod.tightenSingleLineHeadings

    tightenSingleLineHeadings('.work-label, .work-card-title')
    initWorkHover()
    initWorkCarousel()
  }

  function deferInit() {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => init(), { timeout: 1500 })
    } else {
      setTimeout(init, 100)
    }
  }

  deferInit()
  document.addEventListener('astro:page-load', deferInit)
</script>
