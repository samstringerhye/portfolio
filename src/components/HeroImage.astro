---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt?: string
}

const { src, alt = 'Project hero image' } = Astro.props
---

<div class="cs-hero-image">
  <Image src={src} alt={alt} width={1260} format="webp" quality={90} loading="eager" />
</div>
