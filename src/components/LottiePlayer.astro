---
/**
 * Inline Lottie animation player.
 * Loads animation JSON at build time and plays on viewport entry.
 */
interface Props {
  /** Path to the Lottie JSON file (relative to project root) */
  src: string
  /** Accessible label */
  label: string
  /** Whether to loop (default: true) */
  loop?: boolean
  /** Whether to autoplay on viewport entry (default: true) */
  autoplay?: boolean
  /** Max width constraint */
  maxWidth?: string
}

const { src, label, loop = true, autoplay = true, maxWidth = '200px' } = Astro.props

import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'

let animationData: string | null = null
try {
  const filePath = resolve(process.cwd(), src)
  animationData = readFileSync(filePath, 'utf-8')
} catch (e) {
  console.warn(`LottiePlayer: Could not read ${src}`)
}
---

{animationData && (
  <div
    class="lottie-player"
    data-animation={animationData}
    data-loop={String(loop)}
    data-autoplay={String(autoplay)}
    role="img"
    aria-label={label}
    style={`max-width: ${maxWidth}; margin: 0 auto;`}
  />
)}

<style>
  .lottie-player {
    width: 100%;
    aspect-ratio: 1;
  }
</style>

<script>
  async function initLottie() {
    const players = document.querySelectorAll<HTMLElement>('.lottie-player[data-animation]')
    if (players.length === 0) return

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    let lottie: any
    let gsap: any
    try {
      const [lottieMod, gsapMod] = await Promise.all([
        import('lottie-web/build/player/lottie_light.min.js'),
        import('gsap'),
      ])
      lottie = lottieMod.default || lottieMod
      gsap = gsapMod.default || gsapMod
    } catch (e) {
      console.warn('LottiePlayer: Failed to load dependencies', e)
      return
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const el = entry.target as HTMLElement
        if (entry.isIntersecting && !el.dataset.initialized) {
          el.dataset.initialized = 'true'
          try {
            const animData = JSON.parse(el.dataset.animation!)
            const anim = lottie.loadAnimation({
              container: el,
              renderer: 'svg',
              loop: false,
              autoplay: false,
              animationData: animData,
            })
            if (!prefersReduced && el.dataset.loop === 'true') {
              const obj = { frame: 0 }
              gsap.to(obj, {
                frame: anim.totalFrames - 1,
                duration: 2,
                ease: 'power2.inOut',
                repeat: -1,
                yoyo: true,
                repeatDelay: 0.5,
                onUpdate: () => anim.goToAndStop(obj.frame, true),
              })
            } else if (!prefersReduced) {
              anim.play()
            }
          } catch (e) {
            console.warn('LottiePlayer: Failed to init animation', e)
          }
        }
      })
    }, { threshold: 0.1 })

    players.forEach(p => observer.observe(p))
  }

  initLottie()
  document.addEventListener('astro:page-load', initLottie)
</script>
