---
---

<div class="page-shutter" id="page-shutter" aria-hidden="true" transition:persist="page-shutter">
  <div class="page-shutter-panel"></div>
</div>

<style>
  .page-shutter {
    position: fixed;
    top: var(--nav-height);
    bottom: 0;
    left: 0;
    right: 0;
    max-width: var(--max-content-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    z-index: var(--z-shutter);
    pointer-events: none;
    overflow: hidden;
  }

  .page-shutter-panel {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--page-margin);
    right: var(--page-margin);
    transform: translateY(101%);
    will-change: transform;
    background-color: var(--color-accent-1);
  }

  /* Suppress default root view transition crossfade —
     our shutter handles the global page transition. */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none !important;
    mix-blend-mode: normal;
  }
</style>

<script>
  import gsap from 'gsap'
  import { animations } from '../data/tokens'

  const cfg = animations.pageTransition

  const accentColors = [
    'var(--color-accent-1)',
    'var(--color-accent-2)',
    'var(--color-accent-3)',
  ]

  type ShutterWindow = Window & {
    __shutterPrepHandler?: (e: Event) => void
    __shutterSwapHandler?: () => void
    __shutterActive?: boolean
    __shutterColorIndex?: number
  }

  function initShutter() {
    const w = window as ShutterWindow
    if (w.__shutterColorIndex == null) w.__shutterColorIndex = 0
    const panel = () => document.querySelector<HTMLElement>('.page-shutter-panel')
    const prefersReduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // Clean up previous handlers (idempotent)
    if (w.__shutterPrepHandler) {
      document.removeEventListener('astro:before-preparation', w.__shutterPrepHandler)
    }
    if (w.__shutterSwapHandler) {
      document.removeEventListener('astro:after-swap', w.__shutterSwapHandler)
    }

    function coverAnimation(): Promise<void> {
      if (prefersReduced()) return Promise.resolve()

      const el = panel()
      if (!el) return Promise.resolve()

      // Cycle to next accent color
      const colorIdx = w.__shutterColorIndex! % accentColors.length
      el.style.backgroundColor = accentColors[colorIdx]
      w.__shutterColorIndex = colorIdx + 1

      // Start below, wipe up to cover
      gsap.set(el, { y: '101%' })

      const container = document.getElementById('page-shutter')
      if (container) container.style.pointerEvents = 'all'

      return new Promise((resolve) => {
        gsap.to(el, {
          y: '0%',
          duration: cfg.duration,
          ease: cfg.ease,
          onComplete: resolve,
        })
      })
    }

    function uncoverAnimation(): Promise<void> {
      const el = panel()
      const container = document.getElementById('page-shutter')

      if (prefersReduced()) {
        if (el) gsap.set(el, { y: '101%' })
        if (container) container.style.pointerEvents = 'none'
        return Promise.resolve()
      }

      if (!el) return Promise.resolve()

      return new Promise((resolve) => {
        gsap.to(el, {
          y: '-101%',
          duration: cfg.duration,
          ease: cfg.ease,
          delay: cfg.exitDelay,
          onComplete: () => {
            gsap.set(el, { y: '101%' })
            if (container) container.style.pointerEvents = 'none'
            resolve()
          },
        })
      })
    }

    const handleBeforePreparation = (e: Event) => {
      const event = e as any
      const originalLoader = event.loader
      event.loader = async () => {
        w.__shutterActive = true
        await coverAnimation()
        await originalLoader()
      }
    }

    const handleAfterSwap = () => {
      if (!w.__shutterActive) return
      w.__shutterActive = false
      uncoverAnimation()
    }

    w.__shutterPrepHandler = handleBeforePreparation
    w.__shutterSwapHandler = handleAfterSwap

    document.addEventListener('astro:before-preparation', handleBeforePreparation)
    document.addEventListener('astro:after-swap', handleAfterSwap)
  }

  initShutter()
</script>
