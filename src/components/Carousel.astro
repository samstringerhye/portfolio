---
/**
 * GSAP Draggable + InertiaPlugin carousel.
 * Pre-calculates snap points after layout, uses static config.
 */
interface Props {
  label?: string
  fullBleed?: boolean
}

const { label, fullBleed = false } = Astro.props
---

<div class:list={['carousel', { 'carousel--full-bleed': fullBleed }]} tabindex="0" role="region" aria-roledescription="carousel" aria-label={label || 'Image carousel'} data-lenis-prevent>
  <div class="carousel-track">
    <slot />
  </div>
  <div class="carousel-dots" aria-live="polite"></div>
</div>

<style>
  .carousel {
    position: relative;
    overflow: hidden;
  }

  .carousel:focus-visible {
    outline: 2px solid var(--focus-ring-color);
    outline-offset: 2px;
  }

  .carousel:focus:not(:focus-visible) {
    outline: none;
  }

  .carousel-track {
    display: flex;
    padding: var(--space-4);
    will-change: transform;
    touch-action: pan-y pinch-zoom;
  }

  @media (pointer: fine) {
    .carousel-track {
      cursor: grab;
    }
    .carousel-track.is-dragging {
      cursor: grabbing;
    }
  }

  .carousel-track > :global(img),
  .carousel-track > :global(.cs-figure) {
    flex: 0 0 60%;
    padding: 0;
    margin: 0;
    border: none;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  .carousel-track > :global(.device-phone) {
    flex: 0 0 auto;
    padding: 0;
    margin: 0;
    border: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  .carousel-track > :global(img),
  .carousel-track > :global(.cs-figure) :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: var(--space-4) 0;
    border-top: var(--border-width-1) solid var(--color-rule);
  }

  .carousel-dots :global(.carousel-dot) {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: var(--color-text-primary);
    opacity: 0.3;
    transition: width 0.3s ease, opacity 0.3s ease;
  }

  .carousel-dots :global(.carousel-dot.is-active) {
    width: 16px;
    opacity: 1;
  }

  .carousel--full-bleed .carousel-track :global(img) {
    border-radius: 0;
    padding: 0 !important;
    background: transparent !important;
    object-fit: cover !important;
  }

  @media (--2x) {
    .carousel-track {
      padding-inline: var(--page-margin);
    }

    .carousel-track > :global(img),
    .carousel-track > :global(.cs-figure) {
      flex: 0 0 82%;
    }

    .carousel-track > :global(.device-phone) {
      flex: 0 0 auto;
      max-width: 82%;
    }

    .carousel-track :global(img) {
      border-radius: 0;
    }

    .carousel-dots {
      display: flex;
    }
  }
</style>

<script>
  import gsap from 'gsap'

  function initCarousels() {
    document.querySelectorAll('.carousel').forEach(carousel => {
      if ((carousel as HTMLElement).dataset.carouselInit === 'true') return
      ;(carousel as HTMLElement).dataset.carouselInit = 'true'

      const track = carousel.querySelector('.carousel-track') as HTMLElement
      const dotsContainer = carousel.querySelector('.carousel-dots') as HTMLElement
      if (!track || !dotsContainer) return

      // Unwrap Astro MDX wrapper div
      const wrapper = track.querySelector(':scope > div')
      if (wrapper && !wrapper.classList.contains('cs-figure') && !wrapper.classList.contains('device-phone')) {
        while (wrapper.firstChild) track.appendChild(wrapper.firstChild)
        wrapper.remove()
      }

      const slides = Array.from(track.querySelectorAll<HTMLElement>(':scope > img, :scope > .cs-figure, :scope > .device-phone'))
      if (slides.length <= 1) {
        dotsContainer.style.display = 'none'
        if (slides[0]) slides[0].style.flex = '0 0 100%'
        return
      }

      let currentIndex = 0
      let snapPoints: number[] = []

      function getGridMetrics() {
        const cw = (carousel as HTMLElement).offsetWidth
        const probe = document.createElement('div')
        probe.style.cssText = 'position:absolute;width:var(--grid-gutter);visibility:hidden;'
        carousel.appendChild(probe)
        const gutter = probe.offsetWidth
        carousel.removeChild(probe)
        const col = (cw - 11 * gutter) / 12
        return { col, gutter }
      }

      function applyGridSizing() {
        const cw = (carousel as HTMLElement).offsetWidth
        if (cw <= 768) {
          const probe = document.createElement('div')
          probe.style.cssText = 'position:absolute;width:var(--page-margin);visibility:hidden;'
          carousel.appendChild(probe)
          const padSide = probe.offsetWidth || 16
          carousel.removeChild(probe)
          const slideWidth = cw - (padSide * 2)
          track.style.paddingLeft = `${padSide}px`
          track.style.paddingRight = `${padSide}px`
          track.style.gap = `${padSide}px`
          slides.forEach(s => {
            if (s.classList.contains('device-phone')) {
              s.style.flex = '0 0 auto'
              s.style.maxWidth = `${slideWidth}px`
            } else {
              s.style.flex = `0 0 ${slideWidth}px`
            }
          })
          return
        }
        const { col, gutter } = getGridMetrics()
        const padLeft = col + gutter
        const slideWidth = col * 6 + gutter * 5
        const padRight = col + gutter
        track.style.paddingLeft = `${padLeft}px`
        track.style.paddingRight = `${padRight}px`
        track.style.gap = `${gutter}px`
        slides.forEach(s => {
          if (s.classList.contains('device-phone')) {
            s.style.flex = '0 0 auto'
            s.style.maxWidth = `${slideWidth}px`
          } else {
            s.style.flex = `0 0 ${slideWidth}px`
          }
        })
      }
      applyGridSizing()

      function buildSnapPoints() {
        const padLeft = parseFloat(getComputedStyle(track).paddingLeft)
        const maxScroll = -(track.scrollWidth - (carousel as HTMLElement).offsetWidth)
        snapPoints = slides.map(s => {
          const snap = padLeft - s.offsetLeft
          return Math.max(snap, maxScroll)
        })
        // Remove consecutive duplicates (tail slides clamped to maxScroll)
        // but always keep the last entry so every slide is reachable
        snapPoints = snapPoints.filter((v, i, a) => i === 0 || v !== a[i - 1])
      }
      buildSnapPoints()

      function nearestIndex(x: number): number {
        let best = 0, bestD = Infinity
        snapPoints.forEach((p, i) => {
          const d = Math.abs(x - p)
          if (d < bestD) { bestD = d; best = i }
        })
        return best
      }

      function renderDots() {
        dotsContainer.innerHTML = ''
        snapPoints.forEach((_, i) => {
          const dot = document.createElement('span')
          dot.className = 'carousel-dot' + (i === 0 ? ' is-active' : '')
          dot.setAttribute('aria-hidden', 'true')
          dotsContainer.appendChild(dot)
        })
      }

      function updateDots(index: number) {
        dotsContainer.querySelectorAll('.carousel-dot').forEach((dot, i) => {
          dot.classList.toggle('is-active', i === index)
        })
      }

      renderDots()

      function animateTo(index: number) {
        const i = Math.max(0, Math.min(index, snapPoints.length - 1))
        currentIndex = i
        updateDots(i)
        gsap.to(track, {
          x: snapPoints[i],
          duration: 0.5,
          ease: 'power3.out',
          overwrite: true,
        })
      }

      // ── Native pointer event drag ──
      let didDrag = false
      let dragging = false
      let startX = 0
      let startY = 0
      let trackStartX = 0
      let lastX = 0
      let lastTime = 0
      let velocityX = 0

      // Suppress click after drag so lightbox doesn't open
      track.addEventListener('click', (e) => {
        if (didDrag) { e.stopPropagation(); e.preventDefault(); didDrag = false }
      }, true)

      let pointerId = -1

      track.addEventListener('pointerdown', (e: PointerEvent) => {
        if (e.button !== 0) return
        dragging = true
        didDrag = false
        pointerId = e.pointerId
        startX = e.clientX
        startY = e.clientY
        lastX = e.clientX
        lastTime = Date.now()
        velocityX = 0
        trackStartX = (gsap.getProperty(track, 'x') as number) || 0
        gsap.killTweensOf(track)
      })

      track.addEventListener('pointermove', (e: PointerEvent) => {
        if (!dragging) return
        const dx = e.clientX - startX
        const dy = e.clientY - startY

        if (!didDrag) {
          const absDx = Math.abs(dx)
          const absDy = Math.abs(dy)
          if (absDx < 5 && absDy < 5) return
          if (absDy > absDx * 1.2) {
            dragging = false
            return
          }
          didDrag = true
          track.setPointerCapture(pointerId)
          track.classList.add('is-dragging')
        }

        e.preventDefault()

        // Track velocity
        const now = Date.now()
        const dt = now - lastTime
        if (dt > 0) {
          velocityX = (e.clientX - lastX) / dt * 1000
          lastX = e.clientX
          lastTime = now
        }

        let newX = trackStartX + dx
        // Rubber-band at edges
        const minX = snapPoints[snapPoints.length - 1]
        const maxX = snapPoints[0]
        if (newX > maxX) newX = maxX + (newX - maxX) * 0.3
        else if (newX < minX) newX = minX + (newX - minX) * 0.3
        gsap.set(track, { x: newX })
        updateDots(nearestIndex(newX))
      })

      function onPointerEnd(e: PointerEvent) {
        if (!dragging) return
        dragging = false
        track.classList.remove('is-dragging')

        if (!didDrag) return

        const trackX = gsap.getProperty(track, 'x') as number
        let targetIndex = nearestIndex(trackX)

        // Flick detection
        if (Math.abs(velocityX) > 300) {
          targetIndex = velocityX > 0
            ? Math.max(0, currentIndex - 1)
            : Math.min(snapPoints.length - 1, currentIndex + 1)
        }

        animateTo(targetIndex)
      }

      track.addEventListener('pointerup', onPointerEnd)
      track.addEventListener('pointercancel', onPointerEnd)

      // Prevent native image dragging
      track.addEventListener('dragstart', (e) => e.preventDefault())

      // ── Keyboard ──
      carousel.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') { animateTo(currentIndex + 1); e.preventDefault() }
        else if (e.key === 'ArrowLeft') { animateTo(currentIndex - 1); e.preventDefault() }
      })

      // Recalculate on resize
      if ((carousel as any).__carouselRo) (carousel as any).__carouselRo.disconnect()
      const ro = new ResizeObserver(() => {
        applyGridSizing()
        buildSnapPoints()
        renderDots()
        updateDots(Math.min(currentIndex, snapPoints.length - 1))
        gsap.set(track, { x: snapPoints[currentIndex] })
      })
      ;(carousel as any).__carouselRo = ro
      ro.observe(carousel)
    })
  }

  initCarousels()
  document.addEventListener('astro:page-load', initCarousels)
</script>
