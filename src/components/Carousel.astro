---
/**
 * Horizontal scroll carousel with CSS scroll-snap.
 * Enhanced: prev/next arrows, slide counter, next-slide peek, touch drag.
 */
interface Props {
  /** Optional label shown above the carousel */
  label?: string
}

const { label } = Astro.props
---

<div class="carousel" tabindex="0" role="region" aria-label={label || 'Image carousel'}>
  <div class="carousel-track">
    <slot />
  </div>
  <button class="carousel-arrow carousel-prev" aria-label="Previous slide">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button class="carousel-arrow carousel-next" aria-label="Next slide">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>
  <div class="carousel-counter" aria-live="polite"></div>
</div>

<style>
  .carousel {
    position: relative;
    outline: none;
  }

  .carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: var(--space-5);
    padding: var(--space-6);
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  /* Each slide: ~65% width so adjacent cards are clearly visible */
  .carousel-track > :global(img),
  .carousel-track > :global(.cs-figure) {
    flex: 0 0 60%;
    scroll-snap-align: center;
    padding: 0;
    margin: 0;
    border: none;
    display: block;
  }

  .carousel-track :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
  }

  /* ── Arrows ── */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-primary);
    border: var(--border-width-1) solid var(--color-text-primary);
    color: var(--color-text-primary);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease;
    padding: 0;
  }

  .carousel:hover .carousel-arrow,
  .carousel:focus-within .carousel-arrow {
    opacity: 1;
  }

  .carousel-arrow:hover {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .carousel-arrow:disabled {
    opacity: 0;
    pointer-events: none;
  }

  .carousel-prev { left: var(--space-2); }
  .carousel-next { right: var(--space-2); }

  /* ── Counter ── */
  .carousel-counter {
    position: absolute;
    bottom: var(--space-2);
    right: var(--space-2);
    font-size: var(--text-100);
    color: var(--color-text-secondary);
    background: var(--color-bg-primary);
    padding: var(--space-1) var(--space-2);
    border: var(--border-width-1) solid var(--color-text-primary);
    line-height: 1;
    z-index: 2;
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      scroll-behavior: auto;
    }
  }

  @media (--2x) {
    .carousel-track {
      padding-inline: var(--content-inset-sm);
    }

    .carousel-track > :global(img),
    .carousel-track > :global(.cs-figure) {
      flex: 0 0 82%;
    }

    .carousel-arrow {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script>
  function initCarousels() {
    document.querySelectorAll('.carousel').forEach(carousel => {
      if ((carousel as HTMLElement).dataset.carouselInit === 'true') return
      ;(carousel as HTMLElement).dataset.carouselInit = 'true'

      const track = carousel.querySelector('.carousel-track') as HTMLElement
      const counter = carousel.querySelector('.carousel-counter') as HTMLElement
      const prevBtn = carousel.querySelector('.carousel-prev') as HTMLButtonElement
      const nextBtn = carousel.querySelector('.carousel-next') as HTMLButtonElement
      if (!track || !counter) return

      // Astro MDX wraps slot content in a <div> — unwrap it so slides
      // become direct children of the track (fixes flex + scroll-snap)
      const wrapper = track.querySelector(':scope > div')
      if (wrapper && !wrapper.classList.contains('cs-figure')) {
        while (wrapper.firstChild) {
          track.appendChild(wrapper.firstChild)
        }
        wrapper.remove()
      }

      const slides = Array.from(track.querySelectorAll<HTMLElement>(':scope > img, :scope > .cs-figure'))
      if (slides.length <= 1) {
        counter.style.display = 'none'
        prevBtn?.remove()
        nextBtn?.remove()
        // Make single slide full width
        if (slides[0]) slides[0].style.flex = '0 0 100%'
        return
      }

      const prefersReduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches
      let currentIndex = 0

      function updateUI(index: number) {
        currentIndex = Math.max(0, Math.min(index, slides.length - 1))
        counter.textContent = `${currentIndex + 1} / ${slides.length}`
        if (prevBtn) prevBtn.disabled = currentIndex === 0
        if (nextBtn) nextBtn.disabled = currentIndex === slides.length - 1
      }

      // The scrollable element is the track itself
      const scrollContainer = track

      function goTo(index: number) {
        const target = slides[Math.max(0, Math.min(index, slides.length - 1))]
        if (!target) return
        const targetLeft = target.offsetLeft - scrollContainer.offsetLeft
        scrollContainer.scrollTo({
          left: targetLeft,
          behavior: prefersReduced() ? 'auto' : 'smooth',
        })
      }

      // Initial state
      updateUI(0)

      // Track scroll position to update counter
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const index = slides.indexOf(entry.target as HTMLElement)
            if (index >= 0) updateUI(index)
          }
        })
      }, { root: scrollContainer, threshold: 0.5 })

      slides.forEach(slide => observer.observe(slide))

      // Arrow buttons
      prevBtn?.addEventListener('click', () => goTo(currentIndex - 1))
      nextBtn?.addEventListener('click', () => goTo(currentIndex + 1))

      // Keyboard navigation
      carousel.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'ArrowRight') { goTo(currentIndex + 1); e.preventDefault() }
        else if ((e as KeyboardEvent).key === 'ArrowLeft') { goTo(currentIndex - 1); e.preventDefault() }
      })

      // Native CSS scroll-snap + touch handles swipe gestures;
      // GSAP Draggable removed — it wraps content in a div that breaks flex layout.
    })
  }

  initCarousels()
  document.addEventListener('astro:page-load', initCarousels)
</script>
