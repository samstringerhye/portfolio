---
import type { TypographyRole } from '../types/typography'
import { animations } from '../data/tokens'

interface Props {
  interests: string[]
  textRole?: TypographyRole
}

const { interests, textRole = 'display' } = Astro.props as Props
const text = interests.join(' \u00b7 ') + ' \u00b7 '
const copies = 4
const dg = animations.dotGrid
---

<section class="interests-section" aria-label="Interests">
  <div class="interests-row" data-direction="left">
    <svg class="interests-svg-defs" aria-hidden="true">
      <defs>
        <filter id="distort-1" color-interpolation-filters="sRGB" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="turbulence" baseFrequency="0.012" numOctaves="3" seed="42" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>
    <div class="interests-track" aria-hidden="true">
      {Array.from({ length: copies }, () => (
        <p class:list={["interests-text", `typo-${textRole}`]}>{text}</p>
      ))}
    </div>
  </div>

  <div class="interests-row" data-direction="right">
    <svg class="interests-svg-defs" aria-hidden="true">
      <defs>
        <filter id="distort-2" color-interpolation-filters="sRGB" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="turbulence" baseFrequency="0.012" numOctaves="3" seed="99" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>
    <div class="interests-track" aria-hidden="true">
      {Array.from({ length: copies }, () => (
        <p class:list={["interests-text", `typo-${textRole}`]}>{text}</p>
      ))}
    </div>
  </div>

  <p class="visually-hidden">{interests.join(', ')}</p>
</section>

<style define:vars={{ dotGridOpacity: dg.opacity, dotSpacing: `${dg.spacing}px`, dotRadius: `${dg.radius}px` }}>
  .interests-section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-2);
    overflow: hidden;
    padding-block: calc(var(--section-padding) * 8);
  }

  .interests-section::before {
    content: '';
    position: absolute;
    inset: 0;
    width: calc(100% + var(--dotSpacing));
    height: calc(100% + var(--dotSpacing));
    background-image: radial-gradient(circle, var(--color-text-primary) var(--dotRadius), transparent var(--dotRadius));
    background-size: var(--dotSpacing) var(--dotSpacing);
    opacity: var(--dotGridOpacity);
    pointer-events: none;
    will-change: transform;
    animation: dot-drift 2s linear infinite;
  }

  @keyframes dot-drift {
    from { transform: translate(0, 0); }
    to { transform: translate(calc(-1 * var(--dotSpacing)), calc(-1 * var(--dotSpacing))); }
  }

  @media (prefers-reduced-motion: reduce) {
    .interests-section::before { animation: none; }
  }

  .interests-row {
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  .interests-svg-defs {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .interests-track {
    display: flex;
    white-space: nowrap;
    will-change: transform;
  }

  .interests-text {
    color: var(--color-text-primary);
    padding: 0 var(--inline-spacing-1x);
    max-width: none;
    white-space: nowrap;
    flex-shrink: 0;
    margin: 0;
  }

  @media (--2x) {
    .interests-section {
      padding-block: calc(var(--section-padding) * 4);
    }
  }
</style>

<script>
  let interestsTweens: any[] = []
  let interestsObserver: IntersectionObserver | null = null

  function cleanupScrollingInterests() {
    interestsTweens.forEach(t => t.kill())
    interestsTweens = []
    interestsObserver?.disconnect()
    interestsObserver = null
  }

  async function initScrollingInterests() {
    cleanupScrollingInterests()

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    const section = document.querySelector('.interests-section')
    if (!section) return

    const [{ default: gsap }, { animations }] = await Promise.all([
      import('gsap'),
      import('../data/tokens'),
    ])

    const scrollDuration = animations.interests.scrollDuration
    const rows = document.querySelectorAll('.interests-row')

    rows.forEach((row, i) => {
      const track = row.querySelector('.interests-track')
      if (!track) return

      const copyWidth = (track as HTMLElement).scrollWidth / 4
      const direction = row.getAttribute('data-direction')
      const filterId = `distort-${i + 1}`

      const canFilter = window.matchMedia('(pointer: fine)').matches
      if (canFilter) {
        ;(track as HTMLElement).style.filter = `url(#${filterId})`
      }

      let tween: any

      if (direction === 'left') {
        tween = gsap.to(track, {
          x: -copyWidth,
          duration: scrollDuration,
          ease: 'none',
          repeat: -1,
          modifiers: {
            x: gsap.utils.unitize((x: string) => parseFloat(x) % copyWidth),
          },
        })
      } else {
        gsap.set(track, { x: -copyWidth })
        tween = gsap.to(track, {
          x: 0,
          duration: scrollDuration,
          ease: 'none',
          repeat: -1,
          modifiers: {
            x: gsap.utils.unitize((x: string) => {
              const v = parseFloat(x) % copyWidth
              return v === 0 ? 0 : v - copyWidth
            }),
          },
        })
      }

      tween.pause()
      interestsTweens.push(tween)
    })

    // Pause/resume infinite tweens based on visibility
    interestsObserver = new IntersectionObserver(([entry]) => {
      interestsTweens.forEach(t => entry.isIntersecting ? t.play() : t.pause())
    }, { threshold: 0 })
    interestsObserver.observe(section)
  }

  function deferInit() {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => initScrollingInterests(), { timeout: 2000 })
    } else {
      setTimeout(initScrollingInterests, 200)
    }
  }

  deferInit()
  document.addEventListener('astro:page-load', deferInit)
  document.addEventListener('astro:before-swap', cleanupScrollingInterests)
</script>
