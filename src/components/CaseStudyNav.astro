---
interface Props {
  prevSlug?: string
  prevTitle?: string
  nextSlug?: string
  nextTitle?: string
}

const { prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
---

<nav class="cs-nav" aria-label="Case study navigation">
  <div class="cs-nav-inner">
    {prevSlug ? (
      <a href={`/work/${prevSlug}`} class="cs-nav-link cs-nav-prev">
        <span class="cs-nav-label typo-ui-caps">Previous</span>
        <span class="cs-nav-title typo-headline-sm">{prevTitle}</span>
      </a>
    ) : <div />}

    {nextSlug ? (
      <a href={`/work/${nextSlug}`} class="cs-nav-link cs-nav-next">
        <span class="cs-nav-label typo-ui-caps">Next</span>
        <span class="cs-nav-title typo-headline-sm">{nextTitle}</span>
      </a>
    ) : (
      <a href="/work" class="cs-nav-link cs-nav-next">
        <span class="cs-nav-label typo-ui-caps">Browse</span>
        <span class="cs-nav-title typo-headline-sm">All work</span>
      </a>
    )}
  </div>
</nav>

<style>
  .cs-nav {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    padding: 0;
  }

  .cs-nav-inner {
    position: relative;
    grid-column: 1 / -1;
    display: flex;
    align-items: flex-start;
    gap: var(--grid-gutter);
    padding: var(--space-6);
  }

  .cs-nav-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 1));
    transform-origin: left;
  }

  .cs-nav-link {
    text-decoration: none;
    padding: var(--space-2) 0;
  }

  .cs-nav-prev {
    margin-right: auto;
  }

  .cs-nav-next {
    text-align: right;
    margin-left: auto;
  }

.cs-nav-label {
    display: block;
    margin-bottom: var(--space-1);
  }

  @media (hover: hover) {
    .cs-nav-link:hover .cs-nav-title {
      animation: cmy-cycle 1.5s steps(1, end) infinite;
    }
  }

  @media (--2x) {
    .cs-nav-inner {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-inline: var(--page-margin);
    }

    .cs-nav-link {
      min-height: 44px;
    }

    .cs-nav-prev {
      margin-right: 0;
    }

    .cs-nav-next {
      text-align: right;
    }

  }
</style>
