---
interface Props {
  prevSlug?: string
  prevTitle?: string
  nextSlug?: string
  nextTitle?: string
}

const { prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
---

{(prevSlug || nextSlug) && (
  <nav class="cs-nav" aria-label="Case study navigation">
    <div class="cs-nav-inner">
      {prevSlug ? (
        <a href={`/work/${prevSlug}`} class="cs-nav-link cs-nav-prev" data-hover="spectral-link">
          <span class="cs-nav-label typo-ui-caps">Previous</span>
          <span class="cs-nav-title typo-ui">{prevTitle}</span>
        </a>
      ) : <div />}

      {nextSlug ? (
        <a href={`/work/${nextSlug}`} class="cs-nav-link cs-nav-next" data-hover="spectral-link">
          <span class="cs-nav-label typo-ui-caps">Next</span>
          <span class="cs-nav-title typo-ui">{nextTitle}</span>
        </a>
      ) : <div />}
    </div>
  </nav>
)}

<style>
  .cs-nav {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    padding: var(--space-6) 0;
  }

  .cs-nav-inner {
    grid-column: 4 / 10;
    display: flex;
    justify-content: space-between;
    border-top: var(--border-width-1) solid var(--color-rule);
    padding-top: var(--space-6);
  }

  .cs-nav-link {
    text-decoration: none;
    transition: color var(--transition-fast) ease;
  }

  .cs-nav-next {
    text-align: right;
  }

  .cs-nav-label {
    display: block;
    margin-bottom: var(--space-1);
  }

  .cs-nav-link:hover .cs-nav-title {
    color: var(--color-text-primary);
  }

  @media (--2x) {
    .cs-nav-inner {
      grid-column: 1 / -1;
    }
  }
</style>
