---
interface Props {
  prevSlug?: string
  prevTitle?: string
  nextSlug?: string
  nextTitle?: string
}

const { prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
---

{(prevSlug || nextSlug) && (
  <nav class="cs-nav" aria-label="Case study navigation">
    <div class="cs-nav-inner">
      <div class="cs-nav-links">
        {prevSlug ? (
          <a href={`/work/${prevSlug}`} class="cs-nav-link cs-nav-prev" data-hover="spectral-link">
            <span class="cs-nav-label typo-ui-caps">Previous</span>
            <span class="cs-nav-title typo-heading-sm">{prevTitle}</span>
          </a>
        ) : <div />}

        {nextSlug ? (
          <a href={`/work/${nextSlug}`} class="cs-nav-link cs-nav-next" data-hover="spectral-link">
            <span class="cs-nav-label typo-ui-caps">Next</span>
            <span class="cs-nav-title typo-heading-sm">{nextTitle}</span>
          </a>
        ) : <div />}
      </div>
    </div>
  </nav>
)}

<style>
  .cs-nav {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    padding: var(--space-6) 0;
  }

  .cs-nav-inner {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    border-top: var(--border-width-1) solid var(--color-rule);
    padding-top: var(--space-6);
  }

  .cs-nav-links {
    grid-column: 2 / 12;
    display: flex;
    justify-content: space-between;
  }

  .cs-nav-link {
    text-decoration: none;
    padding: var(--space-2) 0;
    transition: color var(--transition-fast) ease;
  }

  .cs-nav-next {
    text-align: right;
  }

  .cs-nav-label {
    display: block;
    margin-bottom: var(--space-1);
  }

  .cs-nav-link:hover .cs-nav-title {
    color: var(--color-text-primary);
  }

  @media (--2x) {
    .cs-nav-inner {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
      border-top: var(--border-width-1) solid var(--color-rule);
    }

    .cs-nav-links {
      grid-column: 1 / -1;
    }
  }
</style>
