---
interface Props {
  prevSlug?: string
  prevTitle?: string
  nextSlug?: string
  nextTitle?: string
}

const { prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
---

{(prevSlug || nextSlug) && (
  <nav class="cs-nav" aria-label="Case study navigation">
    <div class="cs-nav-inner">
      {prevSlug ? (
        <a href={`/work/${prevSlug}`} class="cs-nav-link cs-nav-prev">
          <span class="cs-nav-label typo-ui-caps">Previous</span>
          <span class="cs-nav-title typo-headline-sm">{prevTitle}</span>
        </a>
      ) : <div />}

      {nextSlug ? (
        <a href={`/work/${nextSlug}`} class="cs-nav-link cs-nav-next">
          <span class="cs-nav-label typo-ui-caps">Next</span>
          <span class="cs-nav-title typo-headline-sm">{nextTitle}</span>
        </a>
      ) : <div />}

      <a href="/work" class="cs-nav-link cs-nav-all">
        <span class="cs-nav-label typo-ui-caps">Browse</span>
        <span class="cs-nav-title typo-headline-sm">All work</span>
      </a>
    </div>
  </nav>
)}

<style>
  .cs-nav {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    padding: var(--space-6) 0;
  }

  .cs-nav-inner {
    grid-column: 2 / 12;
    display: flex;
    align-items: flex-start;
    gap: var(--grid-gutter);
    border-top: var(--border-width-1) solid var(--color-rule);
    padding-top: var(--space-6);
  }

  .cs-nav-link {
    text-decoration: none;
    padding: var(--space-2) 0;
    transition: color var(--duration-short) ease;
  }

  .cs-nav-prev {
    margin-right: auto;
  }

  .cs-nav-next {
    text-align: right;
  }

  .cs-nav-all {
    margin-left: auto;
    display: flex;
    align-items: center;
    padding: var(--space-2) 0;
    color: var(--color-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-short) ease;
  }

  .cs-nav-all:hover {
    color: var(--color-text-primary);
  }

  .cs-nav-label {
    display: block;
    margin-bottom: var(--space-1);
  }

  @media (hover: hover) {
    .cs-nav-link:hover .cs-nav-title {
      color: var(--color-text-primary);
    }
  }

  @media (--2x) {
    .cs-nav-inner {
      grid-column: 1 / -1;
      flex-wrap: wrap;
      padding-inline: var(--page-margin);
    }

    .cs-nav-link {
      min-height: 44px;
    }

    .cs-nav-all {
      min-height: 44px;
    }
  }
</style>
