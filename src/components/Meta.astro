---
interface Props {
  client: string
  role: string
  agency: string
  year: number
}

const { client, role, agency, year } = Astro.props
---

<dl class="cs-hero-meta">
  <div class="cs-meta-item">
    <dt class="cs-meta-label typo-ui-caps">Client</dt>
    <dd class="cs-meta-value typo-body-lg">{client}</dd>
  </div>
  <div class="cs-meta-item">
    <dt class="cs-meta-label typo-ui-caps">Role</dt>
    <dd class="cs-meta-value typo-body-lg">{role}</dd>
  </div>
  <div class="cs-meta-item">
    <dt class="cs-meta-label typo-ui-caps">Agency</dt>
    <dd class="cs-meta-value typo-body-lg">{agency}</dd>
  </div>
  <div class="cs-meta-item">
    <dt class="cs-meta-label typo-ui-caps">Year</dt>
    <dd class="cs-meta-value typo-body-lg">{year}</dd>
  </div>
</dl>
