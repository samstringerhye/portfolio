---
import type { HeadingTag, TypographyRole } from '../types/typography'
import { animations } from '../data/tokens'

interface Props {
  headline: string
  tag?: HeadingTag
  role?: TypographyRole
}

const { headline, tag = 'h1', role = 'display' } = Astro.props as Props
const HeroTag = tag as any
const heroRole = `typo-${role}`

const revealCfg = animations.textReveal
const heroInitBlur = `${revealCfg.initialBlur}px`
---

<section class="hero" aria-label="Introduction">
  <div class="hero-canvas-fallback" aria-hidden="true"></div>
  <div id="hero-canvas-root" aria-hidden="true">
    <canvas style="display:block;width:100%;height:100%"></canvas>
  </div>
  <div class="hero-text">
    <HeroTag class:list={["hero-block", heroRole]} data-hero-text>{headline}</HeroTag>
  </div>
</section>

<style define:vars={{ heroInitBlur }}>
  .hero {
    position: relative;
    width: 100%;
    height: 75vh;
    overflow: hidden;
    background-color: var(--color-bg-primary);
  }

  .hero-canvas-fallback {
    position: absolute;
    inset: 0;
    z-index: var(--z-base);
    background: radial-gradient(ellipse at 50% 60%, var(--color-bg-alt) 0%, var(--color-bg-primary) 70%);
  }

  #hero-canvas-root {
    position: absolute;
    inset: 0;
    z-index: var(--z-base);
    background-color: var(--color-bg-primary);
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  #hero-canvas-root.is-ready {
    opacity: 1;
  }

  .hero-text {
    position: relative;
    width: 100%;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-inline: var(--page-margin);
    z-index: var(--z-base, 1);
  }

  .hero-block {
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
  }

  /* Initial state set via JS to avoid blocking LCP */

  @media (prefers-reduced-motion: reduce) {
    .hero-block {
      opacity: 1;
      transform: none;
      filter: none;
    }
    #hero-canvas-root {
      transition: none;
      opacity: 1;
    }
  }
</style>

<script>
  import type { CmyAutoSplitHandle } from './cmy-animate'

  let heroHandles: CmyAutoSplitHandle[] = []

  async function animateHero() {
    const els = document.querySelectorAll<HTMLElement>('[data-hero-text]')
    if (!els.length) return

    heroHandles.forEach(h => h.kill())
    heroHandles = []

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const [{ default: gsap }, { animations }, { createCmyAutoSplitReveal }] = await Promise.all([
      import('gsap'),
      import('../data/tokens'),
      import('./cmy-animate'),
    ])

    if (prefersReduced) {
      gsap.set(els, { opacity: 1, y: 0, filter: 'none', textShadow: 'none' })
      return
    }

    const cfg = animations.textReveal

    // Set initial hidden state via JS (not CSS) so LCP isn't blocked
    gsap.set(els, { opacity: 0, filter: `blur(${cfg.initialBlur}px)` })

    const startDelay = animations.hero.text.startDelay

    await document.fonts.ready

    els.forEach(el => {
      heroHandles.push(createCmyAutoSplitReveal(el, cfg, { delay: startDelay }))
    })
  }

  function deferHero() {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => animateHero(), { timeout: 1500 })
    } else {
      setTimeout(animateHero, 100)
    }
  }

  document.addEventListener('astro:page-load', deferHero)
</script>

<script>
  let cleanupCanvas: (() => void) | null = null

  async function mountHeroCanvas() {
    const root = document.getElementById('hero-canvas-root')
    if (!root) return
    cleanupCanvas?.()
    const { initHeroCanvas } = await import('./hero-canvas')
    cleanupCanvas = await initHeroCanvas(root)
  }

  function deferCanvas() {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => mountHeroCanvas(), { timeout: 1500 })
    } else {
      setTimeout(mountHeroCanvas, 1000)
    }
  }

  document.addEventListener('astro:page-load', deferCanvas)
</script>
