---
import homeData from '../content/home.json'
import type { HomeContent } from '../types/content'

interface Props {
  contentInset?: 'sm' | 'md' | 'lg'
}

const { contentInset = 'md' } = Astro.props as Props

const home: HomeContent = homeData
const {
  headline = 'Experience',
  headingTag = 'h2', headingRole = 'display',
  jobTitleTag = 'h3', jobTitleRole = 'subhead',
  companyTag = 'p', companyRole = 'body',
  highlightRole = 'body',
  jobs,
} = home.experience

const HeadingTag = headingTag as any
const JobTitleTag = jobTitleTag as any
const CompanyTag = companyTag as any

const currentYear = new Date().getFullYear()

function getYear(d: string | null) {
  if (!d) return currentYear
  return parseInt(d.split('-')[0], 10)
}

const timelineStart = 2012
const timelineEnd = currentYear - 1 // display years 2012–2025

// Year markers — one per grid row, newest at top
const yearMarkers: number[] = []
for (let y = timelineEnd; y >= timelineStart; y--) {
  yearMarkers.push(y)
}

// Each year = 1 grid row. Newest year = row 1.
function yearToRow(year: number) {
  return timelineEnd - year + 1
}

const jobsChronological = [...jobs]

const jobsWithRows = jobsChronological.map((j, i) => {
  const start = getYear(j.startDate)
  const end = getYear(j.endDate)
  const yearLabel = j.endDate ? `${start}–${end}` : `${start}–Present`
  // In inverted grid: end year is at top (lower row), start year at bottom (higher row).
  // End year is exclusive (same convention as original) — current jobs extend to row 1.
  const rowStart = end > timelineEnd ? yearToRow(timelineEnd) : yearToRow(end) + 1
  const rowEnd = yearToRow(start) + 1
  return {
    ...j,
    yearLabel,
    index: i,
    rowStart,
    rowEnd,
  }
})
---

<section class="experience-section" aria-label="Experience" style={`--content-inset: var(--content-inset-${contentInset})`}>
  <div class="experience-header">
    <HeadingTag class:list={["experience-heading", `typo-${headingRole}`]} data-reveal>{headline}</HeadingTag>
    <a href="/resume" class="experience-download" aria-label="View resume">
      <svg class="experience-download-icon" width="28" height="28" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="80" y1="100" x2="140" y2="100"/><polyline points="115,75 140,100 115,125"/></svg>
    </a>
  </div>
  <div class="experience-timeline" data-timeline
       style={`--tl-rows: ${yearMarkers.length}`}>
    {/* Year cells — column 1, one per row */}
    {yearMarkers.map((year, i) => (
      <div class="tl-year" style={`grid-row: ${i + 1}`} aria-hidden="true">
        <p class="typo-ui-caps">{year}</p>
      </div>
    ))}

    {/* Job rows — columns 2-8, spanning year rows */}
    <ul class="tl-jobs" role="list" style="display:contents">
      {jobsWithRows.map((job) => (
        <li class="tl-job" style={`grid-row: ${job.rowStart} / ${job.rowEnd}`}
            data-card-index={job.index}>
          <div class="tl-job-wipe" aria-hidden="true"></div>
          <span class="visually-hidden">{job.yearLabel}</span>
          <span class="tl-job-year-mobile typo-ui-caps">{job.yearLabel}</span>
          <div class="tl-job-info">
            <JobTitleTag class:list={[`typo-${jobTitleRole}`, 'tl-job-title']}>
              {job.title}
            </JobTitleTag>
            <CompanyTag class:list={[`typo-${companyRole}`, 'tl-job-company']}>
              {job.company}
            </CompanyTag>
          </div>
          {job.highlights?.length > 0 && (
            <div class="tl-job-highlights">
              {job.highlights.map((h: string) => (
                <p class:list={[`typo-${highlightRole}`]}>{h}</p>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .experience-section {
    padding: 0;
  }

  .experience-header {
    position: relative;
    display: flex;
    align-items: center;
  }

  .experience-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--experience-header-draw, 0));
    transform-origin: left;
  }

  @media (prefers-reduced-motion: reduce) {
    .experience-header {
      --experience-header-draw: 1 !important;
    }
    .tl-year,
    .tl-job,
    .experience-download {
      --border-draw: 1 !important;
    }
  }

  .experience-heading {
    color: var(--color-text-primary);
    margin: 0;
    padding: var(--content-inset-md);
  }

  .experience-download {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    transition: background-color var(--duration-medium) ease;
  }

  /* Left border — draws top to bottom */
  .experience-download::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: var(--border-width-1);
    background: var(--color-text-primary);
    transform: scaleY(var(--border-draw, 0));
    transform-origin: top;
  }

  .experience-download-icon {
    width: 65%;
    height: 65%;
    transition: transform var(--duration-medium) cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @media (hover: hover) {
    .experience-download:hover .experience-download-icon {
      transform: scale(1.2) rotate(-5deg);
      transition: transform 490ms cubic-bezier(0.5, 0, 0, 1);
    }
  }

  /* ── Grid layout: year col + 12-col grid ── */
  .experience-timeline {
    display: grid;
    grid-template-columns: auto repeat(12, 1fr);
    column-gap: var(--grid-gutter);
    grid-template-rows: repeat(var(--tl-rows), auto);
    padding-inline: var(--page-margin);
    min-width: 0;
  }

  /* Year cells — column 1 with drawn borders */
  .tl-year {
    grid-column: 1;
    position: relative;
    display: flex;
    align-items: center;
    padding: var(--space-2) var(--space-3) var(--space-2) var(--page-margin);
    margin-left: calc(var(--page-margin) * -1);
    color: var(--color-text-primary);
  }

  /* Bottom border — draws left to right */
  .tl-year::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 0));
    transform-origin: left;
  }

  /* Right border — draws top to bottom */
  .tl-year::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleY(var(--border-draw, 0));
    transform-origin: top;
  }

  .tl-year:last-of-type::after {
    display: none;
  }

  /* Job cards — columns 2-13, subgrid */
  .tl-job {
    grid-column: 2 / -1;
    position: relative;
    display: grid;
    grid-template-columns: subgrid;
    align-items: center;
    margin-left: calc(var(--grid-gutter) * -1);
    margin-right: calc(var(--page-margin) * -1);
    padding: var(--space-2) var(--page-margin) var(--space-2) var(--grid-gutter);
    overflow: hidden;
  }

  /* Bottom border — draws left to right */
  .tl-job::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--border-width-1);
    background: var(--color-rule);
    transform: scaleX(var(--border-draw, 0));
    transform-origin: left;
    z-index: 0;
  }

  .tl-job:last-child::after {
    display: none;
  }

  /* Wipe overlay for hover */
  .tl-job-wipe {
    position: absolute;
    inset: 0;
    transform: scaleX(0);
    transform-origin: left;
    pointer-events: none;
    will-change: transform;
  }

  .tl-job-title,
  .tl-job-company {
    position: relative;
    z-index: 1;
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  /* Job info — 3 cols wide (subgrid cols 1–3) */
  .tl-job-info {
    grid-column: 1 / 4;
    grid-row: 1;
    position: relative;
    z-index: 1;
  }

  /* Highlights — starting at col 4 with gutter inset */
  .tl-job-highlights {
    grid-column: 4 / 10;
    grid-row: 1;
    padding-left: var(--grid-gutter);
    position: relative;
    z-index: 1;
    visibility: hidden;
    color: var(--color-text-primary);
    text-wrap: pretty;
  }

  /* Mobile year label — hidden on desktop */
  .tl-job-year-mobile {
    display: none;
    color: var(--color-text-primary);
  }

  /* ── Mobile ── */
  @media (--2x) {
    .experience-timeline {
      grid-template-columns: auto 1fr;
      column-gap: 0;
      padding-inline: 0;
    }

    .tl-year {
      padding: var(--space-2) var(--space-3);
      margin-left: 0;
    }

    .tl-job {
      grid-column: 2;
      display: flex;
      align-items: center;
      margin-left: 0;
      margin-right: 0;
      padding: var(--space-2) var(--page-margin) var(--space-2) var(--space-3);
      pointer-events: none;
    }

    .tl-job-wipe {
      display: none;
    }

    .tl-job-highlights {
      display: none;
    }

    .tl-job-year-mobile {
      display: none;
    }

    .experience-heading {
      padding: var(--space-4) var(--page-margin);
    }

    .experience-download {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { SplitText } from 'gsap/SplitText'
  import { animations, cmyRgba } from '../data/tokens'
  import { tightenSingleLineHeadings } from './tighten-headings'

  gsap.registerPlugin(SplitText)

  const h = animations.timeline.hover
  const CMY_COLORS = cmyRgba(h.cmyOpacity)
  let colorIndex = 0

  function initTimelineHover() {
    const timeline = document.querySelector<HTMLElement>('[data-timeline]')
    if (!timeline) return

    const cards = Array.from(timeline.querySelectorAll<HTMLElement>('.tl-job'))
    const yearCells = Array.from(timeline.querySelectorAll<HTMLElement>('.tl-year'))

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    // Build a map of grid-row index → year cell element
    const yearsByRow = new Map<number, HTMLElement>()
    yearCells.forEach((el) => {
      const row = parseInt(el.style.gridRow, 10)
      if (!isNaN(row)) yearsByRow.set(row, el)
    })

    function getJobYears(card: HTMLElement): HTMLElement[] {
      const parts = card.style.gridRow.split('/')
      const start = parseInt(parts[0], 10)
      const end = parseInt(parts[1], 10)
      const matched: HTMLElement[] = []
      for (let r = start; r < end; r++) {
        const el = yearsByRow.get(r)
        if (el) matched.push(el)
      }
      return matched
    }

    cards.forEach((card) => {
      if (card.dataset.hoverBound === 'true') return
      card.dataset.hoverBound = 'true'

      const wipe = card.querySelector<HTMLElement>('.tl-job-wipe')!
      const highlights = card.querySelector<HTMLElement>('.tl-job-highlights')
      const jobYears = getJobYears(card)

      // Pre-split highlights into lines
      let splitLines: HTMLElement[] = []
      if (highlights) {
        const split = SplitText.create(highlights, {
          type: 'lines',
          linesClass: 'highlight-line',
          autoSplit: true,
        })
        splitLines = split.lines as HTMLElement[]
        gsap.set(splitLines, { opacity: 0, x: -12 })
        // Keep container hidden until hover — visibility toggled in enter/leave
      }

      card.addEventListener('mouseenter', () => {
        const color = CMY_COLORS[colorIndex++ % CMY_COLORS.length]

        gsap.set(wipe, { backgroundColor: color, scaleX: 0 })
        gsap.to(wipe, { scaleX: 1, duration: h.wipeDuration, ease: h.wipeEase })

        // Light up corresponding year cells
        jobYears.forEach((yr) => {
          gsap.to(yr, { backgroundColor: color, duration: h.wipeDuration, ease: h.wipeEase })
        })

        if (splitLines.length && highlights) {
          highlights.style.visibility = 'visible'
          gsap.killTweensOf(splitLines)
          gsap.set(splitLines, { opacity: 0, x: -12 })
          gsap.to(splitLines, {
            opacity: 1, x: 0,
            duration: 0.6,
            delay: h.highlightsShowDelay,
            ease: 'power4.out',
            stagger: 0.08,
          })
        }
      })

      card.addEventListener('mouseleave', () => {
        gsap.to(wipe, { scaleX: 0, duration: h.wipeOutDuration, ease: h.wipeOutEase })

        // Reset year cells
        jobYears.forEach((yr) => {
          gsap.to(yr, { backgroundColor: 'transparent', duration: h.wipeOutDuration, ease: h.wipeOutEase })
        })

        if (splitLines.length && highlights) {
          gsap.killTweensOf(splitLines)
          gsap.to(splitLines, {
            opacity: 0, x: -12,
            duration: 0.25,
            ease: 'power2.in',
            stagger: 0.02,
            overwrite: true,
            onComplete: () => { highlights.style.visibility = 'hidden' },
          })
        }
      })
    })
  }

  function initDownloadHover() {
    if (!window.matchMedia('(hover: hover)').matches) return
    document.querySelectorAll<HTMLElement>('.experience-download').forEach((el) => {
      if (el.dataset.hoverBound === 'true') return
      el.dataset.hoverBound = 'true'
      el.addEventListener('mouseenter', () => {
        el.style.backgroundColor = CMY_COLORS[colorIndex++ % CMY_COLORS.length]
      })
      el.addEventListener('mouseleave', () => {
        el.style.backgroundColor = ''
      })
    })
  }

  tightenSingleLineHeadings('.experience-heading')
  initTimelineHover()
  initDownloadHover()
  document.addEventListener('astro:page-load', () => {
    tightenSingleLineHeadings('.experience-heading')
    initTimelineHover()
    initDownloadHover()
  })
</script>

