---
/**
 * Spacing System diagram for Whataburger case study.
 * ×100 scale (base 4px) for spacing, radius, and stroke
 */
const spacing = [
  { token: '050', value: 2 },
  { token: '0', value: 0 },
  { token: '100', value: 4 },
  { token: '200', value: 8 },
  { token: '300', value: 12 },
  { token: '400', value: 16 },
  { token: '600', value: 24 },
  { token: '800', value: 32 },
  { token: '1200', value: 48 },
  { token: '1600', value: 64 },
  { token: '2000', value: 80 },
  { token: '3000', value: 120 },
]

const radius = [
  { token: '0', value: 0, prim: 'radius/0' },
  { token: '100', value: 4, prim: 'radius/4' },
  { token: '200', value: 8, prim: 'radius/8' },
  { token: '300', value: 16, prim: 'radius/16' },
  { token: '400', value: 24, prim: 'radius/24' },
  { token: '600', value: 32, prim: 'radius/32' },
  { token: '800', value: 48, prim: 'radius/48' },
  { token: 'full', value: 999, prim: 'radius/999' },
]
---

<section class="spacing-system" aria-label="Spacing and radius token system">
  <div class="system-grid">
    <div class="spacing-section">
      <h4 class="section-title">Spacing</h4>
      <p class="section-desc">12 steps, ×100 scale (base 4px)</p>
      <div class="spacing-rows">
        {spacing.filter(s => s.value > 0).map(s => (
          <div class="spacing-row">
            <code class="spacing-token">spacing/{s.token}</code>
            <div class="spacing-bar-track">
              <div class="spacing-bar" style={`width: ${Math.min((s.value / 120) * 100, 100)}%;`} />
            </div>
            <span class="spacing-value">{s.value}px</span>
          </div>
        ))}
      </div>
    </div>

    <div class="radius-section">
      <h4 class="section-title">Radius</h4>
      <p class="section-desc">8 steps, ×100 scale (base 4px) + full</p>
      <div class="radius-grid">
        {radius.map(r => (
          <div class="radius-item">
            <div class="radius-preview" style={`border-radius: ${r.value === 999 ? '50%' : r.value + 'px'};`} />
            <code class="radius-token">radius/{r.token}</code>
            <span class="radius-value">{r.value === 999 ? '999' : r.value}px</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .spacing-system {
    background: #fdf8f4;
    margin: 2rem 0;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
  }

  .system-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
  }

  .section-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: #472c19;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.15rem;
  }

  .section-desc {
    font-size: 0.75rem;
    color: #806c5b;
    margin: 0 0 1rem;
  }

  .spacing-rows {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .spacing-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .spacing-token {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: #472c19;
    width: 100px;
    min-width: 100px;
    text-align: right;
  }

  .spacing-bar-track {
    flex: 1;
    height: 12px;
    background: #fdf8f4;
    border-radius: 3px;
    overflow: hidden;
  }

  .spacing-bar {
    height: 100%;
    background: #fe7800;
    border-radius: 3px;
    min-width: 2px;
  }

  .spacing-value {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: #806c5b;
    width: 40px;
    min-width: 40px;
  }

  .radius-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .radius-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .radius-preview {
    width: 56px;
    height: 56px;
    background: #fe7800;
    flex-shrink: 0;
  }

  .radius-token {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.65rem;
    color: #472c19;
    text-align: center;
  }

  .radius-value {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.65rem;
    color: #806c5b;
  }

  @media (max-width: 768px) {
    .system-grid {
      grid-template-columns: 1fr;
    }
    .radius-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
