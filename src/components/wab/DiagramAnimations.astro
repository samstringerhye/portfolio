---
/**
 * Loader component for shared diagram scroll animations.
 * Place once at the bottom of the case study MDX.
 */
---

<div data-diagram-animations></div>

<script>
  import { initDiagramAnimations } from './diagram-animations'

  function init() {
    const el = document.querySelector('[data-diagram-animations]')
    if (!el || (el as HTMLElement).dataset.loaded === 'true') return
    ;(el as HTMLElement).dataset.loaded = 'true'
    initDiagramAnimations()
  }

  init()
  document.addEventListener('astro:page-load', init)
</script>
