---
/**
 * Color States diagram for Whataburger case study.
 * Shows 11 states × 3 categories (fg, bg, border)
 */
const states = [
  // Row 1: Core states
  {
    name: 'Primary', desc: 'Default UI surfaces',
    fg: { token: 'neutral/1000', hex: '#472c19' },
    bg: { token: 'neutral/100', hex: '#fcfcfb' },
    border: { token: 'orange/200', hex: '#ffd6ba' },
    style: 'light',
  },
  {
    name: 'Secondary', desc: 'Warm-tinted surfaces',
    fg: { token: 'neutral/900', hex: '#59412c' },
    bg: { token: 'orange/100', hex: '#fff8f4' },
    border: { token: 'neutral/300', hex: '#f4ebe1' },
    style: 'light',
  },
  {
    name: 'Inverse', desc: 'Dark surfaces, light text',
    fg: { token: 'neutral/100', hex: '#fcfcfb' },
    bg: { token: 'neutral/1000', hex: '#472c19' },
    border: { token: 'neutral/700', hex: '#806c5b' },
    style: 'dark',
  },
  {
    name: 'Accent', desc: 'CTAs, active highlights',
    fg: { token: 'orange/1000', hex: '#4e1e00' },
    bg: { token: 'orange/500', hex: '#fe7800' },
    border: { token: 'orange/600', hex: '#d86600' },
    style: 'accent',
  },
  // Row 2: Interactive states
  {
    name: 'Hover', desc: 'Interactive hover',
    fg: { token: 'neutral/900', hex: '#59412c' },
    bg: { token: 'orange/100', hex: '#fff8f4' },
    border: { token: 'neutral/300', hex: '#f4ebe1' },
    style: 'light',
  },
  {
    name: 'Disabled', desc: 'Non-interactive',
    fg: { token: 'neutral/600', hex: '#948274' },
    bg: { token: 'neutral/300', hex: '#f4ebe1' },
    border: { token: 'neutral/400', hex: '#bcb1a8' },
    style: 'muted',
  },
  {
    name: 'Active', desc: 'Active / selected',
    fg: { token: 'orange/500', hex: '#fe7800' },
    bg: { token: 'orange/100', hex: '#fff8f4' },
    border: { token: 'orange/500', hex: '#fe7800' },
    style: 'active',
  },
  {
    name: 'Pressed', desc: 'Momentary click/tap',
    fg: { token: 'orange/700', hex: '#b35200' },
    bg: { token: 'orange/600', hex: '#d86600' },
    border: { token: 'orange/700', hex: '#b35200' },
    style: 'pressed',
  },
  // Row 3: Feedback states
  {
    name: 'Error', desc: 'Errors, destructive',
    fg: { token: 'red/500', hex: '#c01f1f' },
    bg: { token: 'red/100', hex: '#ffe3de' },
    border: { token: 'red/500', hex: '#c01f1f' },
    style: 'error',
  },
  {
    name: 'Success', desc: 'Confirmations, positive',
    fg: { token: 'green/800', hex: '#29771f' },
    bg: { token: 'green/100', hex: '#def2da' },
    border: { token: 'green/500', hex: '#39b54a' },
    style: 'success',
  },
  {
    name: 'Warning', desc: 'Caution, attention',
    fg: { token: 'yellow/800', hex: '#de8a16' },
    bg: { token: 'yellow/100', hex: '#f6ead1' },
    border: { token: 'yellow/500', hex: '#ffb700' },
    style: 'warning',
  },
]
---

<section class="color-states" aria-label="Color states system">
  <div class="states-header">
    <p class="states-subtitle">11 states × 3 categories (foreground, background, border)</p>
  </div>

  <div class="states-grid">
    {states.map(s => (
      <div class={`state-card state--${s.style}`} style={`--card-bg: ${s.bg.hex}; --card-fg: ${s.fg.hex}; --card-border: ${s.border.hex};`}>
        <div class="state-preview">
          <h4 class="state-name">{s.name}</h4>
          <p class="state-desc">{s.desc}</p>
        </div>
        <div class="state-tokens">
          <div class="token-row">
            <span class="token-category">fg</span>
            <code>{s.fg.token}</code>
            <span class="token-swatch" style={`background: ${s.fg.hex};`} />
          </div>
          <div class="token-row">
            <span class="token-category">bg</span>
            <code>{s.bg.token}</code>
            <span class="token-swatch" style={`background: ${s.bg.hex};`} />
          </div>
          <div class="token-row">
            <span class="token-category">border</span>
            <code>{s.border.token}</code>
            <span class="token-swatch" style={`background: ${s.border.hex};`} />
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .color-states {
    background: #fdf8f4;
    margin: 2rem 0;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
  }

  .states-header {
    margin-bottom: 1.25rem;
  }

  .states-subtitle {
    font-size: 0.85rem;
    color: #806c5b;
    margin: 0;
  }

  .states-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .state-card {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #f4ebe1;
  }

  .state-preview {
    background: var(--card-bg);
    border: 2px solid var(--card-border);
    border-radius: 10px 10px 0 0;
    padding: 0.85rem;
    min-height: 64px;
  }

  .state-name {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--card-fg);
    line-height: 1.2;
  }

  .state-desc {
    margin: 0.2rem 0 0;
    font-size: 0.72rem;
    color: var(--card-fg);
    opacity: 0.75;
    line-height: 1.3;
  }

  .state-tokens {
    background: white;
    padding: 0.6rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .token-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
  }

  .token-category {
    width: 36px;
    min-width: 36px;
    font-weight: 700;
    color: #806c5b;
    text-transform: uppercase;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
  }

  .token-row code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.68rem;
    color: #472c19;
    flex: 1;
  }

  .token-swatch {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    border: 1px solid rgba(0,0,0,0.08);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .states-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .states-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 380px) {
    .state-tokens {
      font-size: 0.65rem;
    }

    .token-row code {
      font-size: 0.6rem;
    }
  }
</style>
