---
/**
 * Elevation System diagram for Whataburger case study.
 * 5 elevation levels composed from shadow distance/blur/spread tokens
 */
const levels = [
  {
    name: 'elevation/raised',
    usage: 'Cards, interactive elements',
    layers: '1 layer',
    shadow: '0 2px 4px -1px rgba(71, 44, 25, 0.06)',
  },
  {
    name: 'elevation/overlay',
    usage: 'Dropdowns, popovers, tooltips',
    layers: '2 layers',
    shadow: '0 4px 8px -2px rgba(71, 44, 25, 0.08), 0 1px 4px 0px rgba(71, 44, 25, 0.04)',
  },
  {
    name: 'elevation/modal',
    usage: 'Modals, bottom sheets, dialogs',
    layers: '2 layers',
    shadow: '0 8px 16px -2px rgba(71, 44, 25, 0.12), 0 2px 4px -1px rgba(71, 44, 25, 0.04)',
  },
  {
    name: 'elevation/dramatic',
    usage: 'FABs, toasts, floating actions',
    layers: '2 layers',
    shadow: '0 16px 16px -4px rgba(71, 44, 25, 0.16), 0 4px 8px -2px rgba(71, 44, 25, 0.06)',
  },
  {
    name: 'elevation/inset',
    usage: 'Pressed states, sunken areas',
    layers: '1 layer (inner)',
    shadow: 'inset 0 -4px 8px 0px rgba(71, 44, 25, 0.08)',
  },
]
---

<section class="elevation-system" aria-label="Elevation system">
  <div class="elevation-cards">
    {levels.map(l => (
      <div class="elev-card">
        <div class="elev-preview" style={`box-shadow: ${l.shadow};`} />
        <div class="elev-info">
          <code class="elev-name">{l.name}</code>
          <p class="elev-usage">{l.usage}</p>
          <p class="elev-layers">{l.layers}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="shadow-tokens">
    <h4 class="shadow-tokens-title">Shadow Tokens (×100 Scale)</h4>
    <p class="shadow-tokens-desc">Primitives → Semantic (×100) → Effect Styles</p>
    <div class="token-table">
      <div class="token-table-row">
        <span class="token-table-label">Distance</span>
        <div class="token-table-values">
          <code>0→0</code> <code>100→1</code> <code>200→2</code> <code>400→4</code> <code>800→8</code> <code>1600→16</code> <code class="inset">inset→-4</code>
        </div>
      </div>
      <div class="token-table-row">
        <span class="token-table-label">Blur</span>
        <div class="token-table-values">
          <code>100→4</code> <code>200→8</code> <code>400→16</code>
        </div>
      </div>
      <div class="token-table-row">
        <span class="token-table-label">Spread</span>
        <div class="token-table-values">
          <code>0→0</code> <code>100→1</code> <code>200→-2</code> <code>400→-4</code>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .elevation-system {
    background: #fdf8f4;
    margin: 2rem 0;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
  }

  .elevation-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .elev-card {
    text-align: center;
  }

  .elev-preview {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: white;
    border-radius: 12px;
    border: 1px solid rgba(244, 235, 225, 0.5);
    margin-bottom: 0.75rem;
  }

  .elev-info {
    text-align: left;
  }

  .elev-name {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    color: #472c19;
    font-weight: 600;
    display: block;
    margin-bottom: 0.2rem;
  }

  .elev-usage {
    font-size: 0.72rem;
    color: #806c5b;
    margin: 0;
    line-height: 1.3;
  }

  .elev-layers {
    font-size: 0.68rem;
    color: #948274;
    margin: 0.15rem 0 0;
  }

  .shadow-tokens {
    background: #fdf8f4;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .shadow-tokens-title {
    font-size: 0.8rem;
    color: #806c5b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.15rem;
    font-weight: 700;
  }

  .shadow-tokens-desc {
    font-size: 0.75rem;
    color: #948274;
    margin: 0 0 0.75rem;
  }

  .token-table {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .token-table-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .token-table-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: #472c19;
    width: 70px;
    min-width: 70px;
  }

  .token-table-values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .token-table-values code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: #fe7800;
    background: white;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }

  .token-table-values code.inset {
    color: #948274;
  }

  @media (max-width: 768px) {
    .elevation-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .elevation-cards {
      grid-template-columns: 1fr 1fr;
    }
    .token-table-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
