---
/**
 * Auto-scrolling horizontal row of DeviceFrame phones for the hero.
 * GSAP handles everything: entrance animation + infinite scroll loop.
 * Respects prefers-reduced-motion.
 *
 * Architecture:
 *   .hero-phone-scroll  — overflow:hidden container
 *     .scroll-track     — flex row of phones; GSAP owns all transforms
 */
import { Image } from 'astro:assets'

interface Screen {
  src: ImageMetadata
  alt: string
}

interface Props {
  screens: Screen[]
}

const { screens } = Astro.props
---

<div class="hero-phone-scroll" aria-label="App screens showcase" data-no-lightbox>
  <div class="scroll-track">
    {/* First set — GSAP entrance targets */}
    {screens.map((s, i) => (
      <div class="scroll-phone" data-phone-index={i}>
        <Image src={s.src} alt={s.alt} width={730} format="webp" quality={90} loading="eager" class="device-screen" />
        <img src="/images/iphone-frame.png" alt="" loading="eager" class="device-frame" />
      </div>
    ))}
    {/* Duplicate set for seamless loop */}
    {screens.map(s => (
      <div class="scroll-phone" data-phone-dupe aria-hidden="true">
        <Image src={s.src} alt={s.alt} width={730} format="webp" quality={90} loading="eager" class="device-screen" />
        <img src="/images/iphone-frame.png" alt="" loading="eager" class="device-frame" />
      </div>
    ))}
  </div>
</div>

<style>
  .hero-phone-scroll {
    overflow: hidden;
    height: 85vh;
    display: flex;
    align-items: center;
    background: #FCF6ED;
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  /* Hide phones until GSAP sets initial state */
  .scroll-phone {
    opacity: 0;
  }

  .scroll-track {
    display: flex;
    gap: 6rem;
    width: max-content;
  }

  .scroll-phone {
    --phone-height: calc(85vh * 0.75);
    --phone-width: calc(var(--phone-height) * 0.484);
    display: grid;
    width: var(--phone-width);
    height: var(--phone-height);
    flex-shrink: 0;
    will-change: transform;
    cursor: default;
  }

  /* Grid stacking for frame overlay */
  .scroll-phone > :global(img) {
    grid-area: 1 / 1;
    background: transparent !important;
    padding: 0 !important;
    object-fit: initial !important;
    max-height: none !important;
    transition: none !important;
  }

  .scroll-phone > :global(img:hover) {
    scale: 1 !important;
  }

  .scroll-phone > :global(img.device-screen) {
    place-self: center;
    border-radius: 9%;
    z-index: 1;
    width: calc(var(--phone-width) * 0.975) !important;
    height: calc(var(--phone-height) * 0.988);
  }

  .scroll-phone > .device-frame {
    z-index: 2;
    pointer-events: none;
    width: 100% !important;
    height: 100%;
    object-fit: fill !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-phone {
      opacity: 1;
    }

    .scroll-track {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .scroll-phone[data-phone-dupe] {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero-phone-scroll {
      height: 60vh;
    }

    .scroll-phone {
      --phone-height: calc(60vh * 0.75);
    }

    .scroll-track {
      gap: 3rem;
    }
  }
</style>

<script>
  const INIT_ATTR = 'data-hero-initialized'

  async function initHeroEntrance() {
    const container = document.querySelector('.hero-phone-scroll') as HTMLElement | null
    if (!container || container.hasAttribute(INIT_ATTR)) return
    container.setAttribute(INIT_ATTR, '')

    const track = container.querySelector('.scroll-track') as HTMLElement
    if (!track) return

    // Reduced motion: show phones, no animation
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    const phones = Array.from(
      track.querySelectorAll<HTMLElement>('.scroll-phone:not([data-phone-dupe])')
    )
    const dupes = Array.from(
      track.querySelectorAll<HTMLElement>('.scroll-phone[data-phone-dupe]')
    )
    if (phones.length === 0) return

    const centerIndex = Math.floor(phones.length / 2)

    // ── Measure phone positions ──
    const rects = phones.map(p => p.getBoundingClientRect())
    const centerRect = rects[centerIndex]
    const centerX = centerRect.left + centerRect.width / 2

    // Each side phone starts tucked behind its inner neighbor
    const phoneOffsets = phones.map((_, i) => {
      if (i === centerIndex) return 0
      const neighborIndex = i < centerIndex ? i + 1 : i - 1
      const neighborMid = rects[neighborIndex].left + rects[neighborIndex].width / 2
      const phoneMid = rects[i].left + rects[i].width / 2
      return neighborMid - phoneMid
    })

    // Track offset to center the middle phone in viewport
    const viewportCenterX = window.innerWidth / 2
    const centerOffset = viewportCenterX - centerX

    // transformOrigin: center phone's position within the track
    const trackRect = track.getBoundingClientRect()
    const originX = centerRect.left - trackRect.left + centerRect.width / 2

    // ── Wait for images ──
    const allImages = track.querySelectorAll<HTMLImageElement>('.scroll-phone:not([data-phone-dupe]) img')
    await Promise.all(
      Array.from(allImages).map(img =>
        img.complete
          ? Promise.resolve()
          : new Promise(resolve => {
              img.addEventListener('load', resolve, { once: true })
              img.addEventListener('error', resolve, { once: true })
            })
      )
    )

    // ── Load GSAP ──
    const { default: gsap } = await import('gsap')

    // ── Set initial state ──
    phones.forEach((phone, i) => {
      const distFromCenter = Math.abs(i - centerIndex)
      gsap.set(phone, {
        opacity: 0,
        x: phoneOffsets[i],
        zIndex: phones.length - distFromCenter,
      })
    })
    gsap.set(dupes, { opacity: 0 })
    gsap.set(track, {
      x: centerOffset,
      scale: 2,
      transformOrigin: `${originX}px center`,
    })

    // ── Entrance timeline ──
    const halfWidth = track.scrollWidth / 2
    const isMobile = window.matchMedia('(max-width: 768px)').matches
    const scrollDuration = isMobile ? 40 : 60

    let scrollTween: ReturnType<typeof gsap.fromTo> | null = null

    function startScroll() {
      scrollTween = gsap.fromTo(track,
        { x: centerOffset },
        { x: centerOffset - halfWidth, duration: scrollDuration, repeat: -1, ease: 'none' }
      )
      // Start frozen, ease into full speed
      scrollTween.timeScale(0)
      gsap.to(scrollTween, { timeScale: 1, duration: 1, ease: 'power2.inOut' })
    }

    const tl = gsap.timeline()

    // GROUP SCALE: track scales down as one unit with spring
    tl.to(track, {
      scale: 1,
      duration: 2,
      ease: 'elastic.out(1, 1)',
    }, 0)

    // CENTER PHONE: fades in first — must complete before side phones start at 0.25s
    tl.to(phones[centerIndex], {
      opacity: 1,
      duration: 0.2,
      ease: 'power2.out',
    }, 0)

    // SIDE PHONES: left and right fan out symmetrically
    const leftPhones = phones.slice(0, centerIndex).reverse()
    const rightPhones = phones.slice(centerIndex + 1)
    const STAGGER = 0.18

    // Fast fade per phone
    const fadeConfig = {
      opacity: 1,
      duration: 0.08,
      ease: 'power2.out' as const,
      stagger: STAGGER,
    }
    tl.to(leftPhones, fadeConfig, 0.25)
    tl.to(rightPhones, fadeConfig, 0.25)

    // Slower x-slide to natural position
    const slideConfig = {
      x: 0,
      duration: 0.7,
      ease: 'power4.out' as const,
      stagger: STAGGER,
    }
    tl.to(leftPhones, slideConfig, 0.25)
    tl.to(rightPhones, slideConfig, 0.25)

    // Start scroll while phones are still fanning out — their motion masks the start
    tl.call(startScroll, [], 0.4)
    tl.set(dupes, { opacity: 1 }, 0.4)
  }

  initHeroEntrance()
  document.addEventListener('astro:page-load', initHeroEntrance)
</script>
