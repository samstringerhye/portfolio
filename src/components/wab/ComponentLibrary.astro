---
/**
 * Component library overview grid for Whataburger case study.
 * Shows the four component categories with counts and examples.
 * Reflects React Native / iOS architecture.
 */
---

<section class="comp-lib" aria-label="Component library overview">
  <div class="lib-header">
    <h4 class="lib-title">Component Library</h4>
    <p class="lib-subtitle">Organized as universal (cross-project reusable) and screen-specific (with promotion plan)</p>
  </div>

  <div class="lib-grid">
    <div class="lib-card">
      <div class="lib-card-header">
        <span class="lib-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <line x1="3" y1="9" x2="21" y2="9"/>
            <line x1="9" y1="21" x2="9" y2="9"/>
          </svg>
        </span>
        <h5 class="lib-card-title">Navigation</h5>
      </div>
      <ul class="lib-parts">
        <li>Tab Bar</li>
        <li>Header + Back</li>
        <li>Bottom Sheet</li>
        <li>Category Pills</li>
      </ul>
      <span class="lib-card-structure">Components + Parts</span>
    </div>

    <div class="lib-card">
      <div class="lib-card-header">
        <span class="lib-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
          </svg>
        </span>
        <h5 class="lib-card-title">Layout</h5>
      </div>
      <ul class="lib-parts">
        <li>Card Variants</li>
        <li>Section Headers</li>
        <li>Dividers + Spacing</li>
        <li>Grid Containers</li>
      </ul>
      <span class="lib-card-structure">Components + Parts</span>
    </div>

    <div class="lib-card">
      <div class="lib-card-header">
        <span class="lib-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </span>
        <h5 class="lib-card-title">Inputs</h5>
      </div>
      <ul class="lib-parts">
        <li>Text Fields</li>
        <li>Buttons (5 variants)</li>
        <li>Toggles + Checkboxes</li>
        <li>Quantity Steppers</li>
      </ul>
      <span class="lib-card-structure">Components + Parts</span>
    </div>

    <div class="lib-card">
      <div class="lib-card-header">
        <span class="lib-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </span>
        <h5 class="lib-card-title">Utilities</h5>
      </div>
      <ul class="lib-parts">
        <li>Toast Notifications</li>
        <li>Loading States</li>
        <li>Empty States</li>
        <li>Error Boundaries</li>
      </ul>
      <span class="lib-card-structure">Components + Parts</span>
    </div>
  </div>

  <div class="lib-footer">
    <div class="lib-footer-stat">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      <span><strong>90+ icons</strong> across 10 categories</span>
    </div>
    <div class="lib-footer-stat">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 19l7-7 3 3-7 7-3-3z"/>
        <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
        <path d="M2 2l7.586 7.586"/>
        <circle cx="11" cy="11" r="2"/>
      </svg>
      <span><strong>Custom illustration system</strong> for branded moments</span>
    </div>
    <div class="lib-footer-stat">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="16 18 22 12 16 6"/>
        <polyline points="8 6 2 12 8 18"/>
      </svg>
      <span><strong>Token names = React props</strong>. Zero translation layer</span>
    </div>
  </div>
</section>

<style>
  .comp-lib {
    background: #fdf8f4;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
    margin: 2rem 0;
  }

  .lib-header {
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f4ebe1;
  }

  .lib-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #472c19;
    margin: 0 0 0.25rem;
  }

  .lib-subtitle {
    font-size: 0.8rem;
    color: #806c5b;
    margin: 0;
    line-height: 1.4;
  }

  .lib-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .lib-card {
    background: white;
    border: 1px solid #f4ebe1;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
  }

  .lib-card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #f4ebe1;
  }

  .lib-card-icon {
    color: #fe7800;
    display: flex;
    flex-shrink: 0;
  }

  .lib-card-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #472c19;
    margin: 0;
  }

  .lib-parts {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .lib-parts li {
    font-size: 0.78rem;
    color: #806c5b;
    padding-left: 0.75rem;
    position: relative;
  }

  .lib-parts li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #cdb9a7;
    font-weight: 700;
  }

  .lib-card-structure {
    margin-top: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid #f4ebe1;
    font-size: 0.68rem;
    color: #a0846c;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lib-footer {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid #f4ebe1;
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .lib-footer-stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #472c19;
    line-height: 1.3;
  }

  .lib-footer-stat svg {
    color: #fe7800;
    flex-shrink: 0;
  }

  .lib-footer-stat strong {
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .lib-grid {
      grid-template-columns: 1fr 1fr;
    }

    .comp-lib {
      padding: 1.25rem;
    }

    .lib-footer {
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .lib-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
