---
/**
 * Scroll-triggered typography hierarchy animation.
 * Shows "before" (all identical all-caps text) morphing into
 * the proper M3-inspired type scale (Display, Headline, Body, Label, Caption).
 * Communicates "no hierarchy → clear roles" without screenshots.
 */
---

<section class="type-hierarchy" aria-label="Typography transformation visualization">
  <div class="th-stage">
    <div class="th-label th-label--before">
      <span class="th-label-tag">Before</span>
      <span class="th-label-text">One typeface. One size. No hierarchy.</span>
    </div>

    <div class="th-lines">
      <div class="th-line" data-role="display">
        <span class="th-text">WHATABURGER MENU</span>
        <span class="th-role">Display</span>
      </div>
      <div class="th-line" data-role="headline">
        <span class="th-text">BROWSE CATEGORIES</span>
        <span class="th-role">Headline</span>
      </div>
      <div class="th-line" data-role="body">
        <span class="th-text">CHOOSE YOUR FAVORITES FROM OUR FULL MENU</span>
        <span class="th-role">Body</span>
      </div>
      <div class="th-line" data-role="label">
        <span class="th-text">ADD TO ORDER</span>
        <span class="th-role">Label</span>
      </div>
      <div class="th-line" data-role="caption">
        <span class="th-text">PRICES MAY VARY BY LOCATION</span>
        <span class="th-role">Caption</span>
      </div>
    </div>

    <div class="th-label th-label--after">
      <span class="th-label-tag">After: Pele system</span>
      <span class="th-label-text">Five roles. Two typefaces. Semantic tokens.</span>
    </div>
  </div>
</section>

<style>
  @font-face {
    font-family: 'Alkaline';
    src: url('/fonts/Alkaline-Bold.otf') format('opentype');
    font-weight: 700;
    font-display: swap;
  }

  @font-face {
    font-family: 'Unbounded';
    src: url('/fonts/Unbounded-Variable.ttf') format('truetype');
    font-display: swap;
  }

  .type-hierarchy {
    background: #fdf8f4;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 3rem 2rem;
    margin: 2rem 0;
    overflow: hidden;
  }

  .th-stage {
    max-width: 700px;
    margin: 0 auto;
  }

  .th-lines {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .th-line {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  /* Before state: all identical */
  .th-text {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #472c19;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .th-role {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fe7800;
    opacity: 0;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .th-label {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .th-label--after {
    opacity: 0;
  }

  .th-label-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #a0846c;
    flex-shrink: 0;
  }

  .th-label--after .th-label-tag {
    color: #fe7800;
  }

  .th-label-text {
    font-size: 1rem;
    font-weight: 600;
    color: #472c19;
  }

  @media (max-width: 768px) {
    .type-hierarchy {
      padding: 2rem 1.25rem;
    }

    .th-text {
      font-size: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .th-label--after {
      opacity: 1;
    }

    .th-role {
      opacity: 1;
    }

    [data-role="display"] .th-text { font-family: 'Alkaline', Georgia, serif; font-size: 2rem; }
    [data-role="headline"] .th-text { font-family: 'Unbounded', sans-serif; font-size: 1.4rem; }
    [data-role="body"] .th-text { font-family: 'Unbounded', sans-serif; font-size: 1rem; font-weight: 400; text-transform: none; letter-spacing: 0; }
    [data-role="label"] .th-text { font-family: 'Unbounded', sans-serif; font-size: 0.85rem; letter-spacing: 0.06em; }
    [data-role="caption"] .th-text { font-family: 'Unbounded', sans-serif; font-size: 0.72rem; font-weight: 400; color: #806c5b; }
  }
</style>

<script>
  async function initTypeHierarchy() {
    const container = document.querySelector('.type-hierarchy') as HTMLElement | null
    if (!container || container.dataset.thInit === 'true') return
    container.dataset.thInit = 'true'

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    const { default: gsap } = await import('gsap')
    const { ScrollTrigger } = await import('gsap/ScrollTrigger')
    gsap.registerPlugin(ScrollTrigger)

    const lines = Array.from(container.querySelectorAll<HTMLElement>('.th-line'))
    const roles = Array.from(container.querySelectorAll<HTMLElement>('.th-role'))
    const texts = Array.from(container.querySelectorAll<HTMLElement>('.th-text'))
    const beforeLabel = container.querySelector('.th-label--before') as HTMLElement
    const afterLabel = container.querySelector('.th-label--after') as HTMLElement

    // Target styles for each role
    const targets: Record<string, Record<string, any>> = {
      display: { fontFamily: "'Alkaline', Georgia, serif", fontSize: '2rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.02em' },
      headline: { fontFamily: "'Unbounded', sans-serif", fontSize: '1.4rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.03em' },
      body: { fontFamily: "'Unbounded', sans-serif", fontSize: '1rem', fontWeight: 400, textTransform: 'none', letterSpacing: '0em' },
      label: { fontFamily: "'Unbounded', sans-serif", fontSize: '0.85rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.06em' },
      caption: { fontFamily: "'Unbounded', sans-serif", fontSize: '0.72rem', fontWeight: 400, textTransform: 'none', letterSpacing: '0.02em', color: '#806c5b' },
    }

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top 70%',
        end: 'top 10%',
        scrub: 1,
      }
    })

    // Animate each text line to its target style
    lines.forEach((line) => {
      const role = line.dataset.role!
      const text = line.querySelector('.th-text') as HTMLElement
      const roleLabel = line.querySelector('.th-role') as HTMLElement
      const target = targets[role]

      tl.to(text, {
        ...target,
        duration: 1,
        ease: 'power2.inOut',
      }, 0)

      // Fade in role labels
      tl.to(roleLabel, {
        opacity: 1,
        duration: 0.3,
        ease: 'power2.out',
      }, 0.5)
    })

    // Crossfade labels
    tl.to(beforeLabel, { opacity: 0, y: -10, duration: 0.3 }, 0.2)
    tl.to(afterLabel, { opacity: 1, y: 0, duration: 0.3 }, 0.5)
  }

  initTypeHierarchy()
  document.addEventListener('astro:page-load', initTypeHierarchy)
</script>
