---
/**
 * Typography Scale diagram for Whataburger case study.
 * M3-inspired naming: Display, Headline, Body, Label
 */
const typeScale = [
  { role: 'Display', size: 'Lg', px: 48, lh: 60, tracking: -0.5, weight: 'Bold', font: 'display', spacing: 'tighter' },
  { role: 'Display', size: 'Med', px: 26, lh: 33, tracking: -0.25, weight: 'Bold', font: 'display', spacing: 'tight' },
  { role: 'Display', size: 'Sm', px: 13, lh: 16, tracking: 0, weight: 'Bold', font: 'display', spacing: 'normal' },
  { role: 'Headline', size: 'Lg', px: 20, lh: 25, tracking: -0.25, weight: 'Bold', font: 'sans', spacing: 'tight' },
  { role: 'Headline', size: 'Med', px: 15, lh: 19, tracking: -0.25, weight: 'Bold', font: 'sans', spacing: 'tight' },
  { role: 'Headline', size: 'Sm', px: 15, lh: 19, tracking: 0, weight: 'Bold', font: 'sans', spacing: 'normal' },
  { role: 'Body', size: 'Lg', px: 16, lh: 20, tracking: 0, weight: 'Regular', font: 'sans', spacing: 'normal' },
  { role: 'Body', size: 'Med', px: 12, lh: 15, tracking: -0.25, weight: 'Regular', font: 'sans', spacing: 'tight' },
  { role: 'Body', size: 'Sm', px: 11, lh: 14, tracking: 0, weight: 'Regular', font: 'sans', spacing: 'normal' },
  { role: 'Label', size: 'Lg', px: 16, lh: 20, tracking: 0.5, weight: 'Bold', font: 'sans', spacing: 'wide' },
  { role: 'Label', size: 'Med', px: 13, lh: 16, tracking: 0.5, weight: 'Bold', font: 'sans', spacing: 'wide' },
  { role: 'Label', size: 'Sm', px: 10, lh: 13, tracking: 0.5, weight: 'Bold', font: 'sans', spacing: 'wide' },
]
---

<section class="type-scale" aria-label="Typography scale">
  <p class="scale-subtitle">13 text styles — M3-inspired naming, bound to semantic tokens</p>

  <div class="scale-table">
    {typeScale.map(t => (
      <div class={`scale-row scale-row--${t.role.toLowerCase()}`}>
        <div class="scale-specimen"
          style={`font-size: ${Math.min(t.px, 36)}px; line-height: ${t.lh / t.px}; font-weight: ${t.weight === 'Bold' ? 700 : 400}; letter-spacing: ${t.tracking}px; ${t.role === 'Label' ? 'text-transform: uppercase;' : ''}`}>
          {t.role} {t.size}
        </div>
        <div class="scale-meta">
          <span class="meta-size">{t.px}px / {t.lh} line-height / {t.tracking} tracking / {t.weight}</span>
          <code class="meta-tokens">size/{t.role.toLowerCase()}-{t.size.toLowerCase()} · line-height/{t.role.toLowerCase()}-{t.size.toLowerCase()} · letter-spacing/{t.spacing} · weight/{t.weight.toLowerCase()}</code>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .type-scale {
    background: #fdf8f4;
    border-radius: 0;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
    margin: 2rem 0;
  }

  .scale-subtitle {
    font-size: 0.85rem;
    color: #806c5b;
    margin: 0 0 1.5rem;
  }

  .scale-table {
    display: flex;
    flex-direction: column;
  }

  .scale-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 214, 186, 0.4);
  }

  .scale-row:last-child {
    border-bottom: none;
  }

  .scale-specimen {
    min-width: 200px;
    width: 200px;
    color: #472c19;
    white-space: nowrap;
  }

  @font-face {
    font-family: 'Alkaline';
    src: url('/fonts/Alkaline-Bold.otf') format('opentype');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Unbounded';
    src: url('/fonts/Unbounded-Variable.ttf') format('truetype');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  .scale-row--display .scale-specimen {
    font-family: 'Alkaline', Georgia, serif;
    font-style: normal;
  }

  .scale-row--headline .scale-specimen,
  .scale-row--body .scale-specimen,
  .scale-row--label .scale-specimen {
    font-family: 'Unbounded', sans-serif;
  }

  .scale-row--label .scale-specimen {
    letter-spacing: 0.5px;
  }

  .scale-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .meta-size {
    font-size: 0.78rem;
    color: #472c19;
    font-weight: 500;
  }

  .meta-tokens {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.68rem;
    color: #948274;
    word-break: break-all;
  }

  @media (max-width: 768px) {
    .scale-row {
      flex-direction: column;
      gap: 0.3rem;
    }
    .scale-specimen {
      min-width: unset;
      width: auto;
    }
    .type-scale {
      padding: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .scale-specimen {
      white-space: normal;
    }
  }
</style>
