---
/**
 * Visual Direction Exploration — 3-column comparison of design directions.
 * Shows Vibrant Bold, Modern, and Austin Dallas with key characteristics
 * and a winner indicator. Displays moodboard images where available.
 *
 * Follows the WAB component visual language: #fdf8f4 bg, brown/orange palette,
 * border-top/bottom pattern.
 */
import { Image } from 'astro:assets'
import vibrantMoodboard from '../../assets/work/wab-2026/direction-vibrant-moodboard.png'
import modernMoodboard from '../../assets/work/wab-2026/direction-modern-moodboard.png'
import austinMoodboard from '../../assets/work/wab-2026/direction-austin-moodboard.png'
---

<section class="direction-exploration" aria-label="Visual direction exploration">
  <div class="de-header">
    <h4 class="de-title">Visual Directions</h4>
    <p class="de-subtitle">Three directions pressure-tested against real wireframes to find the right balance of brand personality and functional clarity.</p>
  </div>

  <div class="de-grid">
    <!-- Direction 1: Vibrant Bold -->
    <div class="de-card">
      <div class="de-moodboard">
        <Image src={vibrantMoodboard} alt="Vibrant Bold moodboard — saturated blues, playful stickers, bold Alkaline type" width={600} format="webp" quality={85} loading="lazy" />
      </div>
      <div class="de-card-top">
        <span class="de-number">01</span>
        <h5 class="de-direction-name">Vibrant Bold</h5>
      </div>
      <div class="de-color-strip">
        <span class="de-swatch" style="background: #4ABAEB;" title="Sky blue"></span>
        <span class="de-swatch" style="background: #FE7800;" title="Bright orange"></span>
        <span class="de-swatch" style="background: #FFD24D;" title="Yellow"></span>
        <span class="de-swatch" style="background: #FFFFFF;" title="White"></span>
        <span class="de-swatch" style="background: #F5F0EB;" title="Warm white"></span>
      </div>
      <p class="de-description">Maximum brand energy. Saturated blues and oranges, playful sticker-style illustrations, and bold typography at every scale. Fun and unapologetically loud.</p>
      <ul class="de-traits">
        <li>Light blue backgrounds</li>
        <li>Sticker-like illustration system</li>
        <li>Alkaline display type at large scale</li>
        <li>High visual density</li>
      </ul>
      <div class="de-verdict de-verdict--merged">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        <span class="de-verdict-label">Merged into final direction</span>
      </div>
    </div>

    <!-- Direction 2: Modern -->
    <div class="de-card de-card--merged">
      <div class="de-moodboard">
        <Image src={modernMoodboard} alt="Modern moodboard — warm cream surfaces, clean orange accents, structured geometric layouts" width={600} format="webp" quality={85} loading="lazy" />
      </div>
      <div class="de-card-top">
        <span class="de-number">02</span>
        <h5 class="de-direction-name">Modern</h5>
      </div>
      <div class="de-color-strip">
        <span class="de-swatch" style="background: #FE7800;" title="Orange"></span>
        <span class="de-swatch" style="background: #FFB366;" title="Light orange"></span>
        <span class="de-swatch" style="background: #FDF8F4;" title="Warm cream"></span>
        <span class="de-swatch" style="background: #FFFFFF;" title="White"></span>
        <span class="de-swatch" style="background: #472C19;" title="Dark brown"></span>
      </div>
      <p class="de-description">Clean and restrained. Warm cream surfaces, orange as pure accent, geometric icons, and structured layouts. Functional clarity over personality.</p>
      <ul class="de-traits">
        <li>Cream/white backgrounds</li>
        <li>Geometric simplified icons</li>
        <li>Unbounded + Ultra type pairing</li>
        <li>Minimal visual density</li>
      </ul>
      <div class="de-verdict de-verdict--merged">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        <span class="de-verdict-label">Merged into final direction</span>
      </div>
    </div>

    <!-- Direction 3: Austin Dallas -->
    <div class="de-card">
      <div class="de-moodboard">
        <Image src={austinMoodboard} alt="Austin Dallas moodboard — dark backgrounds, warm browns, bright orange accents, premium feel" width={600} format="webp" quality={85} loading="lazy" />
      </div>
      <div class="de-card-top">
        <span class="de-number">03</span>
        <h5 class="de-direction-name">Austin Dallas</h5>
      </div>
      <div class="de-color-strip">
        <span class="de-swatch" style="background: #1A1410;" title="Near black"></span>
        <span class="de-swatch" style="background: #472C19;" title="Dark brown"></span>
        <span class="de-swatch" style="background: #FE7800;" title="Bright orange"></span>
        <span class="de-swatch" style="background: #C4885A;" title="Warm tan"></span>
        <span class="de-swatch" style="background: #FDF8F4;" title="Warm cream"></span>
      </div>
      <p class="de-description">Warm and premium. Dark backgrounds with rich browns and bright orange accents, textured photography, and restrained type. The brand's warmth without the noise.</p>
      <ul class="de-traits">
        <li>Dark moody backgrounds</li>
        <li>Warm hand-drawn illustrations</li>
        <li>Unbounded + Alkaline pairing</li>
        <li>Premium, atmospheric feel</li>
      </ul>
      <div class="de-verdict de-verdict--rejected">
        <span class="de-verdict-label">Too dark for a daily-use app</span>
      </div>
    </div>
  </div>

  <p class="de-footnote">The final direction took Vibrant Bold's iconography, typography, and bold color energy, then paired it with Modern's component structure and lighter palette.</p>
</section>

<style>
  .direction-exploration {
    background: #fdf8f4;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
    margin: 2rem 0;
  }

  .de-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f4ebe1;
  }

  .de-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #472c19;
    margin: 0 0 0.25rem;
  }

  .de-subtitle {
    font-size: 0.8rem;
    color: #806c5b;
    margin: 0;
    line-height: 1.5;
    max-width: 56ch;
  }

  .de-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .de-card {
    background: white;
    border: 1px solid #f4ebe1;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s ease;
  }

  .de-moodboard {
    margin: -1.25rem -1.25rem 0;
    overflow: hidden;
    border-bottom: 1px solid #f4ebe1;
  }

  .de-card--merged .de-moodboard {
    border-bottom-color: rgba(254, 120, 0, 0.2);
  }

  .de-moodboard :global(img) {
    width: 100%;
    height: auto;
    display: block;
    transition: scale 0.3s ease;
  }

  .de-moodboard:hover :global(img) {
    scale: 1.02;
  }

  .de-card--merged {
    border-color: #fe7800;
    box-shadow: 0 0 0 1px #fe7800;
  }

  .de-card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #f4ebe1;
  }

  .de-card--merged .de-card-top {
    border-bottom-color: rgba(254, 120, 0, 0.2);
  }

  .de-number {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: #a0846c;
    background: #fdf8f4;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }

  .de-card--merged .de-number {
    color: #fe7800;
    background: rgba(254, 120, 0, 0.08);
  }

  .de-direction-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #472c19;
    margin: 0;
    flex: 1;
  }

  .de-color-strip {
    display: flex;
    gap: 4px;
    height: 24px;
  }

  .de-swatch {
    flex: 1;
    border-radius: 4px;
    border: 1px solid rgba(71, 44, 25, 0.08);
  }

  .de-description {
    font-size: 0.78rem;
    color: #806c5b;
    line-height: 1.55;
    margin: 0;
  }

  .de-traits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .de-traits li {
    font-size: 0.72rem;
    color: #806c5b;
    padding-left: 0.75rem;
    position: relative;
  }

  .de-traits li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #cdb9a7;
    font-weight: 700;
  }

  .de-card--merged .de-traits li::before {
    color: #fe7800;
  }

  .de-verdict {
    margin-top: auto;
    padding-top: 0.6rem;
    border-top: 1px solid #f4ebe1;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .de-verdict-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .de-verdict--considered .de-verdict-label {
    color: #a0846c;
  }

  .de-verdict--merged {
    border-top-color: rgba(254, 120, 0, 0.2);
    color: #fe7800;
  }

  .de-verdict--merged .de-verdict-label {
    color: #fe7800;
  }

  .de-verdict--rejected .de-verdict-label {
    color: #a0846c;
  }

  .de-footnote {
    margin: 1.25rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid #f4ebe1;
    font-size: 0.78rem;
    color: #806c5b;
    line-height: 1.55;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .de-grid {
      grid-template-columns: 1fr;
    }

    .direction-exploration {
      padding: 1.25rem;
    }
  }
</style>
