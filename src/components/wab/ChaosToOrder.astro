---
/**
 * Scroll-triggered "Chaos to Order" morph animation.
 * Scattered orange rectangles organize into a structured color grid.
 * Communicates "no system → system" without needing old app screenshots.
 *
 * Architecture:
 *   .chaos-to-order  — overflow-hidden container, scroll-pinned
 *     .morph-canvas   — positioned container for elements
 *       .morph-el     — individual rectangles that animate
 *     .morph-labels   — before/after labels that crossfade
 */
---

<section class="chaos-to-order" aria-label="Design system transformation visualization">
  <div class="morph-stage">
    <div class="morph-label morph-label--before">
      <span class="morph-label-tag">Before</span>
      <span class="morph-label-text">One color. No states. No system.</span>
    </div>
    <div class="morph-canvas">
      {Array.from({ length: 12 }).map((_, i) => (
        <div class="morph-el" data-morph-index={i} />
      ))}
    </div>
    <div class="morph-label morph-label--after">
      <span class="morph-label-tag">After — Pele system</span>
      <span class="morph-label-text">258 tokens. 11 states. One system.</span>
    </div>
  </div>
</section>

<style>
  .chaos-to-order {
    background: #fdf8f4;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 3rem 2rem;
    margin: 2rem 0;
    overflow: hidden;
  }

  .morph-stage {
    max-width: 700px;
    margin: 0 auto;
  }

  .morph-canvas {
    position: relative;
    height: 280px;
    margin: 1.5rem 0;
  }

  .morph-el {
    position: absolute;
    width: 80px;
    height: 56px;
    background: #fe7800;
    border-radius: 2px;
  }

  .morph-label {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .morph-label--after {
    opacity: 0;
  }

  .morph-label-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #a0846c;
    flex-shrink: 0;
  }

  .morph-label--after .morph-label-tag {
    color: #fe7800;
  }

  .morph-label-text {
    font-size: 1rem;
    font-weight: 600;
    color: #472c19;
  }

  @media (max-width: 768px) {
    .chaos-to-order {
      padding: 2rem 1.25rem;
    }

    .morph-canvas {
      height: 220px;
    }

    .morph-el {
      width: 56px;
      height: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .morph-label--after {
      opacity: 1;
    }
  }
</style>

<script>
  async function initChaosToOrder() {
    const container = document.querySelector('.chaos-to-order') as HTMLElement | null
    if (!container || container.dataset.morphInit === 'true') return
    container.dataset.morphInit = 'true'

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    const { default: gsap } = await import('gsap')
    const { ScrollTrigger } = await import('gsap/ScrollTrigger')
    gsap.registerPlugin(ScrollTrigger)

    const canvas = container.querySelector('.morph-canvas') as HTMLElement
    const elements = Array.from(container.querySelectorAll<HTMLElement>('.morph-el'))
    const beforeLabel = container.querySelector('.morph-label--before') as HTMLElement
    const afterLabel = container.querySelector('.morph-label--after') as HTMLElement

    const canvasW = canvas.offsetWidth
    const canvasH = canvas.offsetHeight

    // Semantic colors for the "after" state
    const afterColors = [
      '#fe7800', '#ff9b40', '#ffbd80', // orange family
      '#472c19', '#6b4c35', '#a0846c', // brown family
      '#1a8754', '#d4382c', '#2563eb', // functional: success, error, info
      '#f4ebe1', '#ffffff', '#fdf8f4', // surfaces
    ]

    // Grid layout for "after" state: 4 columns × 3 rows
    const cols = 4
    const rows = 3
    const gap = 12
    const elW = (canvasW - (cols - 1) * gap) / cols
    const elH = (canvasH - (rows - 1) * gap) / rows

    const gridPositions = elements.map((_, i) => ({
      x: (i % cols) * (elW + gap),
      y: Math.floor(i / cols) * (elH + gap),
    }))

    // Chaos state: scattered, rotated, overlapping, all same orange
    elements.forEach((el, i) => {
      gsap.set(el, {
        x: Math.random() * (canvasW - 80),
        y: Math.random() * (canvasH - 56),
        rotation: (Math.random() - 0.5) * 40,
        scale: 0.6 + Math.random() * 0.8,
        opacity: 0.4 + Math.random() * 0.6,
        backgroundColor: '#fe7800',
        borderRadius: Math.random() * 12,
        zIndex: Math.floor(Math.random() * 12),
      })
    })

    // Timeline: chaos → order on scroll
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top 70%',
        end: 'top 10%',
        scrub: 1,
      }
    })

    // Morph elements to grid
    tl.to(elements, {
      x: (i: number) => gridPositions[i].x,
      y: (i: number) => gridPositions[i].y,
      width: elW,
      height: elH,
      rotation: 0,
      scale: 1,
      opacity: 1,
      backgroundColor: (i: number) => afterColors[i],
      borderRadius: 8,
      zIndex: 1,
      duration: 1,
      stagger: 0.03,
      ease: 'power2.inOut',
    }, 0)

    // Crossfade labels
    tl.to(beforeLabel, { opacity: 0, y: -10, duration: 0.3 }, 0.2)
    tl.to(afterLabel, { opacity: 1, y: 0, duration: 0.3 }, 0.5)

    // Add subtle elevation shadows at the end
    tl.to(elements, {
      boxShadow: '0 2px 8px rgba(71, 44, 25, 0.12)',
      duration: 0.3,
      stagger: 0.02,
    }, 0.7)
  }

  initChaosToOrder()
  document.addEventListener('astro:page-load', initChaosToOrder)
</script>
