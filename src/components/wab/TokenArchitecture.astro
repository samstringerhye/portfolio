---
/**
 * Token Architecture diagram for Whataburger case study.
 * Shows the 3-tier flow: Primitive → Semantic → Component
 */
---

<section class="token-arch" aria-label="Token architecture diagram">
  <div class="flow">
    <div class="tier">
      <div class="tier-header">
        <span class="tier-number">1</span>
        <div>
          <h4 class="tier-title">Primitive</h4>
          <p class="tier-subtitle">Raw values, never used directly</p>
        </div>
      </div>
      <ul class="token-list">
        <li><code>orange/500</code> <span class="val">#fe7800</span></li>
        <li><code>neutral/1000</code> <span class="val">#472c19</span></li>
        <li><code>spacing/16</code> <span class="val">16px</span></li>
        <li><code>radius/8</code> <span class="val">8px</span></li>
        <li><code>weight/700</code> <span class="val">Bold</span></li>
      </ul>
      <div class="tier-count">110 tokens</div>
    </div>

    <div class="arrow" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <div class="tier">
      <div class="tier-header">
        <span class="tier-number">2</span>
        <div>
          <h4 class="tier-title">Semantic</h4>
          <p class="tier-subtitle">Purpose-driven aliases</p>
        </div>
      </div>
      <ul class="token-list">
        <li><code>bg/accent</code> <span class="ref">→ orange/500</span></li>
        <li><code>fg/primary</code> <span class="ref">→ neutral/1000</span></li>
        <li><code>spacing/400</code> <span class="ref">→ spacing/16</span></li>
        <li><code>radius/200</code> <span class="ref">→ radius/8</span></li>
        <li><code>weight/bold</code> <span class="ref">→ weight/700</span></li>
      </ul>
      <div class="tier-count">128 tokens</div>
    </div>

    <div class="arrow" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <div class="tier">
      <div class="tier-header">
        <span class="tier-number">3</span>
        <div>
          <h4 class="tier-title">Component</h4>
          <p class="tier-subtitle">Bound to semantics</p>
        </div>
      </div>
      <ul class="token-list">
        <li><code>Button fill</code> <span class="ref">→ bg/accent</span></li>
        <li><code>Card text</code> <span class="ref">→ fg/primary</span></li>
        <li><code>Card padding</code> <span class="ref">→ spacing/400</span></li>
        <li><code>Card radius</code> <span class="ref">→ radius/200</span></li>
        <li><code>Headline</code> <span class="ref">→ weight/bold</span></li>
      </ul>
      <div class="tier-count">Bound in Figma</div>
    </div>
  </div>

  <div class="why-box">
    <strong>Why?</strong> Change <code>orange/500</code> once → every accent button, card, and highlight updates automatically.
  </div>
</section>

<style>
  .token-arch {
    --arch-bg: #fdf8f4;
    --arch-border: #ffd6ba;
    --arch-brown: #472c19;
    --arch-orange: #fe7800;
    --arch-muted: #806c5b;
    background: var(--arch-bg);
    border-radius: 0;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
    margin: 2rem 0;
  }

  .flow {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
  }

  .tier {
    flex: 1;
    background: white;
    border: 1px solid var(--arch-border);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
  }

  .tier-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--arch-border);
  }

  .tier-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    min-width: 28px;
    background: var(--arch-orange);
    color: white;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.85rem;
  }

  .tier-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--arch-brown);
    margin: 0;
    line-height: 1.2;
  }

  .tier-subtitle {
    font-size: 0.8rem;
    color: var(--arch-muted);
    margin: 0.15rem 0 0;
    line-height: 1.3;
  }

  .token-list {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .token-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    gap: 0.5rem;
  }

  .token-list code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    color: var(--arch-brown);
    background: var(--arch-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .val {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    color: var(--arch-muted);
  }

  .ref {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    color: var(--arch-orange);
  }

  .tier-count {
    margin-top: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--arch-border);
    font-size: 0.75rem;
    color: var(--arch-muted);
    text-align: center;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .arrow {
    display: flex;
    align-items: center;
    color: var(--arch-orange);
    flex-shrink: 0;
  }

  .why-box {
    margin-top: 1.25rem;
    padding: 0.85rem 1rem;
    background: white;
    border-left: 3px solid var(--arch-orange);
    border-radius: 0;
    font-size: 0.85rem;
    color: var(--arch-brown);
    line-height: 1.5;
  }

  .why-box code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    background: var(--arch-bg);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
  }

  @media (max-width: 768px) {
    .flow {
      flex-direction: column;
      gap: 0.25rem;
    }
    .arrow {
      justify-content: center;
      transform: rotate(90deg);
    }
    .token-arch {
      padding: 1.25rem;
    }
  }
</style>
