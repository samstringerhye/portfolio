---
/**
 * Before/After comparison of the old vs new design system.
 * Visualizes the structural problems and the Pele rebuild.
 */
---

<section class="system-ba" aria-label="Design system before and after comparison">
  <div class="ba-grid">
    <div class="ba-col ba-before">
      <div class="ba-label">Before</div>
      <h4 class="ba-title">Legacy System</h4>
      <ul class="ba-list">
        <li class="ba-item ba-problem">
          <span class="ba-icon">✕</span>
          <div>
            <strong>Brand-named tokens</strong>
            <span class="ba-detail">"Whataburger Orange" — named by appearance, not function</span>
          </div>
        </li>
        <li class="ba-item ba-problem">
          <span class="ba-icon">✕</span>
          <div>
            <strong>No interactive states</strong>
            <span class="ba-detail">One color per element — no hover, pressed, or disabled</span>
          </div>
        </li>
        <li class="ba-item ba-problem">
          <span class="ba-icon">✕</span>
          <div>
            <strong>No semantic layer</strong>
            <span class="ba-detail">Primitives only — every new screen meant inventing values</span>
          </div>
        </li>
        <li class="ba-item ba-problem">
          <span class="ba-icon">✕</span>
          <div>
            <strong>No spacing or elevation system</strong>
            <span class="ba-detail">Arbitrary values with no scale or convention</span>
          </div>
        </li>
        <li class="ba-item ba-problem">
          <span class="ba-icon">✕</span>
          <div>
            <strong>One display typeface everywhere</strong>
            <span class="ba-detail">All-caps branded type with no hierarchy or roles</span>
          </div>
        </li>
      </ul>
    </div>

    <div class="ba-divider" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <div class="ba-col ba-after">
      <div class="ba-label">After — Pele system</div>
      <h4 class="ba-title">Rebuilt System</h4>
      <ul class="ba-list">
        <li class="ba-item ba-success">
          <span class="ba-icon">✓</span>
          <div>
            <strong>3-tier token architecture</strong>
            <span class="ba-detail">Primitive → Semantic → Component — 258 variables</span>
          </div>
        </li>
        <li class="ba-item ba-success">
          <span class="ba-icon">✓</span>
          <div>
            <strong>11 interactive color states</strong>
            <span class="ba-detail">Foreground, background, and border for every state</span>
          </div>
        </li>
        <li class="ba-item ba-success">
          <span class="ba-icon">✓</span>
          <div>
            <strong>Semantic naming = React props</strong>
            <span class="ba-detail"><code>fg/primary</code> maps directly to component theme tokens</span>
          </div>
        </li>
        <li class="ba-item ba-success">
          <span class="ba-icon">✓</span>
          <div>
            <strong>Complete spatial system</strong>
            <span class="ba-detail">×100 scale for spacing, radius, elevation, and motion</span>
          </div>
        </li>
        <li class="ba-item ba-success">
          <span class="ba-icon">✓</span>
          <div>
            <strong>M3-inspired type scale</strong>
            <span class="ba-detail">Display, Headline, Body, Label — each with semantic tokens</span>
          </div>
        </li>
      </ul>
    </div>
  </div>

  <div class="ba-stats">
    <div class="ba-stat">
      <span class="ba-stat-number" data-target="258">0</span>
      <span class="ba-stat-label">Tokens</span>
    </div>
    <div class="ba-stat">
      <span class="ba-stat-number" data-target="3">0</span>
      <span class="ba-stat-label">Collections</span>
    </div>
    <div class="ba-stat">
      <span class="ba-stat-number" data-target="90" data-suffix="+">0</span>
      <span class="ba-stat-label">Icons</span>
    </div>
    <div class="ba-stat">
      <span class="ba-stat-number" data-target="11">0</span>
      <span class="ba-stat-label">Color States</span>
    </div>
  </div>
</section>

<style>
  .system-ba {
    background: #fdf8f4;
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    padding: 2rem;
    margin: 2rem 0;
  }

  .ba-grid {
    display: flex;
    gap: 1rem;
    align-items: stretch;
  }

  .ba-col {
    flex: 1;
    padding: 1.5rem;
    background: white;
    border: 1px solid #f4ebe1;
  }

  .ba-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .ba-before .ba-label {
    color: #a0846c;
  }

  .ba-after .ba-label {
    color: #fe7800;
  }

  .ba-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #472c19;
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f4ebe1;
  }

  .ba-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ba-item {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.85rem;
    line-height: 1.4;
    color: #472c19;
  }

  .ba-item div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .ba-detail {
    font-size: 0.75rem;
    color: #806c5b;
  }

  .ba-detail code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    background: #fdf8f4;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }

  .ba-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    margin-top: 1px;
  }

  .ba-problem .ba-icon {
    background: #f4ebe1;
    color: #a0846c;
  }

  .ba-success .ba-icon {
    background: #fe7800;
    color: white;
  }

  .ba-divider {
    display: flex;
    align-items: center;
    color: #fe7800;
    flex-shrink: 0;
  }

  .ba-stats {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #f4ebe1;
  }

  .ba-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .ba-stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fe7800;
    line-height: 1;
  }

  .ba-stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #806c5b;
  }

  @media (max-width: 768px) {
    .ba-grid {
      flex-direction: column;
      gap: 0.5rem;
    }

    .ba-divider {
      justify-content: center;
      transform: rotate(90deg);
    }

    .system-ba {
      padding: 1.25rem;
    }

    .ba-stats {
      gap: 1.5rem;
      flex-wrap: wrap;
    }
  }
</style>

<script>
  async function initSystemBA() {
    const container = document.querySelector('.system-ba') as HTMLElement | null
    if (!container || container.dataset.baInit === 'true') return
    container.dataset.baInit = 'true'

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Show final state immediately
      container.querySelectorAll<HTMLElement>('.ba-stat-number').forEach(el => {
        const target = el.dataset.target || '0'
        const suffix = el.dataset.suffix || ''
        el.textContent = target + suffix
      })
      return
    }

    const { default: gsap } = await import('gsap')
    const { ScrollTrigger } = await import('gsap/ScrollTrigger')
    gsap.registerPlugin(ScrollTrigger)

    // Staggered entrance for before/after items
    gsap.from('.ba-item', {
      y: 20,
      opacity: 0,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.ba-grid',
        start: 'top 80%',
      }
    })

    // Stat counter animation
    container.querySelectorAll<HTMLElement>('.ba-stat-number').forEach(el => {
      const target = parseInt(el.dataset.target || '0', 10)
      const suffix = el.dataset.suffix || ''
      const obj = { val: 0 }

      gsap.to(obj, {
        val: target,
        duration: 2,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '.ba-stats',
          start: 'top 85%',
        },
        onUpdate() {
          el.textContent = Math.round(obj.val) + suffix
        },
      })
    })
  }

  initSystemBA()
  document.addEventListener('astro:page-load', initSystemBA)
</script>
