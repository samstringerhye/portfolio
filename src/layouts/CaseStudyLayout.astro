---
import BaseLayout from './BaseLayout.astro'
import CaseStudyNav from '../components/CaseStudyNav.astro'

interface Props {
  title: string
  tagline?: string
  prevSlug?: string
  prevTitle?: string
  nextSlug?: string
  nextTitle?: string
}

const { title, tagline, prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
---

<BaseLayout title={`${title} — Sam Stringer-Hye`} description={tagline}>
  <article class="case-study-body">
    <slot />
  </article>

  <CaseStudyNav
    prevSlug={prevSlug}
    prevTitle={prevTitle}
    nextSlug={nextSlug}
    nextTitle={nextTitle}
  />
</BaseLayout>

<style is:global>
  .case-study-body {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
  }

  /* ── All children: full-width bordered frame ── */
  .case-study-body > * {
    grid-column: 1 / -1;
    border-left: var(--border-width-1) solid var(--color-text-primary);
    border-right: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
    margin: 0;
  }

  /* Border-top on first child (hero image) */
  .case-study-body > *:first-child {
    border-top: var(--border-width-1) solid var(--color-text-primary);
  }

  /* ── Hero image ── */
  .case-study-body .cs-hero-image {
    overflow: hidden;
  }

  .case-study-body .cs-hero-image img {
    width: 100%;
    display: block;
    aspect-ratio: 16/9;
  }

  /* ── Meta bar ── */
  .case-study-body .cs-hero-meta {
    display: flex;
    flex-direction: row;
    padding: 0;
  }

  .case-study-body .cs-meta-item {
    flex: 1 1 0%;
    display: flex;
    flex-direction: column;
    gap: var(--content-inset);
    padding: var(--content-inset);
  }

  .case-study-body .cs-meta-item + .cs-meta-item {
    border-left: var(--border-width-1) solid var(--color-text-primary);
  }

  .case-study-body .cs-meta-value {
    margin: 0;
  }

  /* ── Copy blocks: inset padding ── */
  /* Standalone elements (sub-section h3s, orphan paragraphs) */
  .case-study-body > h1,
  .case-study-body > h2,
  .case-study-body > h3,
  .case-study-body > p,
  .case-study-body > ul,
  .case-study-body > ol,
  .case-study-body > blockquote {
    padding: var(--content-inset);
  }

  /* Prose groups: inset the container, not individual children */
  .case-study-body .prose-group {
    padding: var(--content-inset);
  }

  /* ── Carousel: inherits bordered frame from > * rule ── */
  .case-study-body .carousel {
    overflow: hidden;
  }

  /* ── Images: flush to cell edges ── */
  .case-study-body > p:has(> img) {
    padding: 0;
  }

  .case-study-body img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Lists ── */
  .case-study-body ul {
    list-style: disc;
    padding-left: var(--content-inset);
  }

  .case-study-body li {
    margin-bottom: var(--space-1);
  }

  /* ── Image pairs: two images side by side ── */
  .case-study-body .image-pair {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--border-width-1);
    padding: 0;
    background: var(--color-text-primary);
    --pair-accent: var(--color-accent-1);
  }

  .case-study-body :nth-child(3n+1 of .image-pair) { --pair-accent: var(--color-accent-1); }
  .case-study-body :nth-child(3n+2 of .image-pair) { --pair-accent: var(--color-accent-2); }
  .case-study-body :nth-child(3n of .image-pair) { --pair-accent: var(--color-accent-3); }

  .case-study-body .image-pair p {
    margin: 0;
    padding: 0;
    border: none;
    background: var(--pair-accent);
    line-height: 0;
  }

  .case-study-body .image-pair img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Mobile ── */
  @media (--2x) {
    .case-study-body > h1,
    .case-study-body > h2,
    .case-study-body > h3,
    .case-study-body > p,
    .case-study-body > ul,
    .case-study-body > ol,
    .case-study-body > blockquote {
      padding-inline: var(--content-inset);
    }

    .case-study-body > ul {
      padding-left: var(--content-inset);
    }

    .case-study-body .image-pair {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: var(--border-width-1);
    }

    .case-study-body .cs-hero-meta {
      flex-wrap: wrap;
    }

    .case-study-body .cs-meta-item {
      flex: 1 1 45%;
    }

    .case-study-body .cs-meta-item + .cs-meta-item {
      border-left: none;
    }

    .case-study-body .cs-meta-item:nth-child(even) {
      border-left: var(--border-width-1) solid var(--color-text-primary);
    }

    .case-study-body .cs-meta-item:nth-child(n+3) {
      border-top: var(--border-width-1) solid var(--color-text-primary);
    }

  }
</style>

<script>
  function sizeImagePairs() {
    document.querySelectorAll('.image-pair').forEach(pair => {
      const imgs = pair.querySelectorAll('img')
      if (imgs.length !== 2) return

      const ratios = Array.from(imgs).map(img => {
        const w = parseInt(img.getAttribute('width')) || img.naturalWidth
        const h = parseInt(img.getAttribute('height')) || img.naturalHeight
        return w && h ? w / h : 0
      })

      if (ratios[0] > 0 && ratios[1] > 0) {
        pair.style.gridTemplateColumns = `${ratios[0]}fr ${ratios[1]}fr`
      }
    })
  }

  sizeImagePairs()
  document.addEventListener('astro:page-load', sizeImagePairs)
</script>
