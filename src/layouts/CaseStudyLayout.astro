---
import BaseLayout from './BaseLayout.astro'
import CaseStudyNav from '../components/CaseStudyNav.astro'

interface Props {
  title: string
  tagline?: string
  prevSlug?: string
  prevTitle?: string
  nextSlug?: string
  nextTitle?: string
}

const { title, tagline, prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props
---

<BaseLayout title={`${title} — Sam Stringer-Hye`} description={tagline}>
  <div class="scroll-progress"></div>
  <div class="img-cursor" aria-hidden="true">
    <svg class="cursor-icon-zoom" width="28" height="28" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="16" x2="7" y2="11"/><polyline points="2,12 2,16 6,16"/><line x1="16" y1="2" x2="11" y2="7"/><polyline points="16,6 16,2 12,2"/></svg>
    <svg class="cursor-icon-drag" width="28" height="28" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><line x1="1" y1="9" x2="6" y2="9"/><polyline points="3,7 1,9 3,11"/><line x1="17" y1="9" x2="12" y2="9"/><polyline points="15,7 17,9 15,11"/></svg>
  </div>
  <article class="case-study-body">
    <slot />
  </article>

  <CaseStudyNav
    prevSlug={prevSlug}
    prevTitle={prevTitle}
    nextSlug={nextSlug}
    nextTitle={nextTitle}
  />
</BaseLayout>

<style is:global>
  .case-study-body {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    row-gap: 0;
  }

  /* ── All children: full-width, no universal border ── */
  .case-study-body > * {
    grid-column: 1 / -1;
    margin: 0;
  }

  /* ── Bordered frame only on visual elements ── */
  .case-study-body .cs-hero-image,
  .case-study-body .cs-hero-meta,
  .case-study-body .image-pair,
  .case-study-body .carousel,
  .case-study-body .zigzag-section,
  .case-study-body .cs-figure,
  .case-study-body .image-grid,
  .case-study-body > img,
  .case-study-body .accent-band {
    border: var(--border-width-1) solid var(--color-text-primary);
  }

  /* Collapse doubled borders: when two bordered siblings are adjacent,
     pull the second one up by 1px so the borders overlap instead of stacking. */
  .case-study-body :is(.cs-hero-image, .cs-hero-meta, .image-pair, .carousel, .zigzag-section, .cs-figure, .image-grid, .accent-band, .lottie-grid)
  + :is(.cs-hero-meta, .image-pair, .carousel, .zigzag-section, .cs-figure, .image-grid, .accent-band, .lottie-grid) {
    margin-top: calc(-1 * var(--border-width-1));
  }


  /* ── Hero image ── */
  .case-study-body .cs-hero-image {
    overflow: hidden;
    border: none;
  }

  .case-study-body .cs-hero-image img {
    width: 100%;
    display: block;
    aspect-ratio: 16/9;
  }

  /* ── Meta bar ── */
  .case-study-body .cs-hero-meta {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
    padding: 0;
    margin-top: 0;
  }

  .case-study-body .cs-meta-item {
    grid-column: span 3;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
  }

  .case-study-body .cs-meta-item + .cs-meta-item {
    border-left: var(--border-width-1) solid var(--color-text-primary);
  }

  .case-study-body .cs-meta-value {
    margin: 0;
  }

  /* ── Copy blocks: align to column grid ── */
  .case-study-body > h1,
  .case-study-body > h2,
  .case-study-body > h3,
  .case-study-body > p,
  .case-study-body > ul,
  .case-study-body > ol,
  .case-study-body > blockquote {
    grid-column: 2 / 10;
    padding: 0;
  }

  /* Prose groups: columns 2–10 (8 of 12 columns) */
  .case-study-body .prose-group {
    grid-column: 2 / 10;
    padding: 0;
  }

  /* ── Carousel: inherits bordered frame from > * rule ── */
  .case-study-body .carousel {
    overflow: hidden;
  }

  .case-study-body .carousel-track {
    cursor: none;
  }

  /* ── Standalone images ── */
  .case-study-body > img {
    padding: 0;
  }

  .case-study-body img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
  }

  .case-study-body img.has-transparency {
    background: #fff;
    padding: var(--space-6);
    object-fit: contain;
  }

  .case-study-body .carousel-track img.has-transparency {
    padding: var(--space-5) var(--space-7);
  }

  /* ── Image hover: subtle scale + shadow lift + zoom cursor ── */
  .case-study-body .cs-hero-image,
  .case-study-body .cs-figure,
  .case-study-body .image-pair,
  .case-study-body .image-pair > img,
  .case-study-body .image-grid,
  .case-study-body .image-grid > .cs-figure,
  .case-study-body .zigzag-media,
  .case-study-body .carousel {
    overflow: hidden;
  }

  .case-study-body .cs-figure img,
  .case-study-body .image-pair img,
  .case-study-body .image-grid img,
  .case-study-body .zigzag-media {
    cursor: none;
    transition: scale 0.3s ease;
  }

  .case-study-body .zigzag-media img {
    cursor: none;
  }

  .case-study-body .cs-figure img:hover,
  .case-study-body .image-pair img:hover,
  .case-study-body .image-grid img:hover {
    scale: 1.02;
  }

  .case-study-body .zigzag-media:hover {
    scale: 1.02;
  }

  @media (prefers-reduced-motion: reduce) {
    .case-study-body img {
      transition: none;
    }
  }

  /* ── Lists ── */
  .case-study-body ul {
    list-style: disc;
    padding-left: 1.25em;
  }

  .case-study-body li {
    margin-bottom: var(--space-1);
  }

  /* ── Image pairs: two images side by side ── */
  .case-study-body .image-pair {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--border-width-1);
    padding: 0;
    background: var(--color-text-primary);
  }

  .case-study-body .image-pair > *,
  .case-study-body .image-pair-cell {
    margin: 0;
    padding: 0;
    border: none;
    background: var(--color-bg-primary);
    line-height: 0;
    overflow: hidden;
  }

  .case-study-body .image-pair img {
    display: block;
    width: 100%;
    height: auto;
  }

  .case-study-body .image-pair:has(img.has-transparency) {
    background: #fff;
    column-gap: 0;
  }

  .case-study-body .image-pair-cell:has(img.has-transparency) + .image-pair-cell {
    border-left: var(--border-width-1) solid var(--color-rule);
  }

  .case-study-body .image-pair-cell:has(img.has-transparency) {
    background: #fff;
  }

  .case-study-body .image-pair img.has-transparency {
    object-fit: contain;
    background: transparent;
  }

  /* ── Zigzag: alternating image/text 2-col sections ── */
  .case-study-body .zigzag-section {
    display: grid;
    grid-template-columns: subgrid;
  }

  .case-study-body .zigzag-media {
    grid-column: 2 / 7;
  }

  .case-study-body .zigzag-prose {
    grid-column: 7 / 12;
  }

  .case-study-body .zigzag-reversed .zigzag-media {
    grid-column: 7 / 12;
    grid-row: 1;
  }

  .case-study-body .zigzag-reversed .zigzag-prose {
    grid-column: 2 / 7;
    grid-row: 1;
  }


  .case-study-body .zigzag-media {
    overflow: hidden;
    line-height: 0;
    border-radius: var(--radius-lg);
  }

  .case-study-body .zigzag-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-study-body .zigzag-media .cs-figure {
    border: none;
    height: 100%;
    padding: 0;
  }

  .case-study-body .zigzag-media .cs-figure > p,
  .case-study-body .zigzag-media .cs-figure > img {
    height: 100%;
  }

  .case-study-body .zigzag-media .cs-figure figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-1) var(--space-3);
    background: linear-gradient(transparent, rgba(0,0,0,0.5));
    color: var(--color-bg-primary);
  }

  .case-study-body .zigzag-media .cs-figure {
    position: relative;
  }

  .case-study-body .zigzag-prose {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0;
    gap: var(--space-2);
  }

  .case-study-body .zigzag-prose .prose-group {
    padding: 0;
    border: none;
  }


  /* ── Accent band: full-width color section ── */
  .case-study-body .accent-band {
    padding-inline: var(--space-3);
  }
  .accent-band-1 { background: var(--color-accent-1); }
  .accent-band-2 { background: var(--color-accent-2); }
  .accent-band-3 { background: var(--color-accent-3); }

  /* Children inside accent band lose their own border */
  .case-study-body .accent-band > * {
    border: none;
  }

  /* ── Figure: image + figcaption ── */
  .case-study-body .cs-figure {
    padding-inline: 0;
  }

  .case-study-body .cs-figure > p,
  .case-study-body .cs-figure > img {
    padding: 0;
    margin: 0;
    border: none;
  }

  .case-study-body .cs-figure figcaption {
    padding: var(--space-2) 0 0;
    font-size: var(--text-100);
    color: var(--color-text-secondary);
    line-height: var(--line-height-normal);
  }

  /* ── Image grid: 2×2 (or n-column) layout ── */
  .case-study-body .image-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols, 2), 1fr);
    gap: var(--border-width-1);
    padding: 0;
    background: var(--color-text-primary);
  }

  .case-study-body .image-grid > .cs-figure,
  .case-study-body .image-grid > img {
    margin: 0;
    padding: 0;
    border: none;
    background: var(--color-bg-primary);
  }

  .case-study-body .image-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    max-height: 60vh;
  }

  .case-study-body .image-grid .cs-figure figcaption {
    background: var(--color-bg-primary);
  }

  /* ── Lottie grid: 4-col full-width with dividers ── */
  .case-study-body .lottie-grid {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--color-accent-1);
    border-top: var(--border-width-1) solid var(--color-text-primary);
    border-bottom: var(--border-width-1) solid var(--color-text-primary);
  }

  .case-study-body .lottie-grid .lottie-player {
    padding: var(--space-6);
    border-right: var(--border-width-1) solid var(--color-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .case-study-body .lottie-grid .lottie-player:last-child {
    border-right: none;
  }

  /* ── Vertical rhythm: block padding on containers ── */
  .case-study-body .zigzag-section,
  .case-study-body .accent-band,
  .case-study-body .cs-figure,
  .case-study-body .prose-group {
    padding-block: var(--space-7);
  }

  .case-study-body .cs-figure--flush {
    padding-block: 0;
  }

  .case-study-body .carousel {
    padding-block: var(--space-4);
  }

  /* ── Mobile ── */
  @media (--2x) {
    .case-study-body > h1,
    .case-study-body > h2,
    .case-study-body > h3,
    .case-study-body > p,
    .case-study-body > ul,
    .case-study-body > ol,
    .case-study-body > blockquote,
    .case-study-body .prose-group {
      grid-column: 1 / -1;
      padding-inline: var(--page-margin);
    }

    .case-study-body .zigzag-section {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .case-study-body .zigzag-media,
    .case-study-body .zigzag-prose {
      padding-inline: var(--page-margin);
    }

    .case-study-body .zigzag-prose {
      padding: 0 var(--page-margin);
    }

    /* Remove box borders on mobile — use horizontal dividers instead */
    .case-study-body .cs-hero-meta,
    .case-study-body .image-pair,
    .case-study-body .carousel,
    .case-study-body .zigzag-section,
    .case-study-body > .cs-figure,
    .case-study-body .image-grid,
    .case-study-body > img,
    .case-study-body .accent-band {
      border: none;
      border-top: var(--border-width-1) solid var(--color-rule);
      border-bottom: var(--border-width-1) solid var(--color-rule);
    }

    /* Collapse doubled borders on mobile too */
    .case-study-body :is(.cs-hero-image, .cs-hero-meta, .image-pair, .carousel, .zigzag-section, .cs-figure, .image-grid, .accent-band, .lottie-grid)
    + :is(.cs-hero-meta, .image-pair, .carousel, .zigzag-section, .cs-figure, .image-grid, .accent-band, .lottie-grid) {
      margin-top: calc(-1 * var(--border-width-1));
    }

    /* Figures inside grids/zigzags: no extra borders */
    .case-study-body .image-grid .cs-figure,
    .case-study-body .zigzag-media .cs-figure {
      border: none;
    }

    .case-study-body .image-pair,
    .case-study-body .image-grid {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 0;
      background: none;
    }

    /* Divider line between stacked images */
    .case-study-body .image-pair > *:not(:first-child),
    .case-study-body .image-pair-cell:not(:first-child),
    .case-study-body .image-grid > *:not(:first-child) {
      border-top: var(--border-width-1) solid var(--color-rule);
      border-left: none;
    }

    .case-study-body .lottie-grid {
      grid-template-columns: repeat(2, 1fr);
      border-left: none;
      border-right: none;
    }

    .case-study-body .lottie-grid .lottie-player:nth-child(2) {
      border-right: none;
    }

    .case-study-body .lottie-grid .lottie-player:nth-child(n+3) {
      border-top: var(--border-width-1) solid var(--color-text-primary);
    }

    .case-study-body .cs-hero-meta {
      display: flex;
      flex-direction: column;
    }

    .case-study-body .cs-meta-item {
      flex: none;
    }

    .case-study-body .cs-meta-item + .cs-meta-item {
      border-left: none;
      border-top: var(--border-width-1) solid var(--color-rule);
    }

  }

  /* ── Lightbox overlay ── */
  .lightbox-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 200);
  }

  .lightbox-overlay.is-open {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img-container {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img-container img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-lg);
    display: block;
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-primary);
    border: var(--border-width-1) solid var(--color-text-primary);
    color: var(--color-text-primary);
    cursor: pointer;
    padding: 0;
  }

  .lightbox-close:hover {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-primary);
    border: var(--border-width-1) solid var(--color-text-primary);
    color: var(--color-text-primary);
    cursor: pointer;
    padding: 0;
  }

  .lightbox-nav:hover {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .lightbox-nav-prev { left: var(--space-3); }
  .lightbox-nav-next { right: var(--space-3); }

  .lightbox-counter {
    position: absolute;
    bottom: var(--space-3);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: var(--text-100);
    color: var(--color-bg-primary);
    background: rgba(0, 0, 0, 0.5);
    padding: var(--space-1) var(--space-2);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  /* ── Scroll progress bar ── */
  .scroll-progress {
    position: fixed;
    top: var(--nav-height, 4rem);
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--color-accent-1);
    z-index: var(--z-nav, 100);
    pointer-events: none;
    transition: none;
  }

  /* ── Custom image cursor ── */
  .img-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--cursor-bg, var(--color-accent-1));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: var(--z-modal, 200);
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    transition:
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.2s ease,
      background 0.3s ease;
    will-change: transform;
  }

  .img-cursor svg {
    flex-shrink: 0;
  }

  .img-cursor.is-visible {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .img-cursor {
      transition: none;
    }
  }

  /* Hide on touch devices */
  @media (pointer: coarse) {
    .img-cursor { display: none; }
  }
</style>

<script>
  const mobileQuery = window.matchMedia('(max-width: 768px)')

  function sizeImagePairs() {
    const isMobile = mobileQuery.matches
    document.querySelectorAll('.image-pair').forEach(pair => {
      const imgs = pair.querySelectorAll('img')
      if (imgs.length !== 2) return

      if (isMobile) {
        pair.style.gridTemplateColumns = ''
        return
      }

      const ratios = Array.from(imgs).map(img => {
        const w = parseInt(img.getAttribute('width')) || img.naturalWidth
        const h = parseInt(img.getAttribute('height')) || img.naturalHeight
        return w && h ? w / h : 0
      })

      if (ratios[0] > 0 && ratios[1] > 0) {
        pair.style.gridTemplateColumns = `${ratios[0]}fr ${ratios[1]}fr`
      }
    })
  }

  sizeImagePairs()
  mobileQuery.addEventListener('change', sizeImagePairs)
  document.addEventListener('astro:page-load', sizeImagePairs)
</script>

<script>
  function detectTransparentImages() {
    const body = document.querySelector('.case-study-body')
    if (!body) return

    body.querySelectorAll<HTMLImageElement>('img').forEach(img => {
      const check = () => {
        if (!img.naturalWidth) return
        const canvas = document.createElement('canvas')
        canvas.width = Math.min(img.naturalWidth, 100)
        canvas.height = Math.min(img.naturalHeight, 100)
        const ctx = canvas.getContext('2d')!
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height)
        const data = ctx.getImageData(0, 0, canvas.width, canvas.height).data
        // Sample corner pixels for alpha < 255
        const corners = [
          3,                                          // top-left
          (canvas.width - 1) * 4 + 3,               // top-right
          (canvas.height - 1) * canvas.width * 4 + 3, // bottom-left
          ((canvas.height - 1) * canvas.width + canvas.width - 1) * 4 + 3, // bottom-right
        ]
        const hasAlpha = corners.some(i => data[i] < 250)
        if (hasAlpha) {
          img.classList.add('has-transparency')
        }
      }
      if (img.complete) check()
      else img.addEventListener('load', check, { once: true })
    })
  }

  detectTransparentImages()
  document.addEventListener('astro:page-load', detectTransparentImages)
</script>

<script>
  function initImageCursor() {
    const cursor = document.querySelector('.img-cursor') as HTMLElement
    if (!cursor || window.matchMedia('(pointer: coarse)').matches) return

    const icons = {
      zoom: cursor.querySelector('.cursor-icon-zoom') as HTMLElement,
      drag: cursor.querySelector('.cursor-icon-drag') as HTMLElement,
    }
    const allIcons = Object.values(icons)

    const imageTargets = document.querySelectorAll(
      '.case-study-body .cs-figure img, .case-study-body .image-pair img, .case-study-body .image-grid img, .case-study-body .zigzag-media img'
    )
    const carouselTargets = document.querySelectorAll(
      '.case-study-body .carousel-track'
    )

    const accents = [
      'var(--color-accent-1)',
      'var(--color-accent-2)',
      'var(--color-accent-3)',
    ]
    let colorIndex = 0
    let raf = 0
    let mx = 0
    let my = 0
    let cx = 0
    let cy = 0
    let active = false

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t }

    function tick() {
      if (!active) return
      cx = lerp(cx, mx, 0.15)
      cy = lerp(cy, my, 0.15)
      cursor.style.left = `${cx}px`
      cursor.style.top = `${cy}px`
      raf = requestAnimationFrame(tick)
    }

    function showIcon(type: 'zoom' | 'drag') {
      allIcons.forEach(icon => icon.style.display = 'none')
      icons[type].style.display = ''
    }

    function onEnter(type: 'zoom' | 'drag') {
      return (e: MouseEvent) => {
        mx = e.clientX; my = e.clientY
        cx = mx; cy = my
        cursor.style.left = `${cx}px`
        cursor.style.top = `${cy}px`
        cursor.style.setProperty('--cursor-bg', accents[colorIndex])
        colorIndex = (colorIndex + 1) % accents.length
        showIcon(type)
        active = true
        cursor.classList.add('is-visible')
        raf = requestAnimationFrame(tick)
      }
    }

    function onMove(e: MouseEvent) {
      mx = e.clientX; my = e.clientY
    }

    function onLeave() {
      active = false
      cursor.classList.remove('is-visible')
      cancelAnimationFrame(raf)
    }

    imageTargets.forEach(el => {
      el.addEventListener('mouseenter', onEnter('zoom') as EventListener)
      el.addEventListener('mousemove', onMove as EventListener)
      el.addEventListener('mouseleave', onLeave)
    })

    carouselTargets.forEach(el => {
      el.addEventListener('mouseenter', onEnter('drag') as EventListener)
      el.addEventListener('mousemove', onMove as EventListener)
      el.addEventListener('mouseleave', onLeave)
    })

  }

  initImageCursor()
  document.addEventListener('astro:page-load', initImageCursor)
</script>
