---
import { ViewTransitions } from 'astro:transitions'
import SEO from '../components/SEO.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import RGBShutter from '../components/RGBShutter.astro'
import { ref, sys, elementMap, animations } from '../data/tokens'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  hideFooter?: boolean
}

const { title, description, ogImage, jsonLd, hideFooter = false } = Astro.props

/* ── Helper: fluid clamp from min→max rem across 480→1140px ── */
function buildClamp(min: number, max: number): string {
  if (min === max) return `${min}rem`
  const rootPx = 16
  const vwMin = 480
  const vwMax = 1140
  const slope = ((max - min) * rootPx * 100) / (vwMax - vwMin)
  const intercept = min - (slope * vwMin) / (100 * rootPx)
  return `clamp(${min.toFixed(4)}rem, ${intercept.toFixed(4)}rem + ${slope.toFixed(4)}vw, ${max.toFixed(4)}rem)`
}

/* ── Helper: resolve a token value (number, string, or {min,max}) to CSS ── */
function cssVal(val: any, unit = 'rem'): string {
  if (typeof val === 'string') return val
  if (typeof val === 'number') return `${val}${unit}`
  if (val && typeof val === 'object' && 'min' in val && 'max' in val) return buildClamp(val.min, val.max)
  return String(val)
}

/* ── Helper: camelCase → kebab-case ── */
function kebab(s: string): string {
  return s.replace(/([a-z])([A-Z])/g, '$1-$2').toLowerCase()
}

/* ── Helper: flatten nested object into CSS var entries ── */
function flattenObject(obj: Record<string, any>, prefix: string): string[] {
  const result: string[] = []
  for (const [key, val] of Object.entries(obj)) {
    const varName = `${prefix}-${kebab(key)}`
    if (typeof val === 'object' && val !== null && !Array.isArray(val)) {
      result.push(...flattenObject(val, varName))
    } else {
      result.push(`${varName}: ${val};`)
    }
  }
  return result
}

/* ── Typography vars ── */
const scaleVars = Object.entries(ref.font.scale).map(([key, val]) => {
  if (typeof val === 'number') return `--text-${key}: ${val}rem;`
  const v = val as { min: number; max: number }
  return `--text-${key}: ${buildClamp(v.min, v.max)};`
}).join('\n    ')

const leadingVars = Object.entries(ref.font.lineHeight)
  .map(([key, val]) => `--line-height-${key}: ${val};`).join('\n    ')

const trackingVars = Object.entries(ref.font.tracking)
  .map(([key, val]) => `--tracking-${key}: ${val};`).join('\n    ')

const fontVars = Object.entries(ref.font.family)
  .map(([key, val]) => `--font-${key}: ${val};`).join('\n    ')

const weightVars = Object.entries(ref.font.weight)
  .map(([key, val]) => `--font-weight-${key}: ${val};`).join('\n    ')

/* ── Color vars (flatten sys.color to --color-*) ── */
const colorVars = flattenObject(sys.color, '--color').join('\n    ')

/* ── Spacing vars ── */
const spacingVars = Object.entries(ref.spacing).map(([key, val]) => {
  if (typeof val === 'number') return `--space-${key}: ${val}rem;`
  const v = val as { min: number; max: number }
  return `--space-${key}: ${buildClamp(v.min, v.max)};`
}).join('\n    ')

/* ── Layout vars ── */
const layoutVars = [
  `--page-margin: ${cssVal(sys.layout.pageMargin)};`,
  `--content-inset-sm: ${cssVal(sys.layout.contentInset.sm)};`,
  `--content-inset-md: ${cssVal(sys.layout.contentInset.md)};`,
  `--content-inset-lg: ${cssVal(sys.layout.contentInset.lg)};`,
  `--content-inset: var(--content-inset-md);`,
  `--grid-gutter: ${cssVal(sys.layout.gridGutter)};`,
  `--section-padding: ${cssVal(sys.layout.sectionPadding)};`,
  `--nav-height: ${sys.layout.navHeight};`,
].join('\n    ')

/* ── Sizing vars ── */
const sizingVars = [
  `--touch-target: ${ref.sizing.touchTarget};`,
  `--section-rule-mark-size: ${ref.sizing.sectionRuleMark};`,
  `--wordmark-size: ${ref.sizing.wordmark};`,
  `--wordmark-size-mobile: ${ref.sizing.wordmarkMobile};`,
  `--nav-toggle-bar-width: ${ref.sizing.navToggleBarWidth};`,
  `--nav-toggle-bar-height: ${ref.sizing.navToggleBarHeight};`,
  `--nav-toggle-gap: ${ref.sizing.navToggleGap};`,
  `--prose-measure: ${ref.sizing.proseMeasure};`,
  `--cs-section-gap: var(--space-3);`,
].join('\n    ')

/* ── Inline spacing vars ── */
const inlineSpacingVars = Object.entries(ref.inlineSpacing)
  .map(([key, val]) => `--inline-spacing-${key}: ${val};`).join('\n    ')

/* ── Radii vars (new semantic names + old aliases) ── */
const radiiVars = Object.entries(ref.radii)
  .map(([key, val]) => `--radius-${key}: ${val};`).join('\n    ')

/* ── Z-index vars (from sys.layer) ── */
const zVars = Object.entries(sys.layer)
  .map(([key, val]) => `--z-${kebab(key)}: ${val};`).join('\n    ')

/* ── Duration vars (new names + old aliases) ── */
const durationVars = Object.entries(ref.motion.duration)
  .map(([key, val]) => `--duration-${key}: ${val};`).join('\n    ')

/* ── Easing vars ── */
const easingVars = Object.entries(ref.motion.easing)
  .map(([key, val]) => `--easing-${key}: ${val};`).join('\n    ')

/* ── Elevation vars ── */
const elevationRefVars = Object.entries(ref.elevation)
  .map(([key, val]) => `--elevation-${key}: ${val};`).join('\n    ')
const elevationSysVars = Object.entries(sys.elevation)
  .map(([key, val]) => `--elevation-${kebab(key)}: ${val};`).join('\n    ')

/* ── Border width vars ── */
const borderWidthVars = Object.entries(ref.border.width)
  .map(([key, val]) => `--border-width-${key}: ${val};`).join('\n    ')

/* ── Focus ring vars ── */
const focusRingVars = [
  `--focus-ring-width: ${sys.focus.ring.width};`,
  `--focus-ring-color: ${sys.focus.ring.color};`,
  `--focus-ring-offset: ${sys.focus.ring.offset};`,
].join('\n    ')

/* ── Modal vars ── */
const modalVars = Object.entries(sys.modal)
  .map(([key, val]) => `--modal-${kebab(key)}: ${val};`).join('\n    ')

/* ── Scrollbar vars ── */
const scrollbarVars = Object.entries(sys.scrollbar)
  .map(([key, val]) => `--scrollbar-${key}: ${val};`).join('\n    ')

/* ── Opacity vars ── */
const opacityVars = Object.entries(ref.opacity)
  .map(([key, val]) => `--opacity-${key}: ${val};`).join('\n    ')

/* ── Hover vars ── */
const hoverVars = Object.entries(sys.hover)
  .map(([key, val]) => {
    const unit = typeof val === 'number' && key !== 'perspective' ? '' : typeof val === 'number' ? 'px' : ''
    return `--hover-${kebab(key)}: ${val}${unit};`
  }).join('\n    ')

/* ── Prose block styling vars ── */
const proseVars = [
  `--prose-code-bg: ${sys.prose.code.bg};`,
  `--prose-code-padding-inline: ${cssVal(sys.prose.code.paddingInline)};`,
  `--prose-code-padding-block: ${cssVal(sys.prose.code.paddingBlock)};`,
  `--prose-code-border-radius: ${cssVal(sys.prose.code.borderRadius)};`,
  `--prose-code-block-padding: ${cssVal(sys.prose.code.blockPadding)};`,
  `--prose-code-block-radius: ${cssVal(sys.prose.code.blockRadius)};`,
].join('\n    ')

/* ── Typography role utility classes ── */
const typescale = sys.typescale as Record<string, { family: string; weight: number; scale: number | { min: number; max: number }; lineHeight: number; tracking: string; textTransform?: string }>

/* Reverse lookup: resolved literal family → CSS var */
const familyToVar = Object.fromEntries(
  Object.entries(ref.font.family).map(([key, val]) => [val, `var(--font-${key})`])
) as Record<string, string>

const roleRules = Object.entries(typescale).map(([name, cfg]) => {
  const fontSize = typeof cfg.scale === 'number' ? `${cfg.scale}rem` : buildClamp(cfg.scale.min, cfg.scale.max)
  const family = familyToVar[cfg.family] ?? cfg.family
  const trackingLine = cfg.tracking && cfg.tracking !== '0rem' ? `\n    --ls-adjust: ${cfg.tracking};` : ''
  const transformLine = cfg.textTransform ? `\n    text-transform: ${cfg.textTransform};` : ''
  return `.typo-${name} {
    font-family: ${family};
    font-weight: ${cfg.weight};
    font-size: ${fontSize};
    line-height: ${cfg.lineHeight};${trackingLine}${transformLine}
  }`
}).join('\n  ')

/* ── Element-level base styles from elementMap ── */
const elementRules = Object.entries(elementMap).map(([el, roleName]) => {
  const cfg = typescale[roleName]
  if (!cfg) return ''
  const fontSize = typeof cfg.scale === 'number' ? `${cfg.scale}rem` : buildClamp(cfg.scale.min, cfg.scale.max)
  const family = familyToVar[cfg.family] ?? cfg.family
  return `${el} {
    font-family: ${family};
    font-weight: ${cfg.weight};
    font-size: ${fontSize};
    line-height: ${cfg.lineHeight};
  }`
}).filter(Boolean).join('\n  ')

/* ── Assemble the full :root block ── */
const typoCss = `:root {
    ${fontVars}
    --font-primary: var(--font-sans);
    ${weightVars}
    ${scaleVars}
    ${leadingVars}
    ${trackingVars}
    ${colorVars}
    ${spacingVars}
    ${inlineSpacingVars}
    ${layoutVars}
    ${sizingVars}
    ${radiiVars}
    ${zVars}
    ${durationVars}
    ${easingVars}
    ${elevationRefVars}
    ${elevationSysVars}
    ${borderWidthVars}
    ${focusRingVars}
    ${modalVars}
    ${scrollbarVars}
    ${opacityVars}
    ${hoverVars}
    ${proseVars}
    --max-content-width: calc(1440px + 4rem);
    --focus-ring: 0 0 0 var(--focus-ring-width) var(--color-bg-primary), 0 0 0 calc(var(--focus-ring-width) + var(--focus-ring-offset)) var(--focus-ring-color);
    --border-light: var(--border-width-1) solid var(--color-rule);
  }
  ${roleRules}
  ${elementRules}`
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400;1,9..40,500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Mono:wght@400;500&subset=latin&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400;1,9..40,500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Mono:wght@400;500&subset=latin&display=swap" rel="stylesheet" /></noscript>
    <style set:html={typoCss}></style>
    <noscript><style>.cmy-word, .hero-block { opacity: 1 !important; transform: none !important; filter: none !important; }</style></noscript>
    <ViewTransitions fallback="swap" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>
    <div class="grid-overlay" aria-hidden="true"></div>
    <Nav />
    <main id="main" class="grid-12" tabindex="-1">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    <RGBShutter />
    <script>
      import Lenis from 'lenis'
      import gsap from 'gsap'
      import { ScrollTrigger } from 'gsap/ScrollTrigger'
      import { animations } from '../data/tokens'

      gsap.registerPlugin(ScrollTrigger)

      const scrollCfg = animations.smoothScroll
      let lenis: InstanceType<typeof Lenis> | null = null
      let lenisTicker: ((time: number) => void) | null = null

      type GlobalInitState = Window & {
        __siteAfterSwapHandler?: () => void
        __sitePageLoadHandler?: () => void
        __siteDestroyLenis?: () => void
      }

      function destroyLenis() {
        if (lenisTicker) {
          gsap.ticker.remove(lenisTicker)
          lenisTicker = null
        }

        lenis?.destroy()
        lenis = null
      }

      function initLenis() {
        destroyLenis()

        // Respect reduced motion
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        if (prefersReduced) return

        lenis = new Lenis({ lerp: scrollCfg.lerp, smoothWheel: true, wheelMultiplier: scrollCfg.wheelMultiplier })

        lenis.on('scroll', ScrollTrigger.update)
        lenisTicker = (time) => lenis?.raf(time * 1000)
        gsap.ticker.add(lenisTicker)
        gsap.ticker.lagSmoothing(0)
      }

      async function initInteractions() {
        try {
          const { initScrollReveals } = await import('../components/scroll-reveals.ts')
          const { initHoverEffects } = await import('../components/hover-effects.ts')
          const { initLightbox } = await import('../components/Lightbox.ts')
          await initScrollReveals()
          initHoverEffects()
          initLightbox()
          initScrollProgress()
        } catch (e) {
          console.warn('Failed to init interactions', e)
        }
      }

      let scrollProgressTrigger: ScrollTrigger | null = null

      function initScrollProgress() {
        // Kill previous trigger to prevent accumulation across page navigations
        scrollProgressTrigger?.kill()
        scrollProgressTrigger = null

        const bar = document.querySelector<HTMLElement>('.scroll-progress')
        if (!bar) return

        const tween = gsap.to(bar, {
          width: '100%',
          ease: 'none',
          scrollTrigger: {
            trigger: document.querySelector('.case-study-body') || document.body,
            start: 'top top',
            end: 'bottom bottom',
            scrub: true,
          },
        })
        scrollProgressTrigger = tween.scrollTrigger ?? null
      }

      const globalState = window as GlobalInitState

      if (globalState.__siteAfterSwapHandler) {
        document.removeEventListener('astro:after-swap', globalState.__siteAfterSwapHandler)
      }
      if (globalState.__sitePageLoadHandler) {
        document.removeEventListener('astro:page-load', globalState.__sitePageLoadHandler)
      }
      globalState.__siteDestroyLenis?.()

      const handleAfterSwap = () => {
        initLenis()
        ScrollTrigger.refresh()
      }

      const handlePageLoad = () => {
        initInteractions()
      }

      globalState.__siteAfterSwapHandler = handleAfterSwap
      globalState.__sitePageLoadHandler = handlePageLoad
      globalState.__siteDestroyLenis = destroyLenis

      initLenis()
      initInteractions()

      document.addEventListener('astro:after-swap', handleAfterSwap)
      document.addEventListener('astro:page-load', handlePageLoad)
    </script>

  </body>
</html>
